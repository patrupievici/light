<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>ZVELT — Welcome</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&amp;family=Inter:wght@300;400;600&amp;family=Space+Grotesk:wght@400;700&amp;family=Space+Mono:wght@400;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<style>body {
    background-color: #121316;
    color: #e3e2e6;
    overflow-x: hidden
    }
.grain-overlay {
    background-image: url(https://lh3.googleusercontent.com/aida-public/AB6AXuAoujIYgIWCjhNHkmy60VIb_rdlhz8_2PgBGEgewG3MSPoaNQGouIOtU_wpKsABxqYWx6YYqLp6gsWlF3e44wW5Hj6epXkRMduMDg7slwYQgP5lNrj7iPYx8IKYsJQfxrOnKeNC_ZVo-pYocfJnwuhDpKAwYKD6dvJ4aKegbP_5qDdX0yBMXRBmLDAF2e7Lat9yK7T_vI_n5YmDNkDvIDs9ztgb_72_pAbxnaY9UBe5Z4kRbolzdheW979Wx9yY6KSnZxgPOiCvgD0);
    opacity: 0.03;
    pointer-events: none
    }
.teal-radial-glow {
    background: radial-gradient(circle at 50% 50%, rgba(0, 215, 176, 0.15) 0%, rgba(18, 19, 22, 0) 70%)
    }
.material-symbols-outlined {
    font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24
    }</style>
<script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                      "secondary-fixed-dim": "#adc6ff",
                      "on-tertiary": "#003640",
                      "on-primary-container": "#005847",
                      "inverse-surface": "#e3e2e6",
                      "background": "#121316",
                      "tertiary-container": "#35cfef",
                      "surface-container-low": "#1b1b1f",
                      "secondary-fixed": "#d8e2ff",
                      "on-secondary-fixed": "#001a41",
                      "on-surface": "#e3e2e6",
                      "surface-container": "#1f1f23",
                      "on-error": "#690005",
                      "tertiary": "#8ee7ff",
                      "surface-container-highest": "#343538",
                      "on-primary-fixed": "#002019",
                      "on-secondary-container": "#e0e8ff",
                      "on-primary-fixed-variant": "#005141",
                      "primary": "#46f4cb",
                      "secondary-container": "#0264d4",
                      "error-container": "#93000a",
                      "tertiary-fixed": "#acedff",
                      "outline-variant": "#3b4a44",
                      "surface-variant": "#343538",
                      "surface-container-lowest": "#0d0e11",
                      "primary-fixed-dim": "#21dfb8",
                      "on-surface-variant": "#bacac3",
                      "surface-dim": "#121316",
                      "surface-bright": "#38393c",
                      "on-tertiary-fixed": "#001f26",
                      "primary-container": "#00d7b0",
                      "on-error-container": "#ffdad6",
                      "on-tertiary-fixed-variant": "#004e5c",
                      "on-background": "#e3e2e6",
                      "secondary": "#adc6ff",
                      "on-secondary": "#002e69",
                      "outline": "#84948e",
                      "inverse-primary": "#006b57",
                      "inverse-on-surface": "#2f3034",
                      "error": "#ffb4ab",
                      "primary-fixed": "#52fcd3",
                      "surface": "#121316",
                      "tertiary-fixed-dim": "#42d7f8",
                      "on-secondary-fixed-variant": "#004494",
                      "on-primary": "#00382c",
                      "surface-tint": "#21dfb8",
                      "on-tertiary-container": "#005564",
                      "surface-container-high": "#292a2d"
              },
              "borderRadius": {
                      "DEFAULT": "1rem",
                      "lg": "2rem",
                      "xl": "3rem",
                      "full": "9999px"
              },
              "fontFamily": {
                      "headline": ["Manrope"],
                      "body": ["Inter"],
                      "label": ["Space Grotesk"],
                      "mono": ["Space Mono"]
              }
            },
          },
        }
      </script>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="font-body selection:bg-primary-container selection:text-on-primary-container">
<div class="fixed inset-0 grain-overlay z-[100]"></div>
<div class="fixed inset-0 teal-radial-glow z-0"></div>
<!-- Background Decoration: Asymmetric Elements -->
<div class="fixed -top-24 -right-24 w-96 h-96 bg-primary-container/10 blur-[120px] rounded-full z-0"></div>
<div class="fixed -bottom-48 -left-48 w-[500px] h-[500px] bg-secondary-container/5 blur-[150px] rounded-full z-0"></div>
<!-- Content Wrapper -->
<div class="relative z-10 flex flex-col min-h-screen">
<!-- TopAppBar (Suppressed for focused entry, but template structure ready) -->
<header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-[#121316]/80 backdrop-blur-lg border-b border-white/10">
<div class="text-2xl font-[800] tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-[#4A8DFF] to-[#00D7B0]">ZVELT</div>
<div class="flex items-center gap-4 text-[#00D7B0]">
<span class="material-symbols-outlined hover:opacity-80 transition-opacity cursor-pointer">settings</span>
</div>
</header>
<!-- Main Content Canvas -->
<main class="flex-grow flex flex-col items-center justify-center px-6 text-center pt-16 pb-16">
<!-- Hero Section -->
<div class="w-full max-w-2xl mx-auto space-y-8">
<!-- Welcome Icon/Emoji -->
<div class="relative inline-block">
<div class="text-7xl md:text-8xl mb-4 transform hover:scale-110 transition-transform cursor-default">👊</div>
<div class="absolute -inset-4 bg-primary/20 blur-2xl rounded-full -z-10"></div>
</div>
<!-- Headline -->
<div class="space-y-2">
<h1 class="font-headline font-extrabold text-5xl md:text-7xl tracking-tighter leading-tight text-on-background">
                        Welcome, <span class="text-[#00D7B0]">Similea!</span>
</h1>
<div class="h-1 w-24 bg-gradient-to-r from-[#4A8DFF] to-[#00D7B0] mx-auto rounded-full mt-6"></div>
</div>
<!-- Body Text -->
<p class="text-on-surface-variant text-lg md:text-xl font-light max-w-md mx-auto leading-relaxed">
                    Your kinetic command center is ready. Prepare to push beyond your peak performance and dominate your data.
                </p>
<!-- Data HUD Strip (Asymmetric visual element) -->
<div class="flex justify-center items-center gap-6 font-mono text-xs uppercase tracking-[0.2em] text-on-surface/40 pt-4">
<span>SYNC: ACTIVE</span>
<span class="text-[#00D7B0]">|</span>
<span>CORE: OPTIMIZED</span>
<span class="text-[#00D7B0]">|</span>
<span>LATENCY: 12MS</span>
</div>
<!-- CTA -->
<div class="pt-8">
<button class="group relative px-12 py-5 bg-gradient-to-r from-[#4A8DFF] to-[#00D7B0] rounded-full font-headline font-bold text-lg text-[#00382c] shadow-[0_0_40px_rgba(74,141,255,0.3)] hover:scale-105 active:scale-95 transition-all duration-300 overflow-hidden">
<span class="relative z-10 flex items-center gap-2">
                            Let's Go 
                            <span class="material-symbols-outlined text-2xl group-hover:translate-x-1 transition-transform">arrow_forward</span>
</span>
<div class="absolute inset-0 bg-white/20 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 ease-in-out"></div>
</button>
</div>
</div>
<!-- Kinetic Bento Mini-Grid (Subtle decorative layer) -->
<div class="mt-20 grid grid-cols-2 md:grid-cols-3 gap-4 w-full max-w-4xl opacity-40">
<!-- Glass Card 1 -->
<div class="bg-white/[0.04] backdrop-blur-md border border-white/[0.08] p-6 rounded-xl text-left space-y-3">
<span class="font-mono text-[10px] text-primary tracking-widest uppercase">Metric_Alpha</span>
<div class="h-2 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full w-2/3 bg-primary"></div>
</div>
</div>
<!-- Glass Card 2 -->
<div class="bg-white/[0.04] backdrop-blur-md border border-white/[0.08] p-6 rounded-xl text-left space-y-3 hidden md:block">
<span class="font-mono text-[10px] text-tertiary tracking-widest uppercase">Neuro_Sync</span>
<div class="flex gap-1">
<div class="w-1.5 h-6 bg-tertiary/20 rounded-full"></div>
<div class="w-1.5 h-8 bg-tertiary/40 rounded-full"></div>
<div class="w-1.5 h-10 bg-tertiary rounded-full"></div>
<div class="w-1.5 h-6 bg-tertiary/20 rounded-full"></div>
</div>
</div>
<!-- Glass Card 3 -->
<div class="bg-white/[0.04] backdrop-blur-md border border-white/[0.08] p-6 rounded-xl text-left space-y-3">
<span class="font-mono text-[10px] text-[#4A8DFF] tracking-widest uppercase">System_Load</span>
<div class="text-2xl font-mono font-bold text-on-surface">98.4%</div>
</div>
</div>
</main>
<!-- BottomNavBar (Hidden on entry screens but structure defined as per JSON) -->
<nav class="hidden fixed bottom-0 left-0 w-full z-50 md:hidden flex justify-around items-center h-20 bg-[#121316]/90 backdrop-blur-xl border-t border-white/5 pb-safe shadow-[0_-10px_40px_rgba(0,0,0,0.5)]">
<div class="flex flex-col items-center justify-center text-slate-600 p-3">
<span class="material-symbols-outlined" data-icon="bolt">bolt</span>
</div>
<div class="flex flex-col items-center justify-center text-slate-600 p-3">
<span class="material-symbols-outlined" data-icon="query_stats">query_stats</span>
</div>
<div class="flex flex-col items-center justify-center text-slate-600 p-3">
<span class="material-symbols-outlined" data-icon="emoji_events">emoji_events</span>
</div>
<div class="flex flex-col items-center justify-center text-slate-600 p-3">
<span class="material-symbols-outlined" data-icon="person">person</span>
</div>
</nav>
<!-- Background Image Interaction Layer -->
<div class="absolute bottom-0 right-0 w-1/3 h-2/3 -z-10 opacity-20 mask-linear-gradient">
<img alt="Elite athlete training" class="w-full h-full object-cover grayscale contrast-125" data-alt="dramatic cinematic black and white close-up of a muscular athlete in high-intensity workout with sweat droplets and teal backlighting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDBfxXUA10BakyFrVPYv-EBLuszsSPC4vVVixWQ7zPBaUZsGCABpiaCJfqjBINyHvw4utMx66Cvu_2FcexM6mVJ5bOOtgRQgknEFPtdBMpGrjBqtjIgl1z6ae65ShCBDzpO8zTuNAINMXVzrGqy_2YugspKsIVyqrBKLJrAFE_0Ebc7t21l0_hWULZ8OapMTy73dsB-V3X-av78ymXj4AKF19yqM-HxjUJ-nrLmwOryeRKwRJ5NZ-yeiEPFItTwECyS5Zm2OORX9S0"/>
</div>
</div>
<!-- Visual Polish: Noise Texture Overlay -->
<svg class="fixed inset-0 pointer-events-none opacity-[0.03] z-[110]">
<filter id="noiseFilter">
<feturbulence basefrequency="0.6" numoctaves="3" stitchtiles="stitch" type="fractalNoise"></feturbulence>
</filter>
<rect filter="url(#noiseFilter)" height="100%" width="100%"></rect>
</svg>
</body></html>