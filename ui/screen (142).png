<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>ZVELT Progress - Weekly Detail</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;family=Manrope:wght@500;600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "secondary-fixed-dim": "#adc6ff",
                    "on-tertiary": "#003640",
                    "on-surface-variant": "#bacac3",
                    "surface-container-low": "#1b1b1f",
                    "surface-bright": "#38393c",
                    "on-primary": "#00382c",
                    "surface-container": "#1f1f23",
                    "tertiary-container": "#35cfef",
                    "primary-fixed-dim": "#21dfb8",
                    "background": "#121316",
                    "on-primary-fixed-variant": "#005141",
                    "on-tertiary-container": "#005564",
                    "surface": "#121316",
                    "surface-container-lowest": "#0d0e11",
                    "on-tertiary-fixed": "#001f26",
                    "on-secondary-fixed": "#001a41",
                    "on-secondary": "#002e69",
                    "surface-variant": "#343538",
                    "on-secondary-container": "#e0e8ff",
                    "primary": "#46f4cb",
                    "surface-container-highest": "#343538",
                    "surface-container-high": "#292a2d",
                    "outline": "#84948e",
                    "primary-fixed": "#52fcd3",
                    "inverse-on-surface": "#2f3034",
                    "on-primary-container": "#005847",
                    "inverse-primary": "#006b57",
                    "secondary": "#adc6ff",
                    "on-tertiary-fixed-variant": "#004e5c",
                    "on-secondary-fixed-variant": "#004494",
                    "on-error": "#690005",
                    "tertiary-fixed-dim": "#42d7f8",
                    "secondary-container": "#0264d4",
                    "on-primary-fixed": "#002019",
                    "tertiary": "#8ee7ff",
                    "on-error-container": "#ffdad6",
                    "error": "#ffb4ab",
                    "outline-variant": "#3b4a44",
                    "inverse-surface": "#e3e2e6",
                    "on-surface": "#e3e2e6",
                    "surface-tint": "#21dfb8",
                    "surface-dim": "#121316",
                    "secondary-fixed": "#d8e2ff",
                    "error-container": "#93000a",
                    "primary-container": "#00d7b0",
                    "on-background": "#e3e2e6",
                    "tertiary-fixed": "#acedff"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "fontFamily": {
                    "headline": ["Manrope"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        },
      }
    </script>
<style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      .glass-card {
        background: rgba(31, 31, 35, 0.6);
        backdrop-filter: blur(12px);
      }
      .liquid-gradient {
        background: linear-gradient(135deg, #46f4cb 0%, #00d7b0 100%);
      }
      .data-glow-primary {
        filter: drop-shadow(0 0 8px rgba(70, 244, 203, 0.3));
      }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background text-on-surface font-body selection:bg-primary/30 min-h-screen pb-24">
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 bg-[#121316]/80 backdrop-blur-lg dark:bg-[#121316]/80 flex justify-between items-center px-6 py-4 w-full">
<div class="flex items-center gap-3">
<div class="w-8 h-8 rounded-full overflow-hidden border border-outline-variant">
<img class="w-full h-full object-cover" data-alt="close-up portrait of an athletic woman with focused expression and professional lighting in a dark gym environment" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCaeDfHtjcRM0Q_a9gTJp8V1Ym3mrC4v4tT4bCd8FybNnVPsszbCGARWJvk2GBlerNBGUCimFHYoFwFCzPNjgGrEIgirY3UDFuw2e8uKE1cqxAYH4AvFcNBknFU8VEtCM8OchnOe2ejq5Bk8DhqAIwMHhoKztS9yyCncPM5I4-JLF-Dp9nRzLC5fClAJtf3YKS5Qnpq_yvehFVUiCqTmLKkxO8NJmSObC7Tar5CCcmNCyjVOTvuLtn4TCgYprlw8eqnuN8BmeoVlPo"/>
</div>
<span class="font-manrope font-extrabold tracking-tighter text-[#F5F7FA] text-2xl uppercase">ZVELT</span>
</div>
<div class="flex items-center gap-4">
<button class="text-[#A7B0BC] hover:bg-[#1f1f23] transition-colors p-2 rounded-lg active:scale-95">
<span class="material-symbols-outlined">settings</span>
</button>
</div>
<div class="bg-[#1b1b1f] h-[2px] w-1/3 absolute bottom-0 left-0"></div>
</header>
<main class="pt-24 px-6 max-w-5xl mx-auto">
<!-- Editorial Header Section -->
<section class="mb-12">
<div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
<div class="max-w-xl">
<span class="font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant font-medium mb-2 block">Weekly Performance Architecture</span>
<h1 class="font-headline font-bold text-4xl md:text-5xl tracking-tight text-[#F5F7FA] leading-tight">Current Cycle: <span class="text-primary">Week 42</span></h1>
<p class="mt-4 text-on-surface-variant text-sm max-w-md leading-relaxed">Precision monitoring of metabolic load and muscular recovery. You are currently operating at peak consistency.</p>
</div>
<div class="flex items-center gap-4">
<div class="bg-surface-container p-4 rounded-xl flex flex-col items-end">
<span class="text-[10px] uppercase tracking-widest text-on-surface-variant mb-1 font-bold">Consistency Score</span>
<span class="font-headline font-bold text-3xl text-primary leading-none">92%</span>
</div>
</div>
</div>
</section>
<!-- Bento Grid Main Content -->
<div class="grid grid-cols-1 md:grid-cols-12 gap-6">
<!-- Training Volume Line Chart (Main Card) -->
<div class="md:col-span-8 bg-surface-container-low rounded-xl p-8 relative overflow-hidden">
<div class="flex justify-between items-start mb-12">
<div>
<h3 class="font-headline font-bold text-xl text-[#F5F7FA]">Weekly Training Volume</h3>
<p class="font-label text-xs text-on-surface-variant mt-1">Accumulated intensity over 7-day period</p>
</div>
<div class="text-right">
<span class="font-headline font-bold text-2xl text-[#F5F7FA]">9.5 <span class="text-sm font-normal text-on-surface-variant">hrs</span></span>
</div>
</div>
<!-- Mock Line Chart -->
<div class="h-48 w-full relative flex items-end justify-between gap-2">
<div class="absolute inset-0 flex flex-col justify-between pointer-events-none opacity-10">
<div class="border-t border-on-surface w-full"></div>
<div class="border-t border-on-surface w-full"></div>
<div class="border-t border-on-surface w-full"></div>
</div>
<!-- Chart Bars/Points -->
<div class="flex-1 flex flex-col items-center group">
<div class="w-full bg-surface-container-highest rounded-t-sm h-24 group-hover:bg-primary/20 transition-colors"></div>
<span class="font-label text-[10px] mt-3 text-on-surface-variant uppercase tracking-tighter">Mon</span>
</div>
<div class="flex-1 flex flex-col items-center group">
<div class="w-full bg-surface-container-highest rounded-t-sm h-32 group-hover:bg-primary/20 transition-colors"></div>
<span class="font-label text-[10px] mt-3 text-on-surface-variant uppercase tracking-tighter">Tue</span>
</div>
<div class="flex-1 flex flex-col items-center group">
<div class="w-full liquid-gradient rounded-t-sm h-40 data-glow-primary"></div>
<span class="font-label text-[10px] mt-3 text-primary uppercase tracking-tighter font-bold">Wed</span>
</div>
<div class="flex-1 flex flex-col items-center group">
<div class="w-full bg-surface-container-highest rounded-t-sm h-16 group-hover:bg-primary/20 transition-colors"></div>
<span class="font-label text-[10px] mt-3 text-on-surface-variant uppercase tracking-tighter">Thu</span>
</div>
<div class="flex-1 flex flex-col items-center group">
<div class="w-full bg-surface-container-highest rounded-t-sm h-36 group-hover:bg-primary/20 transition-colors"></div>
<span class="font-label text-[10px] mt-3 text-on-surface-variant uppercase tracking-tighter">Fri</span>
</div>
<div class="flex-1 flex flex-col items-center group">
<div class="w-full bg-surface-container-highest rounded-t-sm h-12 group-hover:bg-primary/20 transition-colors opacity-50"></div>
<span class="font-label text-[10px] mt-3 text-on-surface-variant/50 uppercase tracking-tighter">Sat</span>
</div>
<div class="flex-1 flex flex-col items-center group">
<div class="w-full bg-surface-container-highest rounded-t-sm h-8 group-hover:bg-primary/20 transition-colors opacity-50"></div>
<span class="font-label text-[10px] mt-3 text-on-surface-variant/50 uppercase tracking-tighter">Sun</span>
</div>
</div>
</div>
<!-- Sessions Completed (Small Card) -->
<div class="md:col-span-4 bg-surface-container-low rounded-xl p-8 flex flex-col justify-between border-l-4 border-primary">
<div>
<h3 class="font-headline font-bold text-lg text-[#F5F7FA]">Sessions</h3>
<p class="font-label text-xs text-on-surface-variant mt-1">Weekly target progress</p>
</div>
<div class="my-6">
<div class="flex items-baseline gap-1">
<span class="font-headline font-bold text-5xl text-[#F5F7FA]">5</span>
<span class="font-headline text-2xl text-on-surface-variant">/ 7</span>
</div>
<div class="w-full h-1 bg-surface-container-highest mt-4 rounded-full overflow-hidden">
<div class="h-full liquid-gradient w-[71%]"></div>
</div>
</div>
<div class="flex items-center gap-2 text-primary">
<span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">check_circle</span>
<span class="font-label text-xs font-bold uppercase tracking-widest">On Track</span>
</div>
</div>
<!-- Load vs Recovery Balance -->
<div class="md:col-span-5 bg-surface-container-low rounded-xl p-8">
<h3 class="font-headline font-bold text-lg text-[#F5F7FA] mb-8">System Equilibrium</h3>
<div class="relative pt-10">
<!-- Balance Indicator Scale -->
<div class="h-2 w-full bg-surface-container-highest rounded-full flex relative">
<div class="absolute -top-8 left-0 font-label text-[10px] uppercase text-on-surface-variant">High Stress</div>
<div class="absolute -top-8 right-0 font-label text-[10px] uppercase text-on-surface-variant">Full Recovery</div>
<div class="h-full w-1/2 bg-error/20 rounded-l-full"></div>
<div class="h-full w-1/2 bg-tertiary/20 rounded-r-full"></div>
<!-- Floating Balance Node -->
<div class="absolute top-1/2 left-[62%] -translate-y-1/2 -translate-x-1/2 w-8 h-8 rounded-full bg-primary flex items-center justify-center shadow-[0_0_20px_rgba(70,244,203,0.4)]">
<span class="material-symbols-outlined text-on-primary text-lg">balance</span>
</div>
</div>
</div>
<div class="mt-12 space-y-4">
<div class="flex justify-between items-center">
<span class="text-xs text-on-surface-variant">Strain Index</span>
<span class="text-xs font-bold font-manrope">7.4 / 10</span>
</div>
<div class="flex justify-between items-center">
<span class="text-xs text-on-surface-variant">Sleep Quality</span>
<span class="text-xs font-bold font-manrope">88%</span>
</div>
<div class="flex justify-between items-center">
<span class="text-xs text-on-surface-variant">HRV Status</span>
<span class="text-xs font-bold font-manrope text-primary">+12ms</span>
</div>
</div>
</div>
<!-- Time Breakdown by Sport -->
<div class="md:col-span-7 bg-surface-container-low rounded-xl p-8">
<div class="flex justify-between items-center mb-8">
<h3 class="font-headline font-bold text-lg text-[#F5F7FA]">Modal Distribution</h3>
<span class="material-symbols-outlined text-on-surface-variant">donut_small</span>
</div>
<div class="space-y-6">
<!-- Running -->
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded bg-[#FF6B6B]/10 flex items-center justify-center text-[#FF6B6B]">
<span class="material-symbols-outlined">directions_run</span>
</div>
<div class="flex-1">
<div class="flex justify-between mb-1">
<span class="font-label text-sm font-medium">Running</span>
<span class="font-manrope text-sm font-bold">4h 00m</span>
</div>
<div class="w-full h-1.5 bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-[#FF6B6B] w-[44%]"></div>
</div>
</div>
</div>
<!-- Gym -->
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded bg-tertiary/10 flex items-center justify-center text-tertiary">
<span class="material-symbols-outlined">fitness_center</span>
</div>
<div class="flex-1">
<div class="flex justify-between mb-1">
<span class="font-label text-sm font-medium">Gym</span>
<span class="font-manrope text-sm font-bold">3h 00m</span>
</div>
<div class="w-full h-1.5 bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-tertiary w-[33%]"></div>
</div>
</div>
</div>
<!-- Cycling -->
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded bg-primary/10 flex items-center justify-center text-primary">
<span class="material-symbols-outlined">directions_bike</span>
</div>
<div class="flex-1">
<div class="flex justify-between mb-1">
<span class="font-label text-sm font-medium">Cycling</span>
<span class="font-manrope text-sm font-bold">2h 00m</span>
</div>
<div class="w-full h-1.5 bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-primary w-[22%]"></div>
</div>
</div>
</div>
</div>
</div>
<!-- Contextual CTA / Insights -->
<div class="md:col-span-12 bg-surface-container-high rounded-xl p-6 flex flex-col md:flex-row items-center gap-8 border border-outline-variant/10">
<div class="flex-shrink-0 w-16 h-16 rounded-full liquid-gradient flex items-center justify-center shadow-lg">
<span class="material-symbols-outlined text-on-primary text-3xl">bolt</span>
</div>
<div class="flex-1 text-center md:text-left">
<h4 class="font-headline font-bold text-xl text-[#F5F7FA]">Insight: Recovery Recommended</h4>
<p class="text-on-surface-variant text-sm mt-1">High load in past 48 hours. Consider a low-intensity mobility session tomorrow to maintain the 92% consistency target.</p>
</div>
<button class="liquid-gradient text-on-primary font-bold px-8 py-4 rounded-md text-sm uppercase tracking-widest shadow-xl active:scale-95 transition-all w-full md:w-auto">
                    Log Rest Day
                </button>
</div>
</div>
</main>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full z-50 bg-[#1b1b1f]/90 backdrop-blur-2xl dark:bg-[#1b1b1f]/90 flex justify-around items-center px-4 pb-6 pt-3 rounded-t-xl" style="box-shadow: 0px 12px 32px rgba(0, 0, 0, 0.4);">
<div class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out">
<span class="material-symbols-outlined">home</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium mt-1">Home</span>
</div>
<div class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out">
<span class="material-symbols-outlined">exercise</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium mt-1">Workout</span>
</div>
<div class="flex flex-col items-center justify-center text-[#46f4cb] bg-[#292a2d] rounded-lg px-3 py-1 transition-all duration-300 ease-out">
<span class="material-symbols-outlined">monitoring</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium mt-1">Progress</span>
</div>
<div class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out">
<span class="material-symbols-outlined">group</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium mt-1">Social</span>
</div>
<div class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out">
<span class="material-symbols-outlined">person</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium mt-1">Profile</span>
</div>
</nav>
</body></html>