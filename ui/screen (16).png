<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;700;800&amp;family=Inter:wght@300;400;500;600&amp;family=Space+Mono:wght@400;700&amp;family=Space+Grotesk:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "secondary-fixed-dim": "#adc6ff",
                        "on-tertiary": "#003640",
                        "on-primary-container": "#005847",
                        "inverse-surface": "#e3e2e6",
                        "background": "#121316",
                        "tertiary-container": "#35cfef",
                        "surface-container-low": "#1b1b1f",
                        "secondary-fixed": "#d8e2ff",
                        "on-secondary-fixed": "#001a41",
                        "on-surface": "#e3e2e6",
                        "surface-container": "#1f1f23",
                        "on-error": "#690005",
                        "tertiary": "#8ee7ff",
                        "surface-container-highest": "#343538",
                        "on-primary-fixed": "#002019",
                        "on-secondary-container": "#e0e8ff",
                        "on-primary-fixed-variant": "#005141",
                        "primary": "#46f4cb",
                        "secondary-container": "#0264d4",
                        "error-container": "#93000a",
                        "tertiary-fixed": "#acedff",
                        "outline-variant": "#3b4a44",
                        "surface-variant": "#343538",
                        "surface-container-lowest": "#0d0e11",
                        "primary-fixed-dim": "#21dfb8",
                        "on-surface-variant": "#bacac3",
                        "surface-dim": "#121316",
                        "surface-bright": "#38393c",
                        "on-tertiary-fixed": "#001f26",
                        "primary-container": "#00d7b0",
                        "on-error-container": "#ffdad6",
                        "on-tertiary-fixed-variant": "#004e5c",
                        "on-background": "#e3e2e6",
                        "secondary": "#adc6ff",
                        "on-secondary": "#002e69",
                        "outline": "#84948e",
                        "inverse-primary": "#006b57",
                        "inverse-on-surface": "#2f3034",
                        "error": "#ffb4ab",
                        "primary-fixed": "#52fcd3",
                        "surface": "#121316",
                        "tertiary-fixed-dim": "#42d7f8",
                        "on-secondary-fixed-variant": "#004494",
                        "on-primary": "#00382c",
                        "surface-tint": "#21dfb8",
                        "on-tertiary-container": "#005564",
                        "surface-container-high": "#292a2d"
                    },
                    "borderRadius": {
                        "DEFAULT": "1rem",
                        "lg": "2rem",
                        "xl": "3rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Manrope"],
                        "body": ["Inter"],
                        "label": ["Space Grotesk"]
                    }
                }
            }
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .grain-overlay {
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3column%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            opacity: 0.03;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-surface-dim text-on-surface font-body selection:bg-primary selection:text-on-primary min-h-screen overflow-x-hidden">
<!-- Atmospheric Glows -->
<div class="fixed top-[-10%] right-[-10%] w-[60%] h-[60%] bg-primary/10 blur-[120px] rounded-full pointer-events-none z-0"></div>
<div class="fixed bottom-[-10%] left-[-10%] w-[50%] h-[50%] bg-secondary-container/5 blur-[120px] rounded-full pointer-events-none z-0"></div>
<div class="fixed inset-0 grain-overlay pointer-events-none z-10"></div>
<!-- Top Navigation Shell (Injected Styles from JSON) -->
<header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-[#121316]/80 backdrop-blur-lg border-b border-white/10 shadow-[0_4px_30px_rgba(0,0,0,0.1)]">
<div class="flex items-center gap-4">
<button class="active:scale-95 transition-transform hover:opacity-80 transition-opacity flex items-center justify-center">
<span class="material-symbols-outlined text-[#00D7B0]">arrow_back</span>
</button>
<span class="font-['Manrope'] font-extrabold uppercase tracking-widest text-sm text-[#00D7B0]">ZVELT</span>
</div>
<div class="flex items-center gap-6">
<!-- Navigation Links (Contextual Hidden on Mobile as per platforms layout rule) -->
<nav class="hidden md:flex items-center gap-8 font-label font-bold text-[12px] uppercase tracking-wider">
<a class="text-slate-500 hover:opacity-80 transition-opacity" href="#">Command</a>
<a class="text-slate-500 hover:opacity-80 transition-opacity" href="#">Analytics</a>
<a class="text-slate-500 hover:opacity-80 transition-opacity" href="#">Rankings</a>
<a class="text-slate-500 hover:opacity-80 transition-opacity" href="#">Profile</a>
</nav>
<button class="active:scale-95 transition-transform hover:opacity-80 transition-opacity">
<span class="material-symbols-outlined text-[#00D7B0]">settings</span>
</button>
</div>
</header>
<main class="relative z-20 pt-24 pb-32 px-6 max-w-2xl mx-auto flex flex-col min-h-screen">
<!-- Header Section -->
<section class="mb-12">
<div class="inline-block mb-4 px-3 py-1 bg-surface-container-highest rounded-full">
<span class="font-['Space_Mono'] text-[10px] uppercase font-bold tracking-widest text-primary">Stage 01 | Identity Setup</span>
</div>
<h1 class="text-5xl md:text-6xl font-['Manrope'] font-[800] leading-tight tracking-tight text-on-surface">
                What's your <br/>
<span class="text-transparent bg-clip-text bg-gradient-to-r from-[#4A8DFF] to-[#00D7B0]">main goal?</span>
</h1>
<p class="mt-4 text-on-surface-variant font-body font-light text-lg">Select the primary directive for your kinetic evolution.</p>
</section>
<!-- Goal Cards Grid -->
<div class="grid grid-cols-1 gap-4">
<!-- Goal Card 1 -->
<div class="group relative bg-white/5 backdrop-blur-xl border border-white/5 rounded-xl p-6 flex items-center justify-between hover:bg-white/10 transition-all duration-300 cursor-pointer">
<div class="flex items-center gap-6">
<div class="w-12 h-12 rounded-lg bg-surface-container-highest flex items-center justify-center text-primary">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">fitness_center</span>
</div>
<div>
<h3 class="font-headline font-bold text-xl text-on-surface">Get stronger</h3>
<p class="font-body text-sm text-on-surface-variant">Focus on progressive overload &amp; power.</p>
</div>
</div>
<div class="w-6 h-6 rounded-full border-2 border-outline-variant group-hover:border-primary transition-colors"></div>
</div>
<!-- Goal Card 2 -->
<div class="group relative bg-white/5 backdrop-blur-xl border border-white/5 rounded-xl p-6 flex items-center justify-between hover:bg-white/10 transition-all duration-300 cursor-pointer">
<div class="flex items-center gap-6">
<div class="w-12 h-12 rounded-lg bg-surface-container-highest flex items-center justify-center text-primary">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">local_fire_department</span>
</div>
<div>
<h3 class="font-headline font-bold text-xl text-on-surface">Lose body fat</h3>
<p class="font-body text-sm text-on-surface-variant">Optimize metabolic rate &amp; definition.</p>
</div>
</div>
<div class="w-6 h-6 rounded-full border-2 border-outline-variant group-hover:border-primary transition-colors"></div>
</div>
<!-- Goal Card 3 (SELECTED) -->
<div class="group relative bg-primary/10 backdrop-blur-xl border-2 border-primary rounded-xl p-6 flex items-center justify-between transition-all duration-300 cursor-pointer shadow-[0_0_40px_rgba(70,244,203,0.15)]">
<div class="flex items-center gap-6">
<div class="w-12 h-12 rounded-lg bg-primary/20 flex items-center justify-center text-primary">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">bolt</span>
</div>
<div>
<h3 class="font-headline font-bold text-xl text-primary">Boost performance</h3>
<p class="font-body text-sm text-primary/80">Enhance speed, agility &amp; output.</p>
</div>
</div>
<div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center">
<span class="material-symbols-outlined text-on-primary text-sm font-bold">check</span>
</div>
</div>
<!-- Goal Card 4 -->
<div class="group relative bg-white/5 backdrop-blur-xl border border-white/5 rounded-xl p-6 flex items-center justify-between hover:bg-white/10 transition-all duration-300 cursor-pointer">
<div class="flex items-center gap-6">
<div class="w-12 h-12 rounded-lg bg-surface-container-highest flex items-center justify-center text-primary">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">calendar_today</span>
</div>
<div>
<h3 class="font-headline font-bold text-xl text-on-surface">Build consistency</h3>
<p class="font-body text-sm text-on-surface-variant">Establish long-term sustainable habits.</p>
</div>
</div>
<div class="w-6 h-6 rounded-full border-2 border-outline-variant group-hover:border-primary transition-colors"></div>
</div>
<!-- Goal Card 5 -->
<div class="group relative bg-white/5 backdrop-blur-xl border border-white/5 rounded-xl p-6 flex items-center justify-between hover:bg-white/10 transition-all duration-300 cursor-pointer">
<div class="flex items-center gap-6">
<div class="w-12 h-12 rounded-lg bg-surface-container-highest flex items-center justify-center text-primary">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">self_improvement</span>
</div>
<div>
<h3 class="font-headline font-bold text-xl text-on-surface">Recover &amp; rebalance</h3>
<p class="font-body text-sm text-on-surface-variant">Restore physiological readiness.</p>
</div>
</div>
<div class="w-6 h-6 rounded-full border-2 border-outline-variant group-hover:border-primary transition-colors"></div>
</div>
</div>
<!-- Data HUD Strip -->
<div class="mt-12 flex items-center justify-center gap-4 py-4 px-6 border-y border-white/5">
<div class="flex items-center gap-2">
<span class="font-['Space_Mono'] text-[10px] text-slate-500 uppercase">Focus:</span>
<span class="font-['Space_Mono'] text-[10px] text-primary font-bold">STRENGTH</span>
</div>
<span class="text-tertiary">|</span>
<div class="flex items-center gap-2">
<span class="font-['Space_Mono'] text-[10px] text-slate-500 uppercase">Intensity:</span>
<span class="font-['Space_Mono'] text-[10px] text-primary font-bold">PEAK</span>
</div>
<span class="text-tertiary">|</span>
<div class="flex items-center gap-2">
<span class="font-['Space_Mono'] text-[10px] text-slate-500 uppercase">Duration:</span>
<span class="font-['Space_Mono'] text-[10px] text-primary font-bold">12 WEEKS</span>
</div>
</div>
<!-- Call to Action -->
<div class="mt-auto pt-12 pb-8">
<button class="w-full py-5 rounded-full bg-gradient-to-r from-[#4A8DFF] to-[#00D7B0] font-headline font-[700] text-on-primary text-lg tracking-wide hover:shadow-[0_8px_30px_rgba(74,141,255,0.3)] active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                Continue
                <span class="material-symbols-outlined">trending_flat</span>
</button>
<p class="text-center mt-4 font-['Space_Mono'] text-[10px] text-slate-600 uppercase tracking-widest">Calculated progression based on biometrics</p>
</div>
</main>
<!-- Background Decorative Element (Asymmetry) -->
<div class="fixed bottom-24 -right-12 w-64 h-64 opacity-10 pointer-events-none transform rotate-12">
<img class="w-full h-full object-cover rounded-xl" data-alt="dramatic black and white close up of a heavy barbell in a high performance industrial gym with moody lighting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAgvzyP2Dx2upX2JAg3FdPuiuoRbHIyxhrrkmMqQAZFd8DG82KXmhowHoG5vi4xVd1XFEIISzyj0d4mLXKEtSUa3yX-54X265lVDGd5R1PxwQW2rGvjuWj5UCxZUMNJtVnPT_XIhDRWfytnCxRaQIy0BefKLouKkpF6DTQ7MYcK4Hd_ySWt3ggCkQHCefJ2ORMtVfJ8CyN-M8zEDU92OJYiR2GATKCbULyFJ4nWO7STEMzOo_sLdXS3PUtvzvSfzqoWWNKxadJ2qIc"/>
</div>
<!-- Mobile Navigation Shell (Injected Styles from JSON) -->
<!-- Suppression Logic: Suppress nav on focused setup flow, but keeping structure if needed for context -->
<nav class="md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center h-20 bg-[#121316]/90 backdrop-blur-xl border-t border-white/5 pb-safe shadow-[0_-10px_40px_rgba(0,0,0,0.5)]">
<div class="flex flex-col items-center justify-center text-slate-600 p-3 hover:text-[#4A8DFF] transition-colors active:scale-90 transition-all">
<span class="material-symbols-outlined">bolt</span>
</div>
<div class="flex flex-col items-center justify-center text-slate-600 p-3 hover:text-[#4A8DFF] transition-colors active:scale-90 transition-all">
<span class="material-symbols-outlined">query_stats</span>
</div>
<div class="flex flex-col items-center justify-center text-slate-600 p-3 hover:text-[#4A8DFF] transition-colors active:scale-90 transition-all">
<span class="material-symbols-outlined">emoji_events</span>
</div>
<div class="flex flex-col items-center justify-center text-slate-600 p-3 hover:text-[#4A8DFF] transition-colors active:scale-90 transition-all">
<span class="material-symbols-outlined">person</span>
</div>
</nav>
</body></html>