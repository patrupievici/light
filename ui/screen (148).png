<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>ZVELT Progress - Weekly Overview</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Manrope:wght@600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "surface": "#121316",
                    "surface-bright": "#38393c",
                    "error-container": "#93000a",
                    "error": "#ffb4ab",
                    "secondary": "#adc6ff",
                    "on-surface": "#e3e2e6",
                    "on-tertiary-fixed": "#001f26",
                    "tertiary-container": "#35cfef",
                    "on-primary-fixed": "#002019",
                    "on-secondary-fixed": "#001a41",
                    "surface-container-low": "#1b1b1f",
                    "on-tertiary": "#003640",
                    "inverse-surface": "#e3e2e6",
                    "tertiary-fixed": "#acedff",
                    "surface-container": "#1f1f23",
                    "inverse-on-surface": "#2f3034",
                    "secondary-fixed": "#d8e2ff",
                    "background": "#121316",
                    "on-surface-variant": "#bacac3",
                    "primary-fixed": "#52fcd3",
                    "surface-variant": "#343538",
                    "outline-variant": "#3b4a44",
                    "on-primary-fixed-variant": "#005141",
                    "on-primary": "#00382c",
                    "primary-container": "#00d7b0",
                    "on-error-container": "#ffdad6",
                    "surface-tint": "#21dfb8",
                    "on-background": "#e3e2e6",
                    "primary": "#46f4cb",
                    "on-tertiary-container": "#005564",
                    "tertiary": "#8ee7ff",
                    "surface-container-lowest": "#0d0e11",
                    "primary-fixed-dim": "#21dfb8",
                    "secondary-container": "#0264d4",
                    "surface-container-high": "#292a2d",
                    "on-primary-container": "#005847",
                    "outline": "#84948e",
                    "secondary-fixed-dim": "#adc6ff",
                    "inverse-primary": "#006b57",
                    "on-error": "#690005",
                    "surface-container-highest": "#343538",
                    "on-secondary-container": "#e0e8ff",
                    "on-secondary": "#002e69",
                    "tertiary-fixed-dim": "#42d7f8",
                    "surface-dim": "#121316",
                    "on-secondary-fixed-variant": "#004494",
                    "on-tertiary-fixed-variant": "#004e5c"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "fontFamily": {
                    "headline": ["Manrope"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        }
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .chart-glow {
            filter: drop-shadow(0 0 8px rgba(70, 244, 203, 0.3));
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-surface text-on-surface font-body selection:bg-primary/30">
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 bg-[#121316]/80 backdrop-blur-lg dark:bg-[#121316]/80 px-6 py-4 flex justify-between items-center">
<div class="flex items-center gap-3">
<div class="w-10 h-10 rounded-full overflow-hidden border border-outline-variant/30">
<img alt="User Profile" class="w-full h-full object-cover" data-alt="portrait of a focused professional athlete with subtle lighting on dark background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAzqhPx2RG-RFovOFvfJuid_ZMQFkjSR_3lb21wSOCtqFAerxPV2oIqNX9MoTG_fpzB_RHQ3S8yEOmPrHmGY1EUYuznK2XgzRun_nxwkJkOQepAr3-wH4onHEgOyoU_h455bMCGMocxeF-FtO8aU6xPcKBhsUAQUVg9qtPTO6G0w6LRd2CbxvG7fF2bSVxl5Jp2ef03_eBOLJQXx3Rb_Yzw24UIfXKPpY_PiHmXjnRnIMDaXjBZ15mkds46CCrRExPtPh_3M7uTtIA"/>
</div>
<span class="font-headline font-extrabold tracking-tighter text-[#F5F7FA] text-2xl">ZVELT</span>
</div>
<div class="flex items-center gap-4">
<button class="text-[#A7B0BC] hover:bg-[#1f1f23] transition-colors p-2 rounded-lg active:scale-95 duration-150">
<span class="material-symbols-outlined" data-icon="settings">settings</span>
</button>
</div>
<div class="bg-[#1b1b1f] h-[2px] w-1/3 absolute bottom-0 left-0"></div>
</header>
<main class="pt-24 pb-32 px-6 max-w-2xl mx-auto space-y-10">
<!-- Section: Weekly Performance Chart -->
<section class="space-y-6">
<div class="flex justify-between items-end">
<div class="space-y-1">
<p class="font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant">Technical Analysis</p>
<h2 class="font-headline text-2xl font-bold text-on-surface">Weekly Load</h2>
</div>
<div class="flex items-center gap-2 px-3 py-1 bg-surface-container-high rounded-full border border-outline-variant/20">
<span class="w-2 h-2 rounded-full bg-primary animate-pulse shadow-[0_0_8px_#46f4cb]"></span>
<span class="font-label text-[10px] uppercase font-bold tracking-widest text-primary">Balanced</span>
</div>
</div>
<div class="bg-surface-container-low rounded-xl p-6 relative overflow-hidden aspect-[16/9] flex items-end justify-between">
<!-- Background Grid -->
<div class="absolute inset-0 opacity-5 pointer-events-none">
<div class="h-full w-full border-b border-l border-outline"></div>
</div>
<!-- Chart Visual (Simulated) -->
<div class="absolute inset-x-6 top-12 bottom-12 flex items-end justify-between">
<!-- Recovery Line (Tertiary) -->
<svg class="absolute inset-0 w-full h-full" preserveaspectratio="none" viewbox="0 0 100 100">
<path class="opacity-40" d="M0,80 Q15,85 30,60 T60,40 T100,20" fill="none" stroke="#8ee7ff" stroke-width="2"></path>
<!-- Training Load Line (Primary) -->
<path class="chart-glow" d="M0,90 Q20,80 40,85 T70,50 T100,30" fill="none" stroke="#46f4cb" stroke-width="2.5"></path>
</svg>
</div>
<!-- Labels -->
<div class="w-full flex justify-between font-label text-[10px] text-on-surface-variant/60 pt-4 z-10">
<span>MON</span><span>TUE</span><span>WED</span><span>THU</span><span>FRI</span><span>SAT</span><span>SUN</span>
</div>
</div>
</section>
<!-- Section: Summary & Sport Distribution -->
<section class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div class="bg-surface-container rounded-xl p-5 space-y-4">
<p class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant font-semibold">Active Time</p>
<div class="flex items-baseline gap-2">
<span class="font-headline text-4xl font-extrabold text-on-surface">12.4</span>
<span class="font-label text-sm text-on-surface-variant">HRS</span>
</div>
<div class="w-full h-1 bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-primary w-[78%]"></div>
</div>
</div>
<div class="bg-surface-container rounded-xl p-5 space-y-4">
<p class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant font-semibold">Energy Burn</p>
<div class="flex items-baseline gap-2">
<span class="font-headline text-4xl font-extrabold text-on-surface">8,420</span>
<span class="font-label text-sm text-on-surface-variant">KCAL</span>
</div>
<div class="w-full h-1 bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-tertiary w-[62%]"></div>
</div>
</div>
<div class="md:col-span-2 bg-surface-container rounded-xl p-5 space-y-6">
<div class="flex justify-between items-center">
<p class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant font-semibold">Sport Distribution</p>
<span class="font-label text-xs text-primary font-bold">8 Sessions</span>
</div>
<div class="space-y-4">
<div class="space-y-2">
<div class="flex justify-between text-xs font-medium">
<span class="text-on-surface">Cycling</span>
<span class="text-on-surface-variant">45%</span>
</div>
<div class="w-full h-1.5 bg-surface-container-highest rounded-full overflow-hidden flex">
<div class="h-full bg-primary-container w-[45%]"></div>
</div>
</div>
<div class="space-y-2">
<div class="flex justify-between text-xs font-medium">
<span class="text-on-surface">Swimming</span>
<span class="text-on-surface-variant">30%</span>
</div>
<div class="w-full h-1.5 bg-surface-container-highest rounded-full overflow-hidden flex">
<div class="h-full bg-tertiary w-[30%]"></div>
</div>
</div>
<div class="space-y-2">
<div class="flex justify-between text-xs font-medium">
<span class="text-on-surface">Strength</span>
<span class="text-on-surface-variant">25%</span>
</div>
<div class="w-full h-1.5 bg-surface-container-highest rounded-full overflow-hidden flex">
<div class="h-full bg-secondary-container w-[25%]"></div>
</div>
</div>
</div>
</div>
</section>
<!-- Section: Personal Bests Bento -->
<section class="space-y-6">
<div class="space-y-1">
<p class="font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant">Achievement</p>
<h2 class="font-headline text-2xl font-bold text-on-surface">Personal Bests</h2>
</div>
<div class="grid grid-cols-2 gap-3">
<div class="bg-surface-container-high rounded-xl p-5 border border-outline-variant/10 group hover:border-primary/30 transition-all cursor-pointer">
<span class="material-symbols-outlined text-primary mb-3 block" data-icon="timer">timer</span>
<h3 class="text-on-surface font-headline font-bold text-lg">04:12</h3>
<p class="text-on-surface-variant text-[10px] uppercase font-bold tracking-widest mt-1">Fastest 1km</p>
</div>
<div class="bg-surface-container-high rounded-xl p-5 border border-outline-variant/10 group hover:border-primary/30 transition-all cursor-pointer">
<span class="material-symbols-outlined text-tertiary mb-3 block" data-icon="fitness_center">fitness_center</span>
<h3 class="text-on-surface font-headline font-bold text-lg">115 kg</h3>
<p class="text-on-surface-variant text-[10px] uppercase font-bold tracking-widest mt-1">Deadlift Max</p>
</div>
<div class="col-span-2 bg-surface-container-high rounded-xl p-5 border border-outline-variant/10 flex items-center justify-between group hover:border-primary/30 transition-all cursor-pointer">
<div>
<span class="material-symbols-outlined text-primary-container mb-2 block" data-icon="route">route</span>
<h3 class="text-on-surface font-headline font-bold text-lg">52.4 km</h3>
<p class="text-on-surface-variant text-[10px] uppercase font-bold tracking-widest mt-1">Longest Ride</p>
</div>
<div class="w-20 h-20 opacity-20 group-hover:opacity-40 transition-opacity">
<span class="material-symbols-outlined text-[80px]" data-icon="workspace_premium">workspace_premium</span>
</div>
</div>
</div>
</section>
</main>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-6 pt-3 bg-[#1b1b1f]/90 backdrop-blur-2xl dark:bg-[#1b1b1f]/90 z-50 rounded-t-xl shadow-[0px_-12px_32px_rgba(0,0,0,0.4)]">
<a class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined mb-1" data-icon="home">home</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium">Home</span>
</a>
<a class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined mb-1" data-icon="exercise">exercise</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium">Workout</span>
</a>
<a class="flex flex-col items-center justify-center text-[#46f4cb] bg-[#292a2d] rounded-lg px-3 py-1 transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined mb-1" data-icon="monitoring" style="font-variation-settings: 'FILL' 1;">monitoring</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium">Progress</span>
</a>
<a class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined mb-1" data-icon="group">group</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium">Social</span>
</a>
<a class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined mb-1" data-icon="person">person</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium">Profile</span>
</a>
</nav>
</body></html>