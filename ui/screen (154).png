<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>ZVELT Progress - Run Drill-down</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "secondary-fixed-dim": "#adc6ff",
                    "on-tertiary": "#003640",
                    "on-surface-variant": "#bacac3",
                    "surface-container-low": "#1b1b1f",
                    "surface-bright": "#38393c",
                    "on-primary": "#00382c",
                    "surface-container": "#1f1f23",
                    "tertiary-container": "#35cfef",
                    "primary-fixed-dim": "#21dfb8",
                    "background": "#121316",
                    "on-primary-fixed-variant": "#005141",
                    "on-tertiary-container": "#005564",
                    "surface": "#121316",
                    "surface-container-lowest": "#0d0e11",
                    "on-tertiary-fixed": "#001f26",
                    "on-secondary-fixed": "#001a41",
                    "on-secondary": "#002e69",
                    "surface-variant": "#343538",
                    "on-secondary-container": "#e0e8ff",
                    "primary": "#46f4cb",
                    "surface-container-highest": "#343538",
                    "surface-container-high": "#292a2d",
                    "outline": "#84948e",
                    "primary-fixed": "#52fcd3",
                    "inverse-on-surface": "#2f3034",
                    "on-primary-container": "#005847",
                    "inverse-primary": "#006b57",
                    "secondary": "#adc6ff",
                    "on-tertiary-fixed-variant": "#004e5c",
                    "on-secondary-fixed-variant": "#004494",
                    "on-error": "#690005",
                    "tertiary-fixed-dim": "#42d7f8",
                    "secondary-container": "#0264d4",
                    "on-primary-fixed": "#002019",
                    "tertiary": "#8ee7ff",
                    "on-error-container": "#ffdad6",
                    "error": "#ffb4ab",
                    "outline-variant": "#3b4a44",
                    "inverse-surface": "#e3e2e6",
                    "on-surface": "#e3e2e6",
                    "surface-tint": "#21dfb8",
                    "surface-dim": "#121316",
                    "secondary-fixed": "#d8e2ff",
                    "error-container": "#93000a",
                    "primary-container": "#00d7b0",
                    "on-background": "#e3e2e6",
                    "tertiary-fixed": "#acedff"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "fontFamily": {
                    "headline": ["Manrope"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-panel {
            background: rgba(27, 27, 31, 0.7);
            backdrop-filter: blur(20px);
        }
        .liquid-metal-cta {
            background: linear-gradient(135deg, #46f4cb 0%, #00d7b0 100%);
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background text-on-background font-body selection:bg-primary selection:text-on-primary">
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 bg-[#121316]/80 backdrop-blur-lg dark:bg-[#121316]/80 flex justify-between items-center px-6 py-4 w-full">
<div class="flex items-center gap-3">
<div class="w-8 h-8 rounded-full overflow-hidden border border-outline-variant">
<img alt="User Profile" data-alt="Close-up portrait of a fitness professional with a focused expression, soft studio lighting on a dark background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDV1NF_CalgxCADHgKLO2LzBocLCfNZQSTriDjvm2DAOBKF5VlYY4Xm95OEtMvQDct2wJvgOevXd3sIdALJLWQAGNfcXAB3TcaRCrcBBqN8PbVJieR4Ma2jbddcA6ig96CMzgLMD_ay5Km3VbBqhfF1Vcg2OPnqCWh0p5Hl2KCEDcjlQEdlfIhuh_XsW2nx9mpZZXsqbCZhl32Nj5gQ5g6W683AlIjpfUPdAAX-ixN9ZDY5W0l81M0aspmADkZfn36udh2DetzhOmE"/>
</div>
<h1 class="font-headline font-extrabold tracking-tighter text-[#F5F7FA] text-2xl">ZVELT</h1>
</div>
<div class="flex items-center gap-4">
<button class="material-symbols-outlined text-[#A7B0BC] hover:text-[#F5F7FA] transition-colors">settings</button>
</div>
<div class="bg-[#1b1b1f] h-[2px] w-1/3 absolute bottom-0 left-0"></div>
</header>
<main class="pt-24 pb-32 px-6 max-w-7xl mx-auto">
<!-- Header Section -->
<section class="mb-10">
<div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
<div>
<span class="font-label text-xs uppercase tracking-[0.2em] text-primary mb-2 block font-semibold">Activity Analysis</span>
<h2 class="font-headline text-4xl font-extrabold text-[#F5F7FA] tracking-tight">Running Performance</h2>
</div>
<div class="flex bg-surface-container-low p-1 rounded-xl">
<button class="px-6 py-2 rounded-lg bg-surface-container-high text-[#F5F7FA] font-medium text-sm transition-all">7D</button>
<button class="px-6 py-2 rounded-lg text-[#A7B0BC] hover:text-[#F5F7FA] font-medium text-sm transition-all">30D</button>
<button class="px-6 py-2 rounded-lg text-[#A7B0BC] hover:text-[#F5F7FA] font-medium text-sm transition-all">90D</button>
</div>
</div>
</section>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
<!-- Performance Insight Card -->
<div class="lg:col-span-4 space-y-6">
<div class="bg-surface-container-low p-8 rounded-xl border-l-4 border-primary relative overflow-hidden">
<div class="relative z-10">
<div class="flex items-center gap-2 mb-4">
<span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings: 'FILL' 1;">bolt</span>
<span class="font-label text-xs font-bold tracking-widest text-[#A7B0BC] uppercase">Insight</span>
</div>
<h3 class="font-headline text-2xl font-bold text-[#F5F7FA] leading-tight mb-4">Your aerobic base is improving</h3>
<p class="text-[#A7B0BC] leading-relaxed text-sm mb-6">Over the last 14 days, your heart rate at a steady 5:30/km pace has decreased by 4 BPM, indicating superior cardiovascular efficiency.</p>
<div class="flex items-center gap-4">
<div class="h-1 flex-1 bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full w-[78%] bg-primary"></div>
</div>
<span class="font-headline text-primary font-bold">78%</span>
</div>
</div>
<!-- Decorative backglow -->
<div class="absolute -right-16 -bottom-16 w-48 h-48 bg-primary/5 blur-[80px] rounded-full"></div>
</div>
<div class="bg-surface-container p-6 rounded-xl space-y-6">
<h4 class="font-label text-xs font-bold tracking-widest text-[#A7B0BC] uppercase">Core Metrics</h4>
<div class="grid grid-cols-2 gap-6">
<div>
<p class="text-[#A7B0BC] text-xs mb-1">Avg. Pace</p>
<p class="font-headline text-2xl font-bold text-[#F5F7FA]">5:24<span class="text-xs font-normal text-[#A7B0BC] ml-1">/km</span></p>
</div>
<div>
<p class="text-[#A7B0BC] text-xs mb-1">Avg. HR</p>
<p class="font-headline text-2xl font-bold text-[#F5F7FA]">142<span class="text-xs font-normal text-[#A7B0BC] ml-1">bpm</span></p>
</div>
<div>
<p class="text-[#A7B0BC] text-xs mb-1">Distance</p>
<p class="font-headline text-2xl font-bold text-[#F5F7FA]">42.8<span class="text-xs font-normal text-[#A7B0BC] ml-1">km</span></p>
</div>
<div>
<p class="text-[#A7B0BC] text-xs mb-1">Elevation</p>
<p class="font-headline text-2xl font-bold text-[#F5F7FA]">842<span class="text-xs font-normal text-[#A7B0BC] ml-1">m</span></p>
</div>
</div>
</div>
</div>
<!-- Main Trend Chart Area -->
<div class="lg:col-span-8 bg-surface-container-low rounded-xl p-8 flex flex-col h-full">
<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-10">
<h3 class="font-headline text-xl font-bold text-[#F5F7FA]">Trend Analysis</h3>
<div class="flex items-center gap-2 bg-surface-container p-1 rounded-lg">
<button class="px-4 py-1.5 rounded-md text-xs font-bold transition-all bg-primary/10 text-primary">PACE</button>
<button class="px-4 py-1.5 rounded-md text-xs font-bold transition-all text-[#A7B0BC] hover:text-[#F5F7FA]">DISTANCE</button>
<button class="px-4 py-1.5 rounded-md text-xs font-bold transition-all text-[#A7B0BC] hover:text-[#F5F7FA]">HEART RATE</button>
</div>
</div>
<div class="flex-1 min-h-[300px] w-full flex flex-col justify-between relative pt-4">
<!-- Grid Lines -->
<div class="absolute inset-0 flex flex-col justify-between pointer-events-none py-4">
<div class="border-t border-outline-variant/10 w-full"></div>
<div class="border-t border-outline-variant/10 w-full"></div>
<div class="border-t border-outline-variant/10 w-full"></div>
<div class="border-t border-outline-variant/10 w-full"></div>
</div>
<!-- Chart Visualization (SVG) -->
<div class="relative w-full h-full">
<svg class="w-full h-full" preserveaspectratio="none" viewbox="0 0 800 300">
<!-- Area Gradient -->
<defs>
<lineargradient id="areaGradient" x1="0" x2="0" y1="0" y2="1">
<stop offset="0%" stop-color="#46f4cb" stop-opacity="0.15"></stop>
<stop offset="100%" stop-color="#46f4cb" stop-opacity="0"></stop>
</lineargradient>
</defs>
<path d="M0,220 Q100,200 200,240 T400,180 T600,120 T800,140 L800,300 L0,300 Z" fill="url(#areaGradient)"></path>
<!-- Line -->
<path d="M0,220 Q100,200 200,240 T400,180 T600,120 T800,140" fill="none" stroke="#46f4cb" stroke-linecap="round" stroke-width="3"></path>
<!-- Points -->
<circle cx="200" cy="240" fill="#46f4cb" r="5" stroke="#121316" stroke-width="2"></circle>
<circle cx="400" cy="180" fill="#46f4cb" r="5" stroke="#121316" stroke-width="2"></circle>
<circle cx="600" cy="120" fill="#46f4cb" r="5" stroke="#121316" stroke-width="2"></circle>
</svg>
<!-- Tooltip Overlay (Selected state) -->
<div class="absolute top-[30%] left-[75%] -translate-x-1/2 -translate-y-full bg-surface-container-high border border-outline-variant/30 px-4 py-3 rounded-lg shadow-2xl">
<p class="text-[10px] uppercase tracking-tighter text-[#A7B0BC] font-bold">Oct 24, 2023</p>
<p class="font-headline text-lg font-bold text-primary">5:12 /km</p>
</div>
</div>
<div class="flex justify-between mt-6 px-2">
<span class="text-[10px] font-bold text-[#A7B0BC] uppercase tracking-widest">Mon</span>
<span class="text-[10px] font-bold text-[#A7B0BC] uppercase tracking-widest">Tue</span>
<span class="text-[10px] font-bold text-[#A7B0BC] uppercase tracking-widest text-[#F5F7FA]">Wed</span>
<span class="text-[10px] font-bold text-[#A7B0BC] uppercase tracking-widest">Thu</span>
<span class="text-[10px] font-bold text-[#A7B0BC] uppercase tracking-widest">Fri</span>
<span class="text-[10px] font-bold text-[#A7B0BC] uppercase tracking-widest">Sat</span>
<span class="text-[10px] font-bold text-[#A7B0BC] uppercase tracking-widest">Sun</span>
</div>
</div>
</div>
</div>
<!-- Recent Sessions Table -->
<section class="mt-12">
<h3 class="font-headline text-xl font-bold text-[#F5F7FA] mb-6">Session History</h3>
<div class="overflow-x-auto">
<table class="w-full text-left border-collapse">
<thead>
<tr class="border-b border-outline-variant/10">
<th class="pb-4 font-label text-[10px] font-bold uppercase tracking-widest text-[#A7B0BC]">Date &amp; Routine</th>
<th class="pb-4 font-label text-[10px] font-bold uppercase tracking-widest text-[#A7B0BC]">Distance</th>
<th class="pb-4 font-label text-[10px] font-bold uppercase tracking-widest text-[#A7B0BC]">Avg Pace</th>
<th class="pb-4 font-label text-[10px] font-bold uppercase tracking-widest text-[#A7B0BC]">HR Intensity</th>
<th class="pb-4 font-label text-[10px] font-bold uppercase tracking-widest text-[#A7B0BC] text-right">Delta</th>
</tr>
</thead>
<tbody class="divide-y divide-outline-variant/5">
<tr class="group hover:bg-surface-container/30 transition-colors">
<td class="py-6">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-lg bg-surface-container-high flex items-center justify-center text-primary">
<span class="material-symbols-outlined">directions_run</span>
</div>
<div>
<p class="font-headline font-bold text-[#F5F7FA]">Morning Intervals</p>
<p class="text-xs text-[#A7B0BC]">Yesterday, 07:42 AM</p>
</div>
</div>
</td>
<td class="py-6 font-headline font-semibold text-[#F5F7FA]">8.4 km</td>
<td class="py-6 font-headline font-semibold text-[#F5F7FA]">5:12 /km</td>
<td class="py-6">
<div class="flex items-center gap-2">
<div class="h-1.5 w-16 bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full w-[85%] bg-error"></div>
</div>
<span class="text-xs font-bold text-[#F5F7FA]">164 bpm</span>
</div>
</td>
<td class="py-6 text-right">
<div class="inline-flex items-center gap-1 text-primary bg-primary/10 px-2 py-1 rounded text-xs font-bold">
<span class="material-symbols-outlined text-sm">arrow_upward</span>
                                    -0:12
                                </div>
</td>
</tr>
<tr class="group hover:bg-surface-container/30 transition-colors">
<td class="py-6">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-lg bg-surface-container-high flex items-center justify-center text-primary">
<span class="material-symbols-outlined">directions_run</span>
</div>
<div>
<p class="font-headline font-bold text-[#F5F7FA]">Tempo Recovery</p>
<p class="text-xs text-[#A7B0BC]">Oct 24, 05:15 PM</p>
</div>
</div>
</td>
<td class="py-6 font-headline font-semibold text-[#F5F7FA]">12.1 km</td>
<td class="py-6 font-headline font-semibold text-[#F5F7FA]">5:45 /km</td>
<td class="py-6">
<div class="flex items-center gap-2">
<div class="h-1.5 w-16 bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full w-[60%] bg-primary"></div>
</div>
<span class="text-xs font-bold text-[#F5F7FA]">138 bpm</span>
</div>
</td>
<td class="py-6 text-right">
<div class="inline-flex items-center gap-1 text-error bg-error/10 px-2 py-1 rounded text-xs font-bold">
<span class="material-symbols-outlined text-sm">arrow_downward</span>
                                    +0:21
                                </div>
</td>
</tr>
<tr class="group hover:bg-surface-container/30 transition-colors">
<td class="py-6">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-lg bg-surface-container-high flex items-center justify-center text-primary">
<span class="material-symbols-outlined">directions_run</span>
</div>
<div>
<p class="font-headline font-bold text-[#F5F7FA]">Hill Sprints</p>
<p class="text-xs text-[#A7B0BC]">Oct 22, 06:30 AM</p>
</div>
</div>
</td>
<td class="py-6 font-headline font-semibold text-[#F5F7FA]">6.2 km</td>
<td class="py-6 font-headline font-semibold text-[#F5F7FA]">5:28 /km</td>
<td class="py-6">
<div class="flex items-center gap-2">
<div class="h-1.5 w-16 bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full w-[92%] bg-error"></div>
</div>
<span class="text-xs font-bold text-[#F5F7FA]">171 bpm</span>
</div>
</td>
<td class="py-6 text-right">
<div class="inline-flex items-center gap-1 text-[#A7B0BC] bg-surface-container-highest px-2 py-1 rounded text-xs font-bold">
<span class="material-symbols-outlined text-sm">remove</span>
                                    AVG
                                </div>
</td>
</tr>
</tbody>
</table>
</div>
</section>
</main>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full z-50 bg-[#1b1b1f]/90 backdrop-blur-2xl dark:bg-[#1b1b1f]/90 flex justify-around items-center px-4 pb-6 pt-3 rounded-t-xl" style="box-shadow: 0px 12px 32px rgba(0, 0, 0, 0.4);">
<a class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined mb-1">home</span>
<span class="font-headline text-[10px] uppercase tracking-widest font-medium">Home</span>
</a>
<a class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined mb-1">exercise</span>
<span class="font-headline text-[10px] uppercase tracking-widest font-medium">Workout</span>
</a>
<a class="flex flex-col items-center justify-center text-[#46f4cb] bg-[#292a2d] rounded-lg px-3 py-1 transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined mb-1">monitoring</span>
<span class="font-headline text-[10px] uppercase tracking-widest font-medium">Progress</span>
</a>
<a class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined mb-1">group</span>
<span class="font-headline text-[10px] uppercase tracking-widest font-medium">Social</span>
</a>
<a class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined mb-1">person</span>
<span class="font-headline text-[10px] uppercase tracking-widest font-medium">Profile</span>
</a>
</nav>
</body></html>