<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&amp;family=Manrope:wght@700;800&amp;family=Space+Mono:wght@400;700&amp;family=Space+Grotesk:wght@400;500;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "secondary-fixed-dim": "#adc6ff",
                    "on-tertiary": "#003640",
                    "on-primary-container": "#005847",
                    "inverse-surface": "#e3e2e6",
                    "background": "#121316",
                    "tertiary-container": "#35cfef",
                    "surface-container-low": "#1b1b1f",
                    "secondary-fixed": "#d8e2ff",
                    "on-secondary-fixed": "#001a41",
                    "on-surface": "#e3e2e6",
                    "surface-container": "#1f1f23",
                    "on-error": "#690005",
                    "tertiary": "#8ee7ff",
                    "surface-container-highest": "#343538",
                    "on-primary-fixed": "#002019",
                    "on-secondary-container": "#e0e8ff",
                    "on-primary-fixed-variant": "#005141",
                    "primary": "#46f4cb",
                    "secondary-container": "#0264d4",
                    "error-container": "#93000a",
                    "tertiary-fixed": "#acedff",
                    "outline-variant": "#3b4a44",
                    "surface-variant": "#343538",
                    "surface-container-lowest": "#0d0e11",
                    "primary-fixed-dim": "#21dfb8",
                    "on-surface-variant": "#bacac3",
                    "surface-dim": "#121316",
                    "surface-bright": "#38393c",
                    "on-tertiary-fixed": "#001f26",
                    "primary-container": "#00d7b0",
                    "on-error-container": "#ffdad6",
                    "on-tertiary-fixed-variant": "#004e5c",
                    "on-background": "#e3e2e6",
                    "secondary": "#adc6ff",
                    "on-secondary": "#002e69",
                    "outline": "#84948e",
                    "inverse-primary": "#006b57",
                    "inverse-on-surface": "#2f3034",
                    "error": "#ffb4ab",
                    "primary-fixed": "#52fcd3",
                    "surface": "#121316",
                    "tertiary-fixed-dim": "#42d7f8",
                    "on-secondary-fixed-variant": "#004494",
                    "on-primary": "#00382c",
                    "surface-tint": "#21dfb8",
                    "on-tertiary-container": "#005564",
                    "surface-container-high": "#292a2d"
            },
            "borderRadius": {
                    "DEFAULT": "1rem",
                    "lg": "2rem",
                    "xl": "3rem",
                    "full": "9999px"
            },
            "fontFamily": {
                    "headline": ["Manrope"],
                    "body": ["Inter"],
                    "label": ["Space Grotesk"]
            }
          },
        },
      }
    </script>
<style>
      body { background-color: #121316; font-family: 'Inter', sans-serif; -webkit-font-smoothing: antialiased; }
      .grain-overlay {
        pointer-events: none;
        position: fixed;
        inset: 0;
        z-index: 99;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        opacity: 0.04;
      }
      .glass-card {
        background: rgba(255, 255, 255, 0.04);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
      }
      .brand-gradient-text {
        background: linear-gradient(to right, #4A8DFF, #00D7B0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .brand-gradient-bg {
        background: linear-gradient(to right, #4A8DFF, #00D7B0);
      }
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background text-on-background min-h-screen flex flex-col overflow-x-hidden">
<div class="grain-overlay"></div>
<!-- Top Navigation (Shell suppressed for onboarding/focused choice, but maintaining TopAppBar structure as requested) -->
<header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-[#121316]/80 backdrop-blur-lg border-b border-white/10 shadow-[0_4px_30px_rgba(0,0,0,0.1)]">
<button class="active:scale-95 transition-transform text-[#00D7B0]">
<span class="material-symbols-outlined">arrow_back</span>
</button>
<span class="font-['Manrope'] font-extrabold uppercase tracking-widest text-sm brand-gradient-text">ZVELT</span>
<button class="active:scale-95 transition-transform text-slate-500">
<span class="material-symbols-outlined">settings</span>
</button>
</header>
<main class="flex-grow flex flex-col pt-24 pb-12 px-6 max-w-lg mx-auto w-full">
<!-- Title & Intro -->
<section class="mb-12">
<h1 class="font-['Manrope'] font-[800] text-4xl md:text-5xl tracking-tight mb-4 leading-none">
                Measurement system
            </h1>
<p class="font-['Space_Mono'] text-on-surface-variant/60 text-xs uppercase tracking-tighter">
                // Setup Phase 04: Athlete Metrics
            </p>
</section>
<!-- Selection Cards -->
<div class="flex flex-col gap-6 mb-8">
<!-- Metric (Pre-selected) -->
<div class="glass-card relative border-2 border-[#00D7B0] rounded-xl p-8 flex justify-between items-center transition-all cursor-pointer group hover:bg-white/[0.06]">
<div class="flex flex-col">
<h2 class="font-['Manrope'] font-bold text-2xl mb-1">Metric</h2>
<p class="font-['Space_Mono'] text-xs text-on-surface-variant/80">kg, cm, km, Celsius</p>
</div>
<div class="w-8 h-8 rounded-full border-2 border-[#00D7B0] flex items-center justify-center">
<div class="w-4 h-4 rounded-full bg-[#00D7B0]"></div>
</div>
</div>
<!-- Imperial -->
<div class="glass-card relative border border-white/10 rounded-xl p-8 flex justify-between items-center transition-all cursor-pointer group hover:border-[#4A8DFF]/40 hover:bg-white/[0.06]">
<div class="flex flex-col">
<h2 class="font-['Manrope'] font-bold text-2xl mb-1 text-on-surface-variant">Imperial</h2>
<p class="font-['Space_Mono'] text-xs text-on-surface-variant/40">lbs, ft/in, mi, Fahrenheit</p>
</div>
<div class="w-8 h-8 rounded-full border-2 border-white/10 flex items-center justify-center group-hover:border-[#4A8DFF]/40">
<!-- Unselected dot -->
</div>
</div>
</div>
<!-- Hint Text -->
<div class="mb-auto">
<p class="font-['Space_Mono'] text-on-surface-variant/50 text-xs text-center">
                // Readjust in Settings
            </p>
</div>
<!-- Call to Action -->
<div class="mt-8">
<button class="w-full brand-gradient-bg py-5 rounded-full font-['Manrope'] font-bold text-on-primary-fixed uppercase tracking-wider text-sm shadow-[0_0_20px_rgba(0,215,176,0.3)] active:scale-95 transition-all">
                Continue
            </button>
</div>
</main>
<!-- Visual Accents (Asymmetric HUD Elements) -->
<div class="fixed top-1/4 -right-12 w-64 h-64 bg-secondary-container/10 rounded-full blur-[100px] pointer-events-none"></div>
<div class="fixed bottom-0 -left-12 w-80 h-80 bg-primary-container/5 rounded-full blur-[120px] pointer-events-none"></div>
<!-- Optional HUD Data Strip for aesthetic consistency -->
<div class="fixed bottom-8 left-1/2 -translate-x-1/2 hidden md:flex items-center gap-4 text-[10px] font-['Space_Mono'] text-on-surface-variant/30 uppercase tracking-[0.2em] whitespace-nowrap">
<span>Precision: High</span>
<span class="text-[#00D7B0]">|</span>
<span>Sync: Active</span>
<span class="text-[#00D7B0]">|</span>
<span>System: ZVELT v2.0</span>
</div>
</body></html>