</div>
<span class="font-headline font-semibold text-lg tracking-tight">X</span>
</div>
<div class="relative flex items-center justify-center">
<input class="peer hidden" type="checkbox"/>
<div class="w-6 h-6 border-2 border-outline-variant rounded-md transition-all peer-checked:bg-primary-container peer-checked:border-primary-container flex items-center justify-center">
<span class="material-symbols-outlined text-on-primary-container text-sm font-bold scale-0 peer-checked:scale-100 transition-transform" data-icon="check" data-weight="fill">check</span>
</div>
</div>
</label>
<!-- Option Row: App Store -->
<label class="group relative flex items-center justify-between p-6 bg-white/[0.04] backdrop-blur-md border border-white/[0.08] rounded-xl cursor-pointer hover:bg-white/[0.08] transition-all duration-300 active:scale-[0.98]">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-lg bg-surface-container-highest flex items-center justify-center">
<span class="material-symbols-outlined text-on-surface-variant" data-icon="app_store">store</span>
</div>
<span class="font-headline font-semibold text-lg tracking-tight">App Store</span>
</div>
<div class="relative flex items-center justify-center">
<input class="peer hidden" type="checkbox"/>
<div class="w-6 h-6 border-2 border-outline-variant rounded-md transition-all peer-checked:bg-primary-container peer-checked:border-primary-container flex items-center justify-center">
<span class="material-symbols-outlined text-on-primary-container text-sm font-bold scale-0 peer-checked:scale-100 transition-transform" data-icon="check" data-weight="fill">check</span>
</div>
</div>
</label>
<!-- Option Row: Word of mouth -->
<label class="group relative flex items-center justify-between p-6 bg-white/[0.04] backdrop-blur-md border border-white/[0.08] rounded-xl cursor-pointer hover:bg-white/[0.08] transition-all duration-300 active:scale-[0.98]">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-lg bg-surface-container-highest flex items-center justify-center">
<span class="material-symbols-outlined text-on-surface-variant" data-icon="forum">forum</span>
</div>
<span class="font-headline font-semibold text-lg tracking-tight">Word of mouth</span>
</div>
<div class="relative flex items-center justify-center">
<input class="peer hidden" type="checkbox"/>
<div class="w-6 h-6 border-2 border-outline-variant rounded-md transition-all peer-checked:bg-primary-container peer-checked:border-primary-container flex items-center justify-center">
<span class="material-symbols-outlined text-on-primary-container text-sm font-bold scale-0 peer-checked:scale-100 transition-transform" data-icon="check" data-weight="fill">check</span>
</div>
</div>
</label>
<!-- Option Row: Other -->
<label class="group relative flex items-center justify-between p-6 bg-white/[0.04] backdrop-blur-md border border-white/[0.08] rounded-xl cursor-pointer hover:bg-white/[0.08] transition-all duration-300 active:scale-[0.98]">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-lg bg-surface-container-highest flex items-center justify-center">
<span class="material-symbols-outlined text-on-surface-variant" data-icon="more_horiz">more_horiz</span>
</div>
<span class="font-headline font-semibold text-lg tracking-tight">Other</span>
</div>
<div class="relative flex items-center justify-center">
<input class="peer hidden" type="checkbox"/>
<div class="w-6 h-6 border-2 border-outline-variant rounded-md transition-all peer-checked:bg-primary-container peer-checked:border-primary-container flex items-center justify-center">
<span class="material-symbols-outlined text-on-primary-container text-sm font-bold scale-0 peer-checked:scale-100 transition-transform" data-icon="check" data-weight="fill">check</span>
</div>
</div>
</label>
</div>
<!-- Footer Action -->
<div class="mt-12 mb-8 sticky bottom-8">
<button class="w-full h-16 bg-gradient-to-r from-[#4A8DFF] to-[#00D7B0] rounded-full flex items-center justify-center font-headline font-bold text-lg text-on-primary shadow-[0_8px_32px_rgba(74,141,255,0.3)] hover:scale-[1.02] active:scale-95 transition-all duration-300">
                Continue
                <span class="material-symbols-outlined ml-2" data-icon="arrow_forward">arrow_forward</span>
</button>
<p class="text-center mt-4 font-mono text-[10px] text-slate-500 uppercase tracking-widest">Step 3 of 5 • Profile Setup</p>
</div>
</main>
<!-- Side Data Strip (HUD Element) -->
<div class="hidden lg:flex fixed left-8 top-1/2 -translate-y-1/2 flex-col gap-8 pointer-events-none opacity-40">
<div class="flex items-center gap-2 font-mono text-xs text-primary">
<span class="material-symbols-outlined text-sm" data-icon="radar">radar</span>
            SCANNING SOURCE
        </div>
<div class="h-40 w-[1px] bg-gradient-to-b from-transparent via-outline-variant to-transparent mx-auto"></div>
<div class="[writing-mode:vertical-lr] font-mono text-[10px] text-slate-600 tracking-[0.4em] uppercase">
            attribution_module_v1.0.8
        </div>
</div>
</body></html>