<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;600;800&amp;family=Inter:wght@300;400;600&amp;family=Space+Grotesk:wght@400;700&amp;family=Space+Mono:wght@400;700&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "secondary-fixed-dim": "#adc6ff",
                        "on-tertiary": "#003640",
                        "on-primary-container": "#005847",
                        "inverse-surface": "#e3e2e6",
                        "background": "#121316",
                        "tertiary-container": "#35cfef",
                        "surface-container-low": "#1b1b1f",
                        "secondary-fixed": "#d8e2ff",
                        "on-secondary-fixed": "#001a41",
                        "on-surface": "#e3e2e6",
                        "surface-container": "#1f1f23",
                        "on-error": "#690005",
                        "tertiary": "#8ee7ff",
                        "surface-container-highest": "#343538",
                        "on-primary-fixed": "#002019",
                        "on-secondary-container": "#e0e8ff",
                        "on-primary-fixed-variant": "#005141",
                        "primary": "#46f4cb",
                        "secondary-container": "#0264d4",
                        "error-container": "#93000a",
                        "tertiary-fixed": "#acedff",
                        "outline-variant": "#3b4a44",
                        "surface-variant": "#343538",
                        "surface-container-lowest": "#0d0e11",
                        "primary-fixed-dim": "#21dfb8",
                        "on-surface-variant": "#bacac3",
                        "surface-dim": "#121316",
                        "surface-bright": "#38393c",
                        "on-tertiary-fixed": "#001f26",
                        "primary-container": "#00d7b0",
                        "on-error-container": "#ffdad6",
                        "on-tertiary-fixed-variant": "#004e5c",
                        "on-background": "#e3e2e6",
                        "secondary": "#adc6ff",
                        "on-secondary": "#002e69",
                        "outline": "#84948e",
                        "inverse-primary": "#006b57",
                        "inverse-on-surface": "#2f3034",
                        "error": "#ffb4ab",
                        "primary-fixed": "#52fcd3",
                        "surface": "#121316",
                        "tertiary-fixed-dim": "#42d7f8",
                        "on-secondary-fixed-variant": "#004494",
                        "on-primary": "#00382c",
                        "surface-tint": "#21dfb8",
                        "on-tertiary-container": "#005564",
                        "surface-container-high": "#292a2d"
                    },
                    "borderRadius": {
                        "DEFAULT": "1rem",
                        "lg": "2rem",
                        "xl": "3rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Manrope"],
                        "body": ["Inter"],
                        "label": ["Space Grotesk"],
                        "mono": ["Space Mono"]
                    }
                },
            },
        }
    </script>
<style>body {
    background-color: #121316;
    background-image: url(https://lh3.googleusercontent.com/aida-public/AB6AXuB3mnuPbBIm4PD4EgfzvwNbAEkHn647BYJTbM0q0ItoLw3495iFNbpNyKqxG3yrqCpoGLIoOlSI7yW9KLDiGgZ9RFGKomK5TnC2xcI1XDH33j-O5B0WiGy7Q_X-JN5BAFtQPJhUDITs6lpZW0ZFvlaWgYFPLjEk_P3rCFBkg26D0k8LycRcWn3pfRs5UCiGyvpG7n1rC9hZnKdfhB-R3M6U3a2oAZONfMUP60kJ2vBM-6rpvy6wnJZ3xLFW-faSvGRTBDMNbenmNNQ);
    color: #e3e2e6;
    font-family: "Inter", sans-serif;
    overflow-x: hidden
    }
.material-symbols-outlined {
    font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24
    }
.glass-sheet {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08)
    }
.ios-toggle {
    width: 44px;
    height: 24px;
    background: #343538;
    border-radius: 999px;
    position: relative
    }
.ios-toggle::after {
    content: "";
    position: absolute;
    top: 2px;
    left: 2px;
    width: 20px;
    height: 20px;
    background: white;
    border-radius: 50%
    }
.ios-toggle-active {
    background: #00d7b0
    }
.ios-toggle-active::after {
    left: 22px
    }
.brand-gradient-text {
    background: linear-gradient(to right, #4A8DFF, #00D7B0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent
    }
.brand-gradient-bg {
    background: linear-gradient(to right, #4A8DFF, #00D7B0)
    }</style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="min-h-screen flex flex-col items-center">
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-[#121316]/80 backdrop-blur-lg border-b border-white/10 shadow-[0_4px_30px_rgba(0,0,0,0.1)]">
<div class="active:scale-95 transition-transform cursor-pointer">
<span class="material-symbols-outlined text-[#00D7B0]">arrow_back</span>
</div>
<div class="text-2xl font-[800] tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-[#4A8DFF] to-[#00D7B0]">
            ZVELT
        </div>
<div class="active:scale-95 transition-transform cursor-pointer">
<span class="material-symbols-outlined text-[#00D7B0]">settings</span>
</div>
</header>
<main class="flex-1 w-full max-w-md px-6 pt-24 pb-12 flex flex-col items-center">
<!-- Apple Health Icon Container -->
<div class="w-24 h-24 bg-white rounded-[2rem] flex items-center justify-center shadow-[0_20px_50px_rgba(0,0,0,0.3)] mb-8 transform hover:scale-105 transition-transform">
<span class="material-symbols-outlined text-[#FF2D55] !text-5xl" style="font-variation-settings: 'FILL' 1;">favorite</span>
</div>
<!-- Title Section -->
<div class="text-center mb-10">
<h1 class="text-3xl font-headline font-extrabold text-on-surface leading-tight mb-3">
                Allow access to Health
            </h1>
<p class="text-on-surface-variant font-body text-sm px-4">
                Sync your steps, heart rate, and sleep data to optimize your performance insights and kinetic command metrics.
            </p>
</div>
<!-- Health Permission Sheet Preview (Glass Card) -->
<div class="w-full glass-sheet rounded-xl p-6 mb-12 shadow-2xl relative overflow-hidden">
<div class="flex justify-between items-center mb-6">
<span class="font-headline font-extrabold text-xs uppercase tracking-widest text-on-surface-variant">Health Access</span>
<button class="text-[#00D7B0] font-headline font-bold text-sm hover:opacity-80 transition-opacity">Turn On All</button>
</div>
<!-- Permission Rows -->
<div class="space-y-6">
<!-- Row 1 -->
<div class="flex items-center justify-between">
<div class="flex items-center gap-4">
<div class="w-8 h-8 rounded-lg bg-surface-container-highest flex items-center justify-center text-[#46f4cb]">
<span class="material-symbols-outlined !text-xl" style="font-variation-settings: 'FILL' 1;">directions_run</span>
</div>
<span class="font-body text-on-surface font-medium">Steps</span>
</div>
<div class="ios-toggle ios-toggle-active"></div>
</div>
<!-- Row 2 -->
<div class="flex items-center justify-between opacity-60">
<div class="flex items-center gap-4">
<div class="w-8 h-8 rounded-lg bg-surface-container-highest flex items-center justify-center text-[#FF2D55]">
<span class="material-symbols-outlined !text-xl" style="font-variation-settings: 'FILL' 1;">favorite</span>
</div>
<span class="font-body text-on-surface font-medium">Heart Rate</span>
</div>
<div class="ios-toggle"></div>
</div>
<!-- Row 3 (Blurred) -->
<div class="flex items-center justify-between blur-[2px] opacity-40">
<div class="flex items-center gap-4">
<div class="w-8 h-8 rounded-lg bg-surface-container-highest flex items-center justify-center text-secondary">
<span class="material-symbols-outlined !text-xl" style="font-variation-settings: 'FILL' 1;">bedtime</span>
</div>
<span class="font-body text-on-surface font-medium">Sleep Analysis</span>
</div>
<div class="ios-toggle"></div>
</div>
</div>
<!-- Kinetic Texture Detail -->
<div class="absolute -right-12 -bottom-12 w-32 h-32 brand-gradient-bg opacity-10 blur-3xl rounded-full"></div>
</div>
<!-- Technical Label (Space Mono) -->
<div class="flex items-center gap-2 mb-8 font-mono text-[10px] text-outline tracking-wider uppercase">
<span class="material-symbols-outlined !text-[14px]">encrypted</span>
            Your data is encrypted &amp; stored locally
        </div>
<!-- Primary Action -->
<button class="w-full h-14 brand-gradient-bg rounded-full font-headline font-bold text-on-primary flex items-center justify-center gap-2 shadow-[0_10px_30px_rgba(0,215,176,0.3)] active:scale-95 transition-all">
            Continue
            <span class="material-symbols-outlined">arrow_forward</span>
</button>
<!-- Skip Link -->
<button class="mt-6 font-headline font-bold text-sm text-slate-500 hover:text-white transition-colors">
            Not now
        </button>
</main>
<!-- Grain Overlay for Premium Feel -->
<div class="fixed inset-0 pointer-events-none opacity-[0.03]" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuD43AoOau7JLUu2l2ziJg0PB6nf6SPAbvihxqstzSCUA6qabNnuHHO_y61SQ8G1Jhf1Z7CL-UdkiTSad_Kzr-k3H5BCXsBJVBDSkzm_hjB1TuY5U9mTCTf1c5LpSj7-IlbYtaonFharZE0444uT8fxEhPlw-Z3RCSKWA9v1FdyZct6EaFPxBW6MCid4K4uqEq2CeL-doj8z_a55CBvvMR7Gpk55eHuy3tPVi4-gTXfSUDyXNx8tVwBOBl3yT4O14JX6eTt3RxrZn2o');"></div>
<!-- Navigation Shell Suppressed for Transactional/Onboarding journey -->
</body></html>