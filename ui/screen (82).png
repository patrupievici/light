<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>ZVELT | Activity History</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "tertiary-fixed-dim": "#42d7f8",
                        "outline": "#84948e",
                        "on-secondary-container": "#e0e8ff",
                        "surface-container-lowest": "#0d0e11",
                        "secondary-container": "#0264d4",
                        "on-surface-variant": "#bacac3",
                        "error": "#ffb4ab",
                        "surface-dim": "#121316",
                        "primary-fixed-dim": "#21dfb8",
                        "on-primary-fixed-variant": "#005141",
                        "on-background": "#e3e2e6",
                        "surface-tint": "#21dfb8",
                        "primary-container": "#00d7b0",
                        "on-surface": "#e3e2e6",
                        "on-primary-container": "#005847",
                        "surface-container-highest": "#343538",
                        "on-tertiary-fixed-variant": "#004e5c",
                        "on-tertiary-fixed": "#001f26",
                        "surface-container-low": "#1b1b1f",
                        "on-error-container": "#ffdad6",
                        "inverse-on-surface": "#2f3034",
                        "primary-fixed": "#52fcd3",
                        "primary": "#46f4cb",
                        "tertiary-container": "#35cfef",
                        "error-container": "#93000a",
                        "on-tertiary": "#003640",
                        "surface-container-high": "#292a2d",
                        "on-secondary-fixed-variant": "#004494",
                        "on-secondary": "#002e69",
                        "on-primary-fixed": "#002019",
                        "secondary-fixed": "#d8e2ff",
                        "background": "#121316",
                        "secondary": "#adc6ff",
                        "secondary-fixed-dim": "#adc6ff",
                        "outline-variant": "#3b4a44",
                        "on-secondary-fixed": "#001a41",
                        "inverse-primary": "#006b57",
                        "on-error": "#690005",
                        "tertiary": "#8ee7ff",
                        "surface-container": "#1f1f23",
                        "surface-bright": "#38393c",
                        "on-tertiary-container": "#005564",
                        "surface-variant": "#343538",
                        "surface": "#121316",
                        "tertiary-fixed": "#acedff",
                        "on-primary": "#00382c",
                        "inverse-surface": "#e3e2e6"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "fontFamily": {
                        "headline": ["Manrope"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    }
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .liquid-metal-bg {
            background: linear-gradient(135deg, #46f4cb 0%, #00d7b0 100%);
        }
        .glass-panel {
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-surface-dim text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">
<!-- TopAppBar -->
<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-zinc-950/60 backdrop-blur-xl">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-zinc-500 cursor-pointer hover:text-[#46f4cb] transition-colors duration-200">menu</span>
<h1 class="text-xl font-bold tracking-tighter text-[#00D7B0] font-headline">ZVELT</h1>
</div>
<div class="flex items-center gap-6">
<nav class="hidden md:flex gap-8 items-center">
<a class="text-zinc-500 font-medium hover:text-[#46f4cb] transition-colors duration-200 font-label text-sm tracking-wide" href="#">Dashboard</a>
<a class="text-zinc-500 font-medium hover:text-[#46f4cb] transition-colors duration-200 font-label text-sm tracking-wide" href="#">Activity</a>
<a class="text-zinc-500 font-medium hover:text-[#46f4cb] transition-colors duration-200 font-label text-sm tracking-wide" href="#">Premium</a>
<a class="text-[#46f4cb] font-semibold font-label text-sm tracking-wide" href="#">Profile</a>
</nav>
<div class="w-8 h-8 rounded-full bg-surface-container-highest border border-outline-variant overflow-hidden">
<img alt="User avatar" class="w-full h-full object-cover" data-alt="close-up portrait of a determined female athlete with subtle sweat on her brow in a moody dark gym setting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuARqwNbdtms1QGiD3Sbse7bX23QGKcFPGBoQcruyPYhe8SbOiCYZms8SvdWZYjJZpo7JavLxn0yS11XfXzxgRlhQBs9O5KyEA2mvAzP-aHqYroeGKNhUFS8OwVOtYGQzmzu7u-ArK4WIQrgLvYsxALjJEy2dbyOk0uiReGJRWvA5O1wxJ1ui9sIVb2M7xSJa8Pz6JrgQuBbYTwvzwTJSzsLON1sRZypnC8751uZ-QHU-TohiMTrTXuS0mrGMm9HEMzXd7Dexga1v7E"/>
</div>
</div>
</header>
<main class="pt-24 pb-32 px-6 max-w-5xl mx-auto min-h-screen">
<!-- Header & Search -->
<section class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
<div class="space-y-1">
<p class="text-xs font-label uppercase tracking-[0.2em] text-on-surface-variant font-medium">Performance Log</p>
<h2 class="text-4xl font-headline font-extrabold tracking-tight text-on-surface">Activity History</h2>
</div>
<!-- Sport Filters -->
<div class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide">
<button class="px-5 py-2 rounded-xl bg-zinc-900/80 text-[#46f4cb] border border-primary/20 text-xs font-semibold font-label tracking-wide whitespace-nowrap">All Sports</button>
<button class="px-5 py-2 rounded-xl bg-surface-container-low text-on-surface-variant hover:text-on-surface transition-colors text-xs font-medium font-label tracking-wide whitespace-nowrap">Running</button>
<button class="px-5 py-2 rounded-xl bg-surface-container-low text-on-surface-variant hover:text-on-surface transition-colors text-xs font-medium font-label tracking-wide whitespace-nowrap">Cycling</button>
<button class="px-5 py-2 rounded-xl bg-surface-container-low text-on-surface-variant hover:text-on-surface transition-colors text-xs font-medium font-label tracking-wide whitespace-nowrap">Swimming</button>
<button class="px-5 py-2 rounded-xl bg-surface-container-low text-on-surface-variant hover:text-on-surface transition-colors text-xs font-medium font-label tracking-wide whitespace-nowrap">Strength</button>
</div>
</section>
<!-- Stats Overview Row -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
<div class="p-6 rounded-xl bg-surface-container-low border-l-2 border-primary">
<p class="text-xs font-label text-on-surface-variant tracking-wider uppercase mb-2">Total Dist.</p>
<p class="text-2xl font-headline font-bold text-on-surface">428.5 <span class="text-sm font-medium text-on-surface-variant">km</span></p>
</div>
<div class="p-6 rounded-xl bg-surface-container-low border-l-2 border-tertiary">
<p class="text-xs font-label text-on-surface-variant tracking-wider uppercase mb-2">Total Time</p>
<p class="text-2xl font-headline font-bold text-on-surface">34 <span class="text-sm font-medium text-on-surface-variant">h</span> 12 <span class="text-sm font-medium text-on-surface-variant">m</span></p>
</div>
<div class="p-6 rounded-xl bg-surface-container-low border-l-2 border-primary-container">
<p class="text-xs font-label text-on-surface-variant tracking-wider uppercase mb-2">Avg. Heart</p>
<p class="text-2xl font-headline font-bold text-on-surface">142 <span class="text-sm font-medium text-on-surface-variant">bpm</span></p>
</div>
<div class="p-6 rounded-xl bg-surface-container-low border-l-2 border-secondary">
<p class="text-xs font-label text-on-surface-variant tracking-wider uppercase mb-2">Sessions</p>
<p class="text-2xl font-headline font-bold text-on-surface">18 <span class="text-sm font-medium text-on-surface-variant">mt</span></p>
</div>
</div>
<!-- Activity List -->
<div class="space-y-4">
<!-- Timeline Separator -->
<div class="flex items-center gap-4 py-4">
<span class="text-xs font-label font-bold tracking-[0.15em] text-on-surface-variant uppercase">September 2023</span>
<div class="h-[1px] flex-grow bg-outline-variant/30"></div>
</div>
<!-- Activity Card: Run -->
<div class="group flex flex-col md:flex-row items-start md:items-center gap-6 p-5 rounded-xl bg-surface-container hover:bg-surface-container-high transition-all cursor-pointer border border-transparent hover:border-outline-variant/20">
<div class="flex items-center gap-5 w-full md:w-auto">
<div class="w-14 h-14 rounded-xl bg-zinc-900 flex items-center justify-center text-primary border border-outline-variant/30">
<span class="material-symbols-outlined text-3xl">directions_run</span>
</div>
<div class="flex flex-col">
<h3 class="font-headline font-bold text-lg text-on-surface leading-tight">Morning Trail Run</h3>
<p class="text-xs font-label text-on-surface-variant">Sep 24 • 07:12 AM</p>
</div>
</div>
<div class="flex-grow grid grid-cols-3 md:grid-cols-4 gap-4 w-full">
<div class="flex flex-col">
<p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant">Distance</p>
<p class="text-base font-bold font-headline">12.4 <span class="text-[10px] font-medium opacity-60">km</span></p>
</div>
<div class="flex flex-col">
<p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant">Duration</p>
<p class="text-base font-bold font-headline">58:12</p>
</div>
<div class="flex flex-col">
<p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant">Avg. Pace</p>
<p class="text-base font-bold font-headline">4'42" <span class="text-[10px] font-medium opacity-60">/km</span></p>
</div>
<div class="hidden md:flex flex-col items-end">
<div class="px-2 py-1 bg-primary/10 rounded-lg">
<p class="text-[10px] font-bold text-primary tracking-tighter">+12 PR</p>
</div>
</div>
</div>
<div class="hidden md:block">
<span class="material-symbols-outlined text-zinc-600 group-hover:text-on-surface transition-colors">chevron_right</span>
</div>
</div>
<!-- Activity Card: Cycle -->
<div class="group flex flex-col md:flex-row items-start md:items-center gap-6 p-5 rounded-xl bg-surface-container hover:bg-surface-container-high transition-all cursor-pointer border border-transparent hover:border-outline-variant/20">
<div class="flex items-center gap-5 w-full md:w-auto">
<div class="w-14 h-14 rounded-xl bg-zinc-900 flex items-center justify-center text-tertiary border border-outline-variant/30">
<span class="material-symbols-outlined text-3xl">directions_bike</span>
</div>
<div class="flex flex-col">
<h3 class="font-headline font-bold text-lg text-on-surface leading-tight">Coastline Sprint</h3>
<p class="text-xs font-label text-on-surface-variant">Sep 22 • 05:45 PM</p>
</div>
</div>
<div class="flex-grow grid grid-cols-3 md:grid-cols-4 gap-4 w-full">
<div class="flex flex-col">
<p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant">Distance</p>
<p class="text-base font-bold font-headline">34.8 <span class="text-[10px] font-medium opacity-60">km</span></p>
</div>
<div class="flex flex-col">
<p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant">Duration</p>
<p class="text-base font-bold font-headline">1:12:05</p>
</div>
<div class="flex flex-col">
<p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant">Avg. Speed</p>
<p class="text-base font-bold font-headline">28.9 <span class="text-[10px] font-medium opacity-60">km/h</span></p>
</div>
<div class="hidden md:flex flex-col items-end">
<div class="px-2 py-1 bg-tertiary/10 rounded-lg">
<p class="text-[10px] font-bold text-tertiary tracking-tighter">AEROBIC</p>
</div>
</div>
</div>
<div class="hidden md:block">
<span class="material-symbols-outlined text-zinc-600 group-hover:text-on-surface transition-colors">chevron_right</span>
</div>
</div>
<!-- Activity Card: Swim -->
<div class="group flex flex-col md:flex-row items-start md:items-center gap-6 p-5 rounded-xl bg-surface-container hover:bg-surface-container-high transition-all cursor-pointer border border-transparent hover:border-outline-variant/20">
<div class="flex items-center gap-5 w-full md:w-auto">
<div class="w-14 h-14 rounded-xl bg-zinc-900 flex items-center justify-center text-[#46f4cb] border border-outline-variant/30">
<span class="material-symbols-outlined text-3xl">pool</span>
</div>
<div class="flex flex-col">
<h3 class="font-headline font-bold text-lg text-on-surface leading-tight">Indoor Lap Session</h3>
<p class="text-xs font-label text-on-surface-variant">Sep 20 • 06:00 AM</p>
</div>
</div>
<div class="flex-grow grid grid-cols-3 md:grid-cols-4 gap-4 w-full">
<div class="flex flex-col">
<p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant">Distance</p>
<p class="text-base font-bold font-headline">2,100 <span class="text-[10px] font-medium opacity-60">m</span></p>
</div>
<div class="flex flex-col">
<p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant">Duration</p>
<p class="text-base font-bold font-headline">45:00</p>
</div>
<div class="flex flex-col">
<p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant">Swolf</p>
<p class="text-base font-bold font-headline">38</p>
</div>
<div class="hidden md:flex flex-col items-end">
<div class="px-2 py-1 bg-primary/10 rounded-lg">
<p class="text-[10px] font-bold text-primary tracking-tighter">RECOVERY</p>
</div>
</div>
</div>
<div class="hidden md:block">
<span class="material-symbols-outlined text-zinc-600 group-hover:text-on-surface transition-colors">chevron_right</span>
</div>
</div>
<!-- Timeline Separator -->
<div class="flex items-center gap-4 py-8">
<span class="text-xs font-label font-bold tracking-[0.15em] text-on-surface-variant uppercase">August 2023</span>
<div class="h-[1px] flex-grow bg-outline-variant/30"></div>
</div>
<!-- Activity Card: Strength -->
<div class="group flex flex-col md:flex-row items-start md:items-center gap-6 p-5 rounded-xl bg-surface-container hover:bg-surface-container-high transition-all cursor-pointer border border-transparent hover:border-outline-variant/20">
<div class="flex items-center gap-5 w-full md:w-auto">
<div class="w-14 h-14 rounded-xl bg-zinc-900 flex items-center justify-center text-secondary border border-outline-variant/30">
<span class="material-symbols-outlined text-3xl">fitness_center</span>
</div>
<div class="flex flex-col">
<h3 class="font-headline font-bold text-lg text-on-surface leading-tight">Upper Body Hypertrophy</h3>
<p class="text-xs font-label text-on-surface-variant">Aug 28 • 08:30 PM</p>
</div>
</div>
<div class="flex-grow grid grid-cols-3 md:grid-cols-4 gap-4 w-full">
<div class="flex flex-col">
<p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant">Volume</p>
<p class="text-base font-bold font-headline">4,200 <span class="text-[10px] font-medium opacity-60">kg</span></p>
</div>
<div class="flex flex-col">
<p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant">Duration</p>
<p class="text-base font-bold font-headline">1:15:00</p>
</div>
<div class="flex flex-col">
<p class="text-[10px] font-label uppercase tracking-widest text-on-surface-variant">Intensity</p>
<p class="text-base font-bold font-headline">High</p>
</div>
<div class="hidden md:flex flex-col items-end">
<div class="px-2 py-1 bg-secondary/10 rounded-lg">
<p class="text-[10px] font-bold text-secondary tracking-tighter">POWER</p>
</div>
</div>
</div>
<div class="hidden md:block">
<span class="material-symbols-outlined text-zinc-600 group-hover:text-on-surface transition-colors">chevron_right</span>
</div>
</div>
</div>
<!-- Load More -->
<div class="mt-12 flex justify-center">
<button class="px-8 py-3 rounded-xl bg-surface-container-low text-on-surface-variant font-label font-semibold text-sm hover:text-on-surface hover:bg-surface-container transition-all border border-outline-variant/20">
                Load Older Activities
            </button>
</div>
</main>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-zinc-950/60 backdrop-blur-xl rounded-t-xl md:hidden">
<div class="flex flex-col items-center justify-center text-zinc-500 opacity-70">
<span class="material-symbols-outlined">speed</span>
<span class="text-[10px] font-label tracking-wider mt-1">Dashboard</span>
</div>
<div class="flex flex-col items-center justify-center text-zinc-500 opacity-70">
<span class="material-symbols-outlined">monitoring</span>
<span class="text-[10px] font-label tracking-wider mt-1">Activity</span>
</div>
<div class="flex flex-col items-center justify-center text-zinc-500 opacity-70">
<span class="material-symbols-outlined">workspace_premium</span>
<span class="text-[10px] font-label tracking-wider mt-1">Premium</span>
</div>
<div class="flex flex-col items-center justify-center text-[#46f4cb] bg-zinc-900/80 rounded-xl px-4 py-1.5 transition-all">
<span class="material-symbols-outlined">person</span>
<span class="text-[10px] font-label tracking-wider mt-1">Profile</span>
</div>
</nav>
</body></html>