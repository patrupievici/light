<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>ZVELT Progress | Goals &amp; Milestones</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&amp;family=Inter:wght@300;400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
            "secondary-fixed-dim": "#adc6ff",
            "on-tertiary": "#003640",
            "on-surface-variant": "#bacac3",
            "surface-container-low": "#1b1b1f",
            "surface-bright": "#38393c",
            "on-primary": "#00382c",
            "surface-container": "#1f1f23",
            "tertiary-container": "#35cfef",
            "primary-fixed-dim": "#21dfb8",
            "background": "#121316",
            "on-primary-fixed-variant": "#005141",
            "on-tertiary-container": "#005564",
            "surface": "#121316",
            "surface-container-lowest": "#0d0e11",
            "on-tertiary-fixed": "#001f26",
            "on-secondary-fixed": "#001a41",
            "on-secondary": "#002e69",
            "surface-variant": "#343538",
            "on-secondary-container": "#e0e8ff",
            "primary": "#46f4cb",
            "surface-container-highest": "#343538",
            "surface-container-high": "#292a2d",
            "outline": "#84948e",
            "primary-fixed": "#52fcd3",
            "inverse-on-surface": "#2f3034",
            "on-primary-container": "#005847",
            "inverse-primary": "#006b57",
            "secondary": "#adc6ff",
            "on-tertiary-fixed-variant": "#004e5c",
            "on-secondary-fixed-variant": "#004494",
            "on-error": "#690005",
            "tertiary-fixed-dim": "#42d7f8",
            "secondary-container": "#0264d4",
            "on-primary-fixed": "#002019",
            "tertiary": "#8ee7ff",
            "on-error-container": "#ffdad6",
            "error": "#ffb4ab",
            "outline-variant": "#3b4a44",
            "inverse-surface": "#e3e2e6",
            "on-surface": "#e3e2e6",
            "surface-tint": "#21dfb8",
            "surface-dim": "#121316",
            "secondary-fixed": "#d8e2ff",
            "error-container": "#93000a",
            "primary-container": "#00d7b0",
            "on-background": "#e3e2e6",
            "tertiary-fixed": "#acedff"
          },
          "borderRadius": {
            "DEFAULT": "0.125rem",
            "lg": "0.25rem",
            "xl": "0.5rem",
            "full": "0.75rem"
          },
          "fontFamily": {
            "headline": ["Manrope"],
            "body": ["Inter"],
            "label": ["Inter"]
          }
        },
      },
    }
  </script>
<style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .liquid-metal-gradient {
      background: linear-gradient(135deg, #46f4cb 0%, #00d7b0 100%);
    }
    .surface-glow {
      box-shadow: 0 0 20px rgba(70, 244, 203, 0.1);
    }
    body {
      background-color: #121316;
      color: #e3e2e6;
      font-family: 'Inter', sans-serif;
    }
  </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background min-h-screen pb-24">
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 bg-[#121316]/80 backdrop-blur-lg dark:bg-[#121316]/80 flex justify-between items-center px-6 py-4 w-full">
<div class="flex items-center gap-3">
<div class="w-8 h-8 rounded-full overflow-hidden border border-outline-variant/30">
<img class="w-full h-full object-cover" data-alt="close-up portrait of a professional athlete with focused expression, high contrast lighting, dark moody background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBiD-b8SAMCT85_mLFxtSpacW8b9K6sl_MGgpVS_YU-8bMpLSqYscOFjEfcrfABPZkDZ5Vf1keUSWhXAIMKnM3WxHSOUgbuLbHKdvu3tnmWBMglGC1aIgDaCUsKy7w478fvP4pSMtC_SCKsVyppCDth6qxbxj_9hvTsKKZiql9tPhZTtY7kJLuH1c8lOiwDgf55IacsCdR8RFK3c9PzABFUpN7c7PTgSJexFL9r3-qOdRlMBQnOoBx4AJxCvhLbTgGhn8vQl1dh104"/>
</div>
<span class="font-manrope font-extrabold tracking-tighter text-[#F5F7FA] text-2xl">ZVELT</span>
</div>
<div class="flex items-center gap-4">
<button class="text-[#A7B0BC] hover:bg-[#1f1f23] transition-colors p-2 rounded-lg active:scale-95 duration-150">
<span class="material-symbols-outlined" data-icon="settings">settings</span>
</button>
</div>
<div class="bg-[#1b1b1f] h-[2px] w-1/3 absolute bottom-0 left-0"></div>
</header>
<main class="pt-24 px-6 max-w-5xl mx-auto space-y-8">
<!-- Hero Section: Streak & Core Metric -->
<section class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
<div class="md:col-span-2 space-y-2">
<h1 class="font-headline font-extrabold text-4xl lg:text-5xl tracking-tight text-on-background">
          Forging <span class="text-primary">Consistency</span>
</h1>
<p class="font-body text-on-surface-variant max-w-md">Your 14-day streak is a testament to disciplined progress. Keep the momentum alive.</p>
</div>
<div class="bg-surface-container-low p-8 rounded-xl border-l-4 border-primary surface-glow flex flex-col items-end justify-between aspect-square md:aspect-auto h-48">
<span class="font-label text-[10px] uppercase tracking-[0.2em] text-on-surface-variant">Active Streak</span>
<div class="text-right">
<span class="font-headline font-bold text-6xl leading-none text-primary">14</span>
<span class="font-label text-lg ml-1 text-on-surface-variant">DAYS</span>
</div>
</div>
</section>
<!-- Bento Grid Goals -->
<section class="grid grid-cols-1 md:grid-cols-12 gap-4">
<!-- Primary Goal Card -->
<div class="md:col-span-8 bg-surface-container p-6 rounded-xl space-y-6">
<div class="flex justify-between items-start">
<div>
<span class="font-label text-[10px] uppercase tracking-widest text-primary mb-1 block">Monthly Objective</span>
<h2 class="font-headline font-bold text-2xl text-on-background">Run 50km this month</h2>
</div>
<span class="material-symbols-outlined text-primary text-3xl" data-icon="directions_run">directions_run</span>
</div>
<div class="space-y-3">
<div class="flex justify-between items-end">
<div class="flex items-baseline gap-1">
<span class="font-headline font-bold text-4xl text-on-background">32.4</span>
<span class="font-label text-on-surface-variant">/ 50 km</span>
</div>
<span class="font-label text-sm font-semibold text-primary">65% Complete</span>
</div>
<div class="h-3 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full liquid-metal-gradient rounded-full" style="width: 65%"></div>
</div>
</div>
<div class="pt-4 grid grid-cols-3 gap-4 border-t border-outline-variant/10">
<div>
<p class="font-label text-[10px] uppercase text-on-surface-variant">Remaining</p>
<p class="font-body font-semibold text-on-background">17.6 km</p>
</div>
<div>
<p class="font-label text-[10px] uppercase text-on-surface-variant">Pace Avg</p>
<p class="font-body font-semibold text-on-background">5'12" /km</p>
</div>
<div>
<p class="font-label text-[10px] uppercase text-on-surface-variant">Days Left</p>
<p class="font-body font-semibold text-on-background">12 Days</p>
</div>
</div>
</div>
<!-- Secondary Goal Card -->
<div class="md:col-span-4 bg-surface-container-low p-6 rounded-xl flex flex-col justify-between">
<div>
<div class="flex justify-between items-start mb-4">
<span class="material-symbols-outlined text-secondary" data-icon="fitness_center">fitness_center</span>
<span class="bg-secondary/10 text-secondary text-[10px] font-bold px-2 py-1 rounded">STRENGTH</span>
</div>
<h3 class="font-headline font-bold text-xl text-on-background leading-tight">Deadlift 200kg</h3>
<p class="font-body text-sm text-on-surface-variant mt-2">Current Max: 185kg</p>
</div>
<div class="mt-8 space-y-2">
<div class="flex justify-between text-xs font-label text-on-surface-variant">
<span>Progress</span>
<span>92%</span>
</div>
<div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-secondary rounded-full" style="width: 92.5%"></div>
</div>
</div>
</div>
<!-- Tertiary Milestone Summary -->
<div class="md:col-span-4 bg-surface-container-highest/30 p-6 rounded-xl border border-outline-variant/10">
<div class="flex items-center gap-3 mb-4">
<span class="material-symbols-outlined text-tertiary" data-icon="workspace_premium">workspace_premium</span>
<h3 class="font-headline font-bold text-lg text-on-background">Milestones</h3>
</div>
<div class="space-y-4">
<div class="flex gap-4">
<div class="flex-shrink-0 w-8 h-8 rounded-lg bg-surface-container-high flex items-center justify-center">
<span class="material-symbols-outlined text-sm text-on-surface-variant" data-icon="check">check</span>
</div>
<div>
<p class="font-body text-sm font-medium text-on-background">First 10k Run</p>
<p class="font-label text-[10px] text-on-surface-variant">Oct 12, 2023</p>
</div>
</div>
<div class="flex gap-4">
<div class="flex-shrink-0 w-8 h-8 rounded-lg bg-surface-container-high flex items-center justify-center">
<span class="material-symbols-outlined text-sm text-on-surface-variant" data-icon="check">check</span>
</div>
<div>
<p class="font-body text-sm font-medium text-on-background">30 Day Streak</p>
<p class="font-label text-[10px] text-on-surface-variant">Aug 20, 2023</p>
</div>
</div>
</div>
</div>
<!-- Data Visualizer -->
<div class="md:col-span-8 bg-surface-container p-6 rounded-xl overflow-hidden relative">
<div class="flex justify-between items-center mb-8">
<h3 class="font-headline font-bold text-lg">Performance Load</h3>
<div class="flex gap-2">
<div class="w-3 h-3 rounded-full bg-primary"></div>
<div class="w-3 h-3 rounded-full bg-tertiary/40"></div>
</div>
</div>
<div class="h-32 flex items-end justify-between gap-1">
<div class="w-full bg-primary/20 rounded-t-sm" style="height: 40%"></div>
<div class="w-full bg-primary/40 rounded-t-sm" style="height: 60%"></div>
<div class="w-full bg-primary/30 rounded-t-sm" style="height: 50%"></div>
<div class="w-full bg-primary/60 rounded-t-sm" style="height: 80%"></div>
<div class="w-full bg-primary rounded-t-sm" style="height: 100%"></div>
<div class="w-full bg-primary/70 rounded-t-sm" style="height: 75%"></div>
<div class="w-full bg-primary/40 rounded-t-sm" style="height: 45%"></div>
<div class="w-full bg-primary/20 rounded-t-sm" style="height: 30%"></div>
<div class="w-full bg-primary/60 rounded-t-sm" style="height: 85%"></div>
<div class="w-full bg-primary rounded-t-sm" style="height: 95%"></div>
<div class="w-full bg-primary/50 rounded-t-sm" style="height: 60%"></div>
<div class="w-full bg-primary/30 rounded-t-sm" style="height: 40%"></div>
</div>
<div class="absolute inset-0 bg-gradient-to-t from-surface-container via-transparent to-transparent pointer-events-none"></div>
</div>
</section>
<!-- Milestone Timeline -->
<section class="space-y-6">
<div class="flex items-center justify-between">
<h2 class="font-headline font-bold text-xl tracking-tight text-on-background">Achievement Timeline</h2>
<button class="font-label text-xs font-semibold text-primary uppercase tracking-widest">View All</button>
</div>
<div class="relative space-y-8 before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-primary/50 before:via-outline-variant/20 before:to-transparent">
<!-- Timeline Item 1 -->
<div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
<div class="flex items-center justify-center w-10 h-10 rounded-full border border-primary bg-background text-primary shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2">
<span class="material-symbols-outlined text-sm" data-icon="military_tech" style="font-variation-settings: 'FILL' 1;">military_tech</span>
</div>
<div class="w-[calc(100%-4rem)] md:w-[45%] bg-surface-container-low p-5 rounded-xl border border-outline-variant/10">
<div class="flex items-center justify-between mb-1">
<div class="font-headline font-bold text-on-background">Iron Will Trophy</div>
<time class="font-label text-[10px] text-on-surface-variant uppercase">Oct 24</time>
</div>
<p class="font-body text-sm text-on-surface-variant">Completed 20 high-intensity interval training sessions in a single month without failure.</p>
</div>
</div>
<!-- Timeline Item 2 -->
<div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
<div class="flex items-center justify-center w-10 h-10 rounded-full border border-outline-variant/50 bg-background text-on-surface-variant shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2">
<span class="material-symbols-outlined text-sm" data-icon="speed">speed</span>
</div>
<div class="w-[calc(100%-4rem)] md:w-[45%] bg-surface-container-low p-5 rounded-xl border border-outline-variant/10">
<div class="flex items-center justify-between mb-1">
<div class="font-headline font-bold text-on-background">Velocity Peak</div>
<time class="font-label text-[10px] text-on-surface-variant uppercase">Sep 12</time>
</div>
<p class="font-body text-sm text-on-surface-variant">Achieved a personal best 5km split time of 19:45 during the Autumn Open session.</p>
</div>
</div>
</div>
</section>
</main>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-6 pt-3 bg-[#1b1b1f]/90 backdrop-blur-2xl dark:bg-[#1b1b1f]/90 z-50 rounded-t-xl" style="box-shadow: 0px 12px 32px rgba(0, 0, 0, 0.4);">
<a class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined" data-icon="home">home</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium mt-1">Home</span>
</a>
<a class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined" data-icon="exercise">exercise</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium mt-1">Workout</span>
</a>
<a class="flex flex-col items-center justify-center text-[#46f4cb] bg-[#292a2d] rounded-lg px-3 py-1 transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined" data-icon="monitoring" style="font-variation-settings: 'FILL' 1;">monitoring</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium mt-1">Progress</span>
</a>
<a class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out" href="#">
<span class="material-symbols-outlined" data-icon="group">group</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium mt-1">Social</span>
</a>
<a class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out" href="#">
<div class="w-6 h-6 rounded-full overflow-hidden border border-on-surface-variant/20 mb-1">
<img class="w-full h-full object-cover" data-alt="close-up portrait of a professional athlete with focused expression, high contrast lighting, dark moody background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDFnpvhEpBhtVSEzHZlh8OU43tTTzMFtoyue3H4vLMGATs7tnxsOLQeEEUXcQB7DagO-E68pexaj_lufhyUQr4dip5snH10akFkLwuMylOA0N2LYxbo70QFrOXj6STzZJvby74aJPzug8e4Cq3nb5YRtk7OsRdQn2aCw1BXLszSi3uZsoitejtpHrSCy3fvmB6hZ-zupZ_OxbTzMUaMmqH-t2RAKfROv7E-dJToN9ylD4vAFsbEznVH7zYSampVIkdMMQl7SKwazmo"/>
</div>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium">Profile</span>
</a>
</nav>
</body></html>