<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>PULSE | Ghost Challenge Config</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "inverse-primary": "#006b57",
                        "surface-container-high": "#292a2d",
                        "outline-variant": "#3b4a44",
                        "secondary": "#adc6ff",
                        "on-primary": "#00382c",
                        "tertiary": "#8ee7ff",
                        "error": "#ffb4ab",
                        "surface-container-low": "#1b1b1f",
                        "surface-bright": "#38393c",
                        "primary-fixed-dim": "#21dfb8",
                        "surface": "#121316",
                        "on-primary-container": "#005847",
                        "tertiary-fixed-dim": "#42d7f8",
                        "primary-fixed": "#52fcd3",
                        "inverse-surface": "#e3e2e6",
                        "surface-container-highest": "#343538",
                        "on-primary-fixed": "#002019",
                        "surface-dim": "#121316",
                        "on-error": "#690005",
                        "on-tertiary-fixed-variant": "#004e5c",
                        "surface-container-lowest": "#0d0e11",
                        "on-surface-variant": "#bacac3",
                        "on-secondary-fixed-variant": "#004494",
                        "inverse-on-surface": "#2f3034",
                        "tertiary-container": "#35cfef",
                        "on-tertiary-fixed": "#001f26",
                        "surface-variant": "#343538",
                        "on-surface": "#e3e2e6",
                        "secondary-fixed": "#d8e2ff",
                        "on-tertiary-container": "#005564",
                        "on-error-container": "#ffdad6",
                        "surface-tint": "#21dfb8",
                        "outline": "#84948e",
                        "on-secondary-container": "#e0e8ff",
                        "on-primary-fixed-variant": "#005141",
                        "on-secondary": "#002e69",
                        "on-background": "#e3e2e6",
                        "error-container": "#93000a",
                        "background": "#121316",
                        "primary": "#46f4cb",
                        "surface-container": "#1f1f23",
                        "secondary-fixed-dim": "#adc6ff",
                        "secondary-container": "#0264d4",
                        "primary-container": "#00d7b0",
                        "on-tertiary": "#003640",
                        "tertiary-fixed": "#acedff",
                        "on-secondary-fixed": "#001a41"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "fontFamily": {
                        "headline": ["Manrope"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    }
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .liquid-metal-gradient {
            background: linear-gradient(135deg, #46f4cb 0%, #00d7b0 100%);
        }
        .data-glow {
            text-shadow: 0 0 15px rgba(70, 244, 203, 0.4);
        }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-surface text-on-surface font-body selection:bg-primary/30 min-h-screen pb-32">
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 flex items-center justify-between px-6 h-16 bg-slate-950/60 backdrop-blur-xl no-border bg-slate-900/40">
<div class="flex items-center gap-4">
<button class="text-slate-400 hover:text-[#46f4cb] transition-colors scale-95 active:opacity-80 transition-transform">
<span class="material-symbols-outlined">arrow_back</span>
</button>
<h1 class="font-['Manrope'] font-black tracking-[0.2em] text-[#F5F7FA]">PULSE</h1>
</div>
<div class="flex items-center gap-6">
<span class="material-symbols-outlined text-[#00D7B0]">search</span>
<span class="material-symbols-outlined text-[#00D7B0]">settings</span>
</div>
</header>
<main class="pt-24 px-6 max-w-2xl mx-auto">
<!-- Editorial Header -->
<div class="mb-10">
<p class="font-label text-[0.6875rem] uppercase tracking-widest text-on-surface-variant mb-2">Social / Challenge Mode</p>
<h2 class="font-headline font-bold text-4xl tracking-tight text-primary">Ghost Sprint</h2>
<p class="text-on-surface-variant mt-2 text-sm max-w-sm">Synchronize with a temporal benchmark. Outrun the shadow to set a new standard.</p>
</div>
<!-- Configuration Bento Grid -->
<div class="grid grid-cols-1 gap-6">
<!-- Benchmark Selection Section -->
<section>
<div class="flex justify-between items-end mb-4 px-1">
<h3 class="font-headline font-bold text-lg text-on-surface">Select Benchmark</h3>
<span class="font-label text-[0.6875rem] text-secondary tracking-wider uppercase">3 sources available</span>
</div>
<div class="space-y-3">
<!-- Personal Best -->
<div class="group relative flex items-center p-4 bg-surface-container rounded-lg cursor-pointer border-l-4 border-primary shadow-lg transition-all hover:bg-surface-container-high">
<div class="mr-4 text-primary bg-primary/10 p-3 rounded-md">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">workspace_premium</span>
</div>
<div class="flex-grow">
<h4 class="font-headline font-bold text-on-surface">Personal Best</h4>
<p class="font-label text-xs text-on-surface-variant">Central Park Loop • 18:42</p>
</div>
<div class="text-right">
<span class="block font-headline font-extrabold text-lg text-primary data-glow">4'15"</span>
<span class="block font-label text-[10px] text-on-surface-variant uppercase">Target Pace</span>
</div>
</div>
<!-- Friend's Session -->
<div class="group relative flex items-center p-4 bg-surface-container-low rounded-lg cursor-pointer transition-all hover:bg-surface-container">
<div class="mr-4 text-secondary bg-secondary/10 p-3 rounded-md">
<span class="material-symbols-outlined">group</span>
</div>
<div class="flex-grow">
<h4 class="font-headline font-bold text-on-surface">Alex Rivera's Ghost</h4>
<p class="font-label text-xs text-on-surface-variant">Last Weekend • 19:15</p>
</div>
<div class="text-right">
<span class="block font-headline font-extrabold text-lg text-on-surface">4'22"</span>
<span class="block font-label text-[10px] text-on-surface-variant uppercase">Target Pace</span>
</div>
</div>
<!-- Target Pace -->
<div class="group relative flex items-center p-4 bg-surface-container-low rounded-lg cursor-pointer transition-all hover:bg-surface-container">
<div class="mr-4 text-tertiary bg-tertiary/10 p-3 rounded-md">
<span class="material-symbols-outlined">speed</span>
</div>
<div class="flex-grow">
<h4 class="font-headline font-bold text-on-surface">Custom Target</h4>
<p class="font-label text-xs text-on-surface-variant">Manual Input Required</p>
</div>
<div class="text-right flex items-center gap-2">
<span class="material-symbols-outlined text-on-surface-variant text-sm">edit</span>
</div>
</div>
</div>
</section>
<!-- HUD Config Section -->
<section class="mt-4">
<div class="flex justify-between items-end mb-4 px-1">
<h3 class="font-headline font-bold text-lg text-on-surface">HUD Configuration</h3>
<span class="font-label text-[0.6875rem] text-on-surface-variant tracking-wider uppercase">Active Telemetry</span>
</div>
<div class="bg-surface-container-low rounded-xl p-6 border-2 border-outline-variant/10">
<div class="grid grid-cols-3 gap-4">
<!-- Pace Toggle -->
<div class="flex flex-col items-center p-3 bg-surface-container rounded-lg border-b-2 border-primary">
<span class="material-symbols-outlined text-primary mb-2">pace</span>
<span class="font-label text-[10px] text-on-surface font-semibold uppercase tracking-tighter">Pace</span>
<div class="mt-2 w-8 h-4 bg-primary rounded-full relative">
<div class="absolute right-0.5 top-0.5 w-3 h-3 bg-on-primary rounded-full"></div>
</div>
</div>
<!-- Gap Toggle -->
<div class="flex flex-col items-center p-3 bg-surface-container rounded-lg border-b-2 border-primary">
<span class="material-symbols-outlined text-primary mb-2">history</span>
<span class="font-label text-[10px] text-on-surface font-semibold uppercase tracking-tighter">Gap (m)</span>
<div class="mt-2 w-8 h-4 bg-primary rounded-full relative">
<div class="absolute right-0.5 top-0.5 w-3 h-3 bg-on-primary rounded-full"></div>
</div>
</div>
<!-- Distance Toggle -->
<div class="flex flex-col items-center p-3 bg-surface-container rounded-lg opacity-60">
<span class="material-symbols-outlined text-on-surface-variant mb-2">straighten</span>
<span class="font-label text-[10px] text-on-surface-variant font-semibold uppercase tracking-tighter">Distance</span>
<div class="mt-2 w-8 h-4 bg-surface-container-highest rounded-full relative">
<div class="absolute left-0.5 top-0.5 w-3 h-3 bg-outline rounded-full"></div>
</div>
</div>
</div>
<div class="mt-6 flex items-center justify-between p-3 bg-surface-container-lowest rounded border border-outline-variant/20">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-secondary text-sm">notifications_active</span>
<span class="text-xs text-on-surface-variant">Audio Pacer Alerts</span>
</div>
<div class="w-10 h-5 bg-secondary/20 rounded-full relative border border-secondary/30">
<div class="absolute right-1 top-1 w-3 h-3 bg-secondary rounded-full"></div>
</div>
</div>
</div>
</section>
<!-- Visual Context -->
<div class="relative w-full h-40 rounded-xl overflow-hidden mt-2 group">
<div class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-transparent z-10"></div>
<img alt="Athletic runner in silhouette" class="w-full h-full object-cover grayscale opacity-40 transition-transform duration-700 group-hover:scale-110" data-alt="dramatic cinematic shot of a runner silhouette against a dark foggy city street at night with neon lights reflecting on wet asphalt" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDvakwz684F4PlKm6inSriK56Vi2WCJzZbAZMmDAsbP64G7nIgIqBsGkV-v0iN6HAg_hoKtQB10p6OrBCeAuVdJC6S0Jp883do4NnZqhMSRqFFiJqhxOSBoN44Vf-uDix5yTc_x2Th2S3nXLLNQN5fsW068taRwrp72oN6rJ25XiTqR6vYLYQVYGvw1bGIt_p-7XEI27tNN4JhDwtiRc4Y7gmjKjTGPGMnC8qMuiQz9_LBxs9thxBOlQGx57rOXvgAt7KMABn1NaA0"/>
<div class="absolute bottom-4 left-4 z-20">
<span class="font-label text-[10px] text-primary uppercase tracking-widest bg-primary/10 px-2 py-1 rounded">Live Map View</span>
<h4 class="font-headline font-bold text-on-surface text-sm mt-1">Central Park South Corridor</h4>
</div>
</div>
<!-- Primary Action -->
<div class="mt-4 pb-12">
<button class="liquid-metal-gradient w-full py-4 rounded-md shadow-[0_0_20px_rgba(70,244,203,0.3)] hover:shadow-[0_0_30px_rgba(70,244,203,0.5)] transition-all flex items-center justify-center gap-3">
<span class="material-symbols-outlined text-on-primary" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
<span class="font-headline font-bold text-on-primary tracking-wide text-lg uppercase">Start Ghost Challenge</span>
</button>
<p class="text-center text-[10px] text-on-surface-variant mt-4 uppercase tracking-[0.2em]">Hardware Lock: GPS / Bio-Link Active</p>
</div>
</div>
</main>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 py-3 pb-safe bg-slate-950/60 backdrop-blur-xl no-border bg-slate-900/40">
<div class="flex flex-col items-center justify-center text-slate-500 hover:text-slate-200 transition-all Active: scale-90 duration-200">
<span class="material-symbols-outlined" data-icon="home">home</span>
<span class="font-['Inter'] text-[10px] font-medium tracking-wider uppercase">Home</span>
</div>
<div class="flex flex-col items-center justify-center text-slate-500 hover:text-slate-200 transition-all Active: scale-90 duration-200">
<span class="material-symbols-outlined" data-icon="fitness_center">fitness_center</span>
<span class="font-['Inter'] text-[10px] font-medium tracking-wider uppercase">Workout</span>
</div>
<div class="flex flex-col items-center justify-center text-slate-500 hover:text-slate-200 transition-all Active: scale-90 duration-200">
<span class="material-symbols-outlined" data-icon="insights">insights</span>
<span class="font-['Inter'] text-[10px] font-medium tracking-wider uppercase">Progress</span>
</div>
<!-- Active Tab: Social (Current Page Context) -->
<div class="flex flex-col items-center justify-center text-[#46f4cb] font-bold Active: scale-90 duration-200">
<span class="material-symbols-outlined" data-icon="group" style="font-variation-settings: 'FILL' 1;">group</span>
<span class="font-['Inter'] text-[10px] font-medium tracking-wider uppercase">Social</span>
</div>
<div class="flex flex-col items-center justify-center text-slate-500 hover:text-slate-200 transition-all Active: scale-90 duration-200">
<span class="material-symbols-outlined" data-icon="person">person</span>
<span class="font-['Inter'] text-[10px] font-medium tracking-wider uppercase">Profile</span>
</div>
</nav>
</body></html>