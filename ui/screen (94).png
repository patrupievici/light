<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>ZVELT | Privacy Settings</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "tertiary-fixed-dim": "#42d7f8",
                    "outline": "#84948e",
                    "on-secondary-container": "#e0e8ff",
                    "surface-container-lowest": "#0d0e11",
                    "secondary-container": "#0264d4",
                    "on-surface-variant": "#bacac3",
                    "error": "#ffb4ab",
                    "surface-dim": "#121316",
                    "primary-fixed-dim": "#21dfb8",
                    "on-primary-fixed-variant": "#005141",
                    "on-background": "#e3e2e6",
                    "surface-tint": "#21dfb8",
                    "primary-container": "#00d7b0",
                    "on-surface": "#e3e2e6",
                    "on-primary-container": "#005847",
                    "surface-container-highest": "#343538",
                    "on-tertiary-fixed-variant": "#004e5c",
                    "on-tertiary-fixed": "#001f26",
                    "surface-container-low": "#1b1b1f",
                    "on-error-container": "#ffdad6",
                    "inverse-on-surface": "#2f3034",
                    "primary-fixed": "#52fcd3",
                    "primary": "#46f4cb",
                    "tertiary-container": "#35cfef",
                    "error-container": "#93000a",
                    "on-tertiary": "#003640",
                    "surface-container-high": "#292a2d",
                    "on-secondary-fixed-variant": "#004494",
                    "on-secondary": "#002e69",
                    "on-primary-fixed": "#002019",
                    "secondary-fixed": "#d8e2ff",
                    "background": "#121316",
                    "secondary": "#adc6ff",
                    "secondary-fixed-dim": "#adc6ff",
                    "outline-variant": "#3b4a44",
                    "on-secondary-fixed": "#001a41",
                    "inverse-primary": "#006b57",
                    "on-error": "#690005",
                    "tertiary": "#8ee7ff",
                    "surface-container": "#1f1f23",
                    "surface-bright": "#38393c",
                    "on-tertiary-container": "#005564",
                    "surface-variant": "#343538",
                    "surface": "#121316",
                    "tertiary-fixed": "#acedff",
                    "on-primary": "#00382c",
                    "inverse-surface": "#e3e2e6"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "fontFamily": {
                    "headline": ["Manrope"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .liquid-metal {
            background: linear-gradient(135deg, #46f4cb 0%, #00d7b0 100%);
        }
        .glass-nav {
            background: rgba(18, 19, 22, 0.6);
            backdrop-filter: blur(20px);
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-surface-dim text-on-surface font-body selection:bg-primary/30">
<!-- TopAppBar -->
<nav class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-zinc-950/60 backdrop-blur-xl">
<div class="flex items-center gap-4">
<button class="text-[#00D7B0] hover:bg-white/5 p-2 rounded-full transition-all active:scale-95">
<span class="material-symbols-outlined" data-icon="arrow_back">arrow_back</span>
</button>
<h1 class="text-xl font-bold tracking-tighter text-[#00D7B0] font-headline">ZVELT</h1>
</div>
<div class="flex items-center gap-4">
<div class="w-8 h-8 rounded-full bg-surface-container-high border border-outline-variant/30 overflow-hidden">
<img alt="User avatar" class="w-full h-full object-cover" data-alt="close-up portrait of a professional athlete with focused expression, high-contrast studio lighting with cool blue tones" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDu6-txPquVVuGLllxhwoLZjakduhkHFXyTbVy1AilIA_aNqmtsF5-FQQzErTw2R5z_MsjipXJnQh9wSpELwda-A2jDfQ3WZjAA95UCWjQiLGxYBsOOj456l98WA1XM6yGdIaUzwrDilMEiELobuJSVP8abt38LEoWvRN-9W9q8pcuLYaUV7ZYL2UTgCX4xP7pNQomNUj3ss3wUm_dhbBf9lg-Xt2P7vYitrd_57dx8TsUrOM9nVKyCZAQd3Y0KlUa4eDmdXF-L4GA"/>
</div>
</div>
</nav>
<main class="pt-24 pb-32 px-6 max-w-2xl mx-auto">
<!-- Header Section -->
<header class="mb-10">
<div class="inline-flex items-center gap-2 mb-2">
<span class="h-[2px] w-8 bg-primary-container"></span>
<span class="text-xs font-label tracking-[0.05em] text-on-surface-variant uppercase">Security &amp; Trust</span>
</div>
<h2 class="text-4xl font-headline font-extrabold tracking-tight text-on-surface mb-3">Privacy Controls</h2>
<p class="text-on-surface-variant leading-relaxed">Manage how your performance data and profile are shared within the ZVELT ecosystem. Your data, your rules.</p>
</header>
<!-- Privacy Sections - Asymmetric Bento Layout -->
<div class="grid grid-cols-1 gap-4">
<!-- Global Visibility Card -->
<section class="p-6 rounded-xl bg-surface-container-low border-l-4 border-primary">
<div class="flex justify-between items-start mb-6">
<div>
<h3 class="text-lg font-headline font-bold text-on-surface">Profile Visibility</h3>
<p class="text-sm text-on-surface-variant mt-1">Control who can see your biometrics and achievements.</p>
</div>
<span class="material-symbols-outlined text-primary-fixed" data-icon="visibility">visibility</span>
</div>
<div class="space-y-4">
<label class="flex items-center justify-between p-4 rounded-lg bg-surface-container cursor-pointer hover:bg-surface-container-high transition-colors">
<div class="flex flex-col">
<span class="font-medium text-on-surface">Public</span>
<span class="text-xs text-on-surface-variant">Visible to all ZVELT users and leaderboards</span>
</div>
<input class="form-radio text-primary bg-surface-container-lowest border-outline-variant focus:ring-primary" name="visibility" type="radio"/>
</label>
<label class="flex items-center justify-between p-4 rounded-lg bg-surface-container-high border border-primary/30 cursor-pointer">
<div class="flex flex-col">
<span class="font-medium text-primary">Followers Only</span>
<span class="text-xs text-on-surface-variant">Only approved followers can see detailed stats</span>
</div>
<input checked="" class="form-radio text-primary bg-surface-container-lowest border-outline-variant focus:ring-primary" name="visibility" type="radio"/>
</label>
<label class="flex items-center justify-between p-4 rounded-lg bg-surface-container cursor-pointer hover:bg-surface-container-high transition-colors">
<div class="flex flex-col">
<span class="font-medium text-on-surface">Private (Ghost Mode)</span>
<span class="text-xs text-on-surface-variant">Only you can see your activity history</span>
</div>
<input class="form-radio text-primary bg-surface-container-lowest border-outline-variant focus:ring-primary" name="visibility" type="radio"/>
</label>
</div>
</section>
<!-- Ghost Challenge Privacy -->
<section class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div class="p-6 rounded-xl bg-surface-container-low">
<span class="material-symbols-outlined text-tertiary mb-4" data-icon="ghost_curve">line_curve</span>
<h3 class="text-base font-headline font-bold text-on-surface">Ghost Participation</h3>
<p class="text-xs text-on-surface-variant mt-2 mb-6">Allow your past performances to be used as 'Ghosts' for others to race against.</p>
<button class="relative inline-flex h-6 w-11 items-center rounded-full bg-primary/20">
<span class="translate-x-6 inline-block h-4 w-4 transform rounded-full bg-primary transition"></span>
</button>
</div>
<div class="p-6 rounded-xl bg-surface-container-low">
<span class="material-symbols-outlined text-secondary mb-4" data-icon="share">share</span>
<h3 class="text-base font-headline font-bold text-on-surface">Auto-Share</h3>
<p class="text-xs text-on-surface-variant mt-2 mb-6">Automatically post peak performance milestones to your connected social circles.</p>
<button class="relative inline-flex h-6 w-11 items-center rounded-full bg-surface-container-highest">
<span class="translate-x-1 inline-block h-4 w-4 transform rounded-full bg-outline-variant transition"></span>
</button>
</div>
</section>
<!-- Location Privacy Card -->
<section class="p-6 rounded-xl bg-surface-container-low">
<div class="flex items-center gap-3 mb-6">
<div class="p-2 rounded-lg bg-error-container/20">
<span class="material-symbols-outlined text-error" data-icon="location_off">location_off</span>
</div>
<div>
<h3 class="text-lg font-headline font-bold text-on-surface">Map Privacy Zones</h3>
<p class="text-sm text-on-surface-variant">Hide your home or office address in shared maps.</p>
</div>
</div>
<div class="space-y-3">
<div class="flex items-center justify-between p-4 bg-surface-container rounded-lg border border-outline-variant/10">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-lg bg-surface-container-high flex items-center justify-center">
<span class="material-symbols-outlined text-on-surface-variant" data-icon="home">home</span>
</div>
<div>
<p class="text-sm font-medium">Home Zone</p>
<p class="text-xs text-on-surface-variant">200m radius hidden</p>
</div>
</div>
<button class="text-on-surface-variant hover:text-primary transition-colors">
<span class="material-symbols-outlined" data-icon="edit">edit</span>
</button>
</div>
<button class="w-full py-4 border-2 border-dashed border-outline-variant/30 rounded-lg text-sm font-medium text-on-surface-variant hover:border-primary/50 hover:text-primary transition-all flex items-center justify-center gap-2">
<span class="material-symbols-outlined text-sm" data-icon="add">add</span>
                        Create New Privacy Zone
                    </button>
</div>
</section>
<!-- Data Export & Security -->
<section class="p-6 rounded-xl bg-surface-container-low overflow-hidden relative">
<!-- Background decorative element -->
<div class="absolute -right-4 -bottom-4 w-32 h-32 bg-primary/5 rounded-full blur-3xl"></div>
<h3 class="text-lg font-headline font-bold text-on-surface mb-4">Account Integrity</h3>
<div class="divide-y divide-outline-variant/10">
<div class="py-4 flex items-center justify-between group cursor-pointer">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors" data-icon="download">download</span>
<span class="text-sm font-medium">Export Personal Biometrics</span>
</div>
<span class="material-symbols-outlined text-on-surface-variant text-sm" data-icon="chevron_right">chevron_right</span>
</div>
<div class="py-4 flex items-center justify-between group cursor-pointer">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors" data-icon="history">history</span>
<span class="text-sm font-medium">Privacy Audit Log</span>
</div>
<span class="material-symbols-outlined text-on-surface-variant text-sm" data-icon="chevron_right">chevron_right</span>
</div>
<div class="py-4 flex items-center justify-between group cursor-pointer">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-error/70 group-hover:text-error transition-colors" data-icon="delete_forever">delete_forever</span>
<span class="text-sm font-medium text-error/70 group-hover:text-error transition-colors">Terminate Account &amp; Purge Data</span>
</div>
<span class="material-symbols-outlined text-error/70 text-sm" data-icon="chevron_right">chevron_right</span>
</div>
</div>
</section>
</div>
<!-- Trust Badge -->
<div class="mt-12 flex flex-col items-center justify-center text-center">
<div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-4">
<span class="material-symbols-outlined text-primary" data-icon="lock" style="font-variation-settings: 'FILL' 1;">lock</span>
</div>
<p class="text-xs font-label text-on-surface-variant uppercase tracking-widest">End-to-End Encryption Enabled</p>
<p class="text-[10px] text-on-surface-variant/60 mt-1 max-w-[280px]">ZVELT uses biometric-grade encryption for all activity and health data processing.</p>
</div>
</main>
<!-- BottomNavBar (Hidden on desktop, shown on mobile) -->
<nav class="md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-zinc-950/60 backdrop-blur-xl rounded-t-xl shadow-[0px_12px_32px_rgba(0,0,0,0.4)]">
<a class="flex flex-col items-center justify-center text-zinc-500 opacity-70 hover:bg-zinc-800/50 transition-all duration-300 rounded-xl px-4 py-1.5" href="#">
<span class="material-symbols-outlined" data-icon="speed">speed</span>
<span class="text-[10px] font-label mt-1 tracking-wider uppercase">Dashboard</span>
</a>
<a class="flex flex-col items-center justify-center text-zinc-500 opacity-70 hover:bg-zinc-800/50 transition-all duration-300 rounded-xl px-4 py-1.5" href="#">
<span class="material-symbols-outlined" data-icon="monitoring">monitoring</span>
<span class="text-[10px] font-label mt-1 tracking-wider uppercase">Activity</span>
</a>
<a class="flex flex-col items-center justify-center text-zinc-500 opacity-70 hover:bg-zinc-800/50 transition-all duration-300 rounded-xl px-4 py-1.5" href="#">
<span class="material-symbols-outlined" data-icon="workspace_premium">workspace_premium</span>
<span class="text-[10px] font-label mt-1 tracking-wider uppercase">Premium</span>
</a>
<a class="flex flex-col items-center justify-center text-[#46f4cb] bg-zinc-900/80 rounded-xl px-4 py-1.5 transition-all" href="#">
<span class="material-symbols-outlined" data-icon="person" style="font-variation-settings: 'FILL' 1;">person</span>
<span class="text-[10px] font-label mt-1 tracking-wider uppercase">Profile</span>
</a>
</nav>
</body></html>