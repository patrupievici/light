<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Manrope:wght@700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "surface": "#121316",
                    "surface-bright": "#38393c",
                    "error-container": "#93000a",
                    "error": "#ffb4ab",
                    "secondary": "#adc6ff",
                    "on-surface": "#e3e2e6",
                    "on-tertiary-fixed": "#001f26",
                    "tertiary-container": "#35cfef",
                    "on-primary-fixed": "#002019",
                    "on-secondary-fixed": "#001a41",
                    "surface-container-low": "#1b1b1f",
                    "on-tertiary": "#003640",
                    "inverse-surface": "#e3e2e6",
                    "tertiary-fixed": "#acedff",
                    "surface-container": "#1f1f23",
                    "inverse-on-surface": "#2f3034",
                    "secondary-fixed": "#d8e2ff",
                    "background": "#121316",
                    "on-surface-variant": "#bacac3",
                    "primary-fixed": "#52fcd3",
                    "surface-variant": "#343538",
                    "outline-variant": "#3b4a44",
                    "on-primary-fixed-variant": "#005141",
                    "on-primary": "#00382c",
                    "primary-container": "#00d7b0",
                    "on-error-container": "#ffdad6",
                    "surface-tint": "#21dfb8",
                    "on-background": "#e3e2e6",
                    "primary": "#46f4cb",
                    "on-tertiary-container": "#005564",
                    "tertiary": "#8ee7ff",
                    "surface-container-lowest": "#0d0e11",
                    "primary-fixed-dim": "#21dfb8",
                    "secondary-container": "#0264d4",
                    "surface-container-high": "#292a2d",
                    "on-primary-container": "#005847",
                    "outline": "#84948e",
                    "secondary-fixed-dim": "#adc6ff",
                    "inverse-primary": "#006b57",
                    "on-error": "#690005",
                    "surface-container-highest": "#343538",
                    "on-secondary-container": "#e0e8ff",
                    "on-secondary": "#002e69",
                    "tertiary-fixed-dim": "#42d7f8",
                    "surface-dim": "#121316",
                    "on-secondary-fixed-variant": "#004494",
                    "on-tertiary-fixed-variant": "#004e5c"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "fontFamily": {
                    "headline": ["Manrope"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        },
      }
    </script>
<style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      .glass-card {
        background: rgba(31, 31, 35, 0.6);
        backdrop-filter: blur(12px);
      }
      .liquid-metal {
        background: linear-gradient(135deg, #46f4cb 0%, #00d7b0 100%);
      }
      .glow-primary {
        box-shadow: 0 0 15px rgba(70, 244, 203, 0.2);
      }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-surface text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 bg-[#121316]/80 backdrop-blur-lg dark:bg-[#121316]/80 flex justify-between items-center px-6 py-4 w-full">
<div class="flex items-center gap-3">
<img alt="User profile avatar" class="w-10 h-10 rounded-full border-2 border-primary/20" data-alt="Close up professional portrait of a fitness athlete with soft cinematic lighting and dark background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCEHIZ4zcqpFfC6D8h7sWsFI1iWxmEw87MrkJJxzavQ6Q8l7zhABBPfQLOHrXmjEZr-JmmKsXD7mBVKxE00gbXyV3mmlkf-U3tJy8dG8C1lThcIheUd_3d2SffGO9ICIpSq84F7ZMS3NmB1T8_sXH_6iZm4Ll62l3t5iLApmoy3wxl33wbAI6KQqWgcMct4wb24NARRlswCLqUUZcpwqmK8aMtiOBb4UtRmoSYHqqFLNh6We0jhQgFC3iYyeJkQkBF9HNtOsRo3des"/>
<span class="font-manrope font-extrabold tracking-tighter text-[#F5F7FA] text-2xl">ZVELT</span>
</div>
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-[#A7B0BC] hover:text-[#F5F7FA] transition-colors cursor-pointer" data-icon="settings">settings</span>
</div>
<div class="bg-[#1b1b1f] h-[2px] w-1/3 absolute bottom-0 left-0"></div>
</header>
<main class="pt-24 pb-32 px-6 max-w-5xl mx-auto">
<!-- Screen Header -->
<div class="mb-10 text-left">
<div class="flex items-center gap-2 mb-2">
<span class="w-2 h-2 rounded-full bg-primary animate-pulse shadow-[0_0_8px_rgba(70,244,203,0.8)]"></span>
<p class="font-label text-xs uppercase tracking-widest text-primary font-semibold">Ghost Protocol</p>
</div>
<h1 class="font-headline text-4xl font-extrabold text-[#F5F7FA] tracking-tight mb-4">GHOST CHALLENGE</h1>
<p class="text-on-surface-variant max-w-md text-sm leading-relaxed">Select a benchmark session to project your ghost data onto a friend's active HUD.</p>
</div>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
<!-- Left Column: Step 1 - Session Selection -->
<div class="lg:col-span-7 space-y-8">
<section>
<div class="flex justify-between items-end mb-4 px-1">
<h2 class="font-headline text-lg font-bold text-[#F5F7FA]">1. SELECT BENCHMARK</h2>
<span class="font-label text-[10px] text-on-surface-variant uppercase tracking-widest">History: Last 30 Days</span>
</div>
<div class="space-y-3">
<!-- Session Card 1 (Active) -->
<div class="relative p-5 rounded-xl bg-surface-container-high border-l-4 border-primary group cursor-pointer transition-all">
<div class="flex justify-between items-start mb-4">
<div>
<h3 class="font-headline text-base font-bold text-primary">VO2 MAX THRESHOLD</h3>
<p class="font-label text-xs text-on-surface-variant">May 24, 2024 • 06:15 AM</p>
</div>
<span class="material-symbols-outlined text-primary" data-icon="check_circle" style="font-variation-settings: 'FILL' 1;">check_circle</span>
</div>
<div class="grid grid-cols-3 gap-4">
<div>
<p class="font-label text-[10px] uppercase text-on-surface-variant tracking-wider">Pace</p>
<p class="font-headline text-xl font-bold text-[#F5F7FA]">4:12<span class="text-xs font-medium ml-1">/km</span></p>
</div>
<div>
<p class="font-label text-[10px] uppercase text-on-surface-variant tracking-wider">Avg HR</p>
<p class="font-headline text-xl font-bold text-[#F5F7FA]">168<span class="text-xs font-medium ml-1">bpm</span></p>
</div>
<div>
<p class="font-label text-[10px] uppercase text-on-surface-variant tracking-wider">Gap</p>
<p class="font-headline text-xl font-bold text-[#F5F7FA]">+2.4<span class="text-xs font-medium ml-1">%</span></p>
</div>
</div>
</div>
<!-- Session Card 2 -->
<div class="p-5 rounded-xl bg-surface-container-low hover:bg-surface-container transition-colors group cursor-pointer">
<div class="flex justify-between items-start mb-4">
<div>
<h3 class="font-headline text-base font-bold text-[#F5F7FA] group-hover:text-primary transition-colors">ENDURANCE L4</h3>
<p class="font-label text-xs text-on-surface-variant">May 22, 2024 • 05:30 PM</p>
</div>
<span class="material-symbols-outlined text-on-surface-variant opacity-40" data-icon="circle">circle</span>
</div>
<div class="grid grid-cols-3 gap-4">
<div>
<p class="font-label text-[10px] uppercase text-on-surface-variant tracking-wider">Pace</p>
<p class="font-headline text-xl font-bold text-[#F5F7FA]/80">5:05<span class="text-xs font-medium ml-1">/km</span></p>
</div>
<div>
<p class="font-label text-[10px] uppercase text-on-surface-variant tracking-wider">Avg HR</p>
<p class="font-headline text-xl font-bold text-[#F5F7FA]/80">142<span class="text-xs font-medium ml-1">bpm</span></p>
</div>
<div>
<p class="font-label text-[10px] uppercase text-on-surface-variant tracking-wider">Gap</p>
<p class="font-headline text-xl font-bold text-[#F5F7FA]/80">-1.2<span class="text-xs font-medium ml-1">%</span></p>
</div>
</div>
</div>
</div>
</section>
<!-- Step 2 - Friend Selection -->
<section>
<div class="flex justify-between items-end mb-4 px-1">
<h2 class="font-headline text-lg font-bold text-[#F5F7FA]">2. TARGET FRIEND</h2>
<span class="font-label text-[10px] text-on-surface-variant uppercase tracking-widest">Active Now</span>
</div>
<div class="flex gap-4 overflow-x-auto pb-4 scrollbar-hide">
<!-- Friend Circle 1 (Selected) -->
<div class="flex-shrink-0 flex flex-col items-center gap-3">
<div class="relative">
<div class="w-16 h-16 rounded-full p-0.5 ring-2 ring-primary">
<img alt="Friend profile avatar" class="w-full h-full rounded-full object-cover grayscale-0" data-alt="Portrait of a male runner looking intense, high contrast lighting, urban gym aesthetic" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBb110pCGMT7zidqQ8_xE6Fhk8r61fjVoov1qNyiWUbi69lU1I25nezufEDGNxsQuUWtzoVJF0vgTIbQLwDHKUo0u6KWmxH3Pm1JXYSFEVFCuMRFs1kA6iDhGeSXl8JdvuGUJscNqjIiPhHZ4L5_OMqeRRxIto1cLtwLo6rcaGnkzvsGf8iQVoAZnT4pjGUMmJ23df2PIWeJ3XNBnmhiisU3LNedeO67B9NT_bpZkKFXDU9q_tu-AHLXSCGVz-dtixnbZVQJeyiASE"/>
</div>
<div class="absolute -bottom-1 -right-1 bg-primary text-on-primary rounded-full p-1 border-2 border-surface">
<span class="material-symbols-outlined text-[12px] block" data-icon="bolt" style="font-variation-settings: 'FILL' 1;">bolt</span>
</div>
</div>
<span class="font-label text-xs font-semibold text-primary">MARCUS.V</span>
</div>
<!-- Friend Circle 2 -->
<div class="flex-shrink-0 flex flex-col items-center gap-3 opacity-60 hover:opacity-100 transition-opacity cursor-pointer">
<div class="w-16 h-16 rounded-full p-0.5">
<img alt="Friend profile avatar" class="w-full h-full rounded-full object-cover grayscale" data-alt="Close up of a female athlete with athletic gear, focused expression, neutral gray background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCCr4AN3KNh9qYU75tF4u-8o5ehrx5gbC8wv_oOu7-fOXNNA3io-ns--QXxa_yrI8Tj0CQDcNkGEFXwdpkLm3bOLqZo_A59u95sDM8kyuVAJ0WAw4mUy4ymqK1bxS5fHLJAtQemAznVsacOS2at6FepWsNHBPVK8mZTvEM_0U8nbTQ66HORLIyCjarumRihcy7aZrgXyqvFDf42i2GZ0TJiN5eJ8uPMDF0SCnltczNA0eaYpkyAoXGEAuXsFlUPKAdE0LGS85E3-Ms"/>
</div>
<span class="font-label text-xs font-semibold text-on-surface-variant">ELENA_K</span>
</div>
<!-- Friend Circle 3 -->
<div class="flex-shrink-0 flex flex-col items-center gap-3 opacity-60 hover:opacity-100 transition-opacity cursor-pointer">
<div class="w-16 h-16 rounded-full p-0.5">
<img alt="Friend profile avatar" class="w-full h-full rounded-full object-cover grayscale" data-alt="Sharp portrait of a man in fitness apparel, soft studio lighting, high end aesthetic" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCsFaoU9nbYhkZHWxE3in5Te9c0FZfeo7cp43gRImcwfhXX42TqS2mC1Z0giDblEWF_yRPxg4yVQs5NRcB8e0U47RepV64Rgp5Ogbhala_jx_67H-tHljnnuK8R333b5Fk3gZ4qhArxrjKnMtvc_VP5DkCYL_M9iivMBAWt2p-W3MY8iS0mr70tYMrEE_tRSYeIFieTwsBAdt5qrYuM9W4rBuxO7Cr1LXE2dbr63TpHvB3G0XoXC0wT-K4iDEz8O4NR2hf3sGS9NLs"/>
</div>
<span class="font-label text-xs font-semibold text-on-surface-variant">DAVID.UX</span>
</div>
</div>
</section>
</div>
<!-- Right Column: Ghost Comparison Details -->
<div class="lg:col-span-5">
<div class="glass-card rounded-xl overflow-hidden border border-outline-variant/20 sticky top-24">
<div class="bg-surface-container-highest px-6 py-4 flex items-center justify-between">
<span class="font-label text-[10px] uppercase font-bold tracking-widest text-[#F5F7FA]">PRE-FLIGHT ANALYTICS</span>
<span class="material-symbols-outlined text-primary text-sm" data-icon="query_stats">query_stats</span>
</div>
<div class="p-6 space-y-6">
<!-- Data Visualization Simulation -->
<div class="h-32 w-full flex items-end gap-[2px] mb-2">
<div class="w-full h-1/2 bg-outline-variant/20 rounded-t-sm"></div>
<div class="w-full h-2/3 bg-outline-variant/20 rounded-t-sm"></div>
<div class="w-full h-3/4 bg-primary/40 rounded-t-sm"></div>
<div class="w-full h-1/2 bg-outline-variant/20 rounded-t-sm"></div>
<div class="w-full h-4/5 bg-primary rounded-t-sm shadow-[0_0_10px_rgba(70,244,203,0.3)]"></div>
<div class="w-full h-2/3 bg-outline-variant/20 rounded-t-sm"></div>
<div class="w-full h-1/3 bg-outline-variant/20 rounded-t-sm"></div>
<div class="w-full h-1/2 bg-primary/60 rounded-t-sm"></div>
<div class="w-full h-3/4 bg-primary rounded-t-sm shadow-[0_0_10px_rgba(70,244,203,0.3)]"></div>
<div class="w-full h-1/2 bg-outline-variant/20 rounded-t-sm"></div>
</div>
<div class="space-y-4">
<div class="flex justify-between items-center py-2 border-b border-outline-variant/10">
<span class="font-label text-xs text-on-surface-variant">Projected Difficulty</span>
<span class="font-headline text-sm font-bold text-primary">ELITE (8.4/10)</span>
</div>
<div class="flex justify-between items-center py-2 border-b border-outline-variant/10">
<span class="font-label text-xs text-on-surface-variant">Head-to-Head Ratio</span>
<span class="font-headline text-sm font-bold text-[#F5F7FA]">54% WIN RATE</span>
</div>
<div class="flex justify-between items-center py-2 border-b border-outline-variant/10">
<span class="font-label text-xs text-on-surface-variant">Ghost Syncing Latency</span>
<span class="font-headline text-sm font-bold text-[#F5F7FA]">14ms</span>
</div>
</div>
<!-- Comparison Module -->
<div class="bg-surface-container-low rounded-lg p-4 flex flex-col gap-4">
<div class="flex justify-between items-center">
<div class="flex items-center gap-2">
<div class="w-2 h-2 rounded-full bg-[#F5F7FA]"></div>
<span class="font-label text-[10px] text-on-surface-variant uppercase tracking-wider">You (Ghost)</span>
</div>
<span class="font-headline text-xs font-bold text-[#F5F7FA]">18.4 km/h</span>
</div>
<div class="w-full h-1 bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-[#F5F7FA] w-[85%]"></div>
</div>
<div class="flex justify-between items-center">
<div class="flex items-center gap-2">
<div class="w-2 h-2 rounded-full bg-primary"></div>
<span class="font-label text-[10px] text-primary uppercase tracking-wider">Marcus.V (Live)</span>
</div>
<span class="font-headline text-xs font-bold text-primary">17.2 km/h</span>
</div>
<div class="w-full h-1 bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-primary w-[78%]"></div>
</div>
</div>
<!-- CTA Button -->
<button class="liquid-metal w-full py-4 rounded-xl font-headline font-bold text-on-primary-fixed uppercase tracking-widest glow-primary active:scale-[0.98] transition-all flex items-center justify-center gap-2">
<span>DEPLOY GHOST</span>
<span class="material-symbols-outlined" data-icon="send">send</span>
</button>
</div>
</div>
</div>
</div>
</main>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full z-50 bg-[#1b1b1f]/90 backdrop-blur-2xl dark:bg-[#1b1b1f]/90 flex justify-around items-center px-4 pb-6 pt-3 shadow-[0px_12px_32px_rgba(0,0,0,0.4)] rounded-t-xl">
<div class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out cursor-pointer">
<span class="material-symbols-outlined" data-icon="home">home</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium">Home</span>
</div>
<div class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out cursor-pointer">
<span class="material-symbols-outlined" data-icon="exercise">exercise</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium">Workout</span>
</div>
<div class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out cursor-pointer">
<span class="material-symbols-outlined" data-icon="monitoring">monitoring</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium">Progress</span>
</div>
<div class="flex flex-col items-center justify-center text-[#46f4cb] bg-[#292a2d] rounded-lg px-3 py-1 transition-all duration-300 ease-out cursor-pointer">
<span class="material-symbols-outlined" data-icon="group">group</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium">Social</span>
</div>
<div class="flex flex-col items-center justify-center text-[#A7B0BC] opacity-60 hover:text-[#F5F7FA] transition-all duration-300 ease-out cursor-pointer">
<span class="material-symbols-outlined" data-icon="person">person</span>
<span class="font-manrope text-[10px] uppercase tracking-widest font-medium">Profile</span>
</div>
</nav>
</body></html>