<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@800&amp;family=Inter:wght@300;400;600&amp;family=Space+Grotesk:wght@400;700&amp;family=Space+Mono:wght@400;700&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "secondary-fixed-dim": "#adc6ff",
                    "on-tertiary": "#003640",
                    "on-primary-container": "#005847",
                    "inverse-surface": "#e3e2e6",
                    "background": "#121316",
                    "tertiary-container": "#35cfef",
                    "surface-container-low": "#1b1b1f",
                    "secondary-fixed": "#d8e2ff",
                    "on-secondary-fixed": "#001a41",
                    "on-surface": "#e3e2e6",
                    "surface-container": "#1f1f23",
                    "on-error": "#690005",
                    "tertiary": "#8ee7ff",
                    "surface-container-highest": "#343538",
                    "on-primary-fixed": "#002019",
                    "on-secondary-container": "#e0e8ff",
                    "on-primary-fixed-variant": "#005141",
                    "primary": "#46f4cb",
                    "secondary-container": "#0264d4",
                    "error-container": "#93000a",
                    "tertiary-fixed": "#acedff",
                    "outline-variant": "#3b4a44",
                    "surface-variant": "#343538",
                    "surface-container-lowest": "#0d0e11",
                    "primary-fixed-dim": "#21dfb8",
                    "on-surface-variant": "#bacac3",
                    "surface-dim": "#121316",
                    "surface-bright": "#38393c",
                    "on-tertiary-fixed": "#001f26",
                    "primary-container": "#00d7b0",
                    "on-error-container": "#ffdad6",
                    "on-tertiary-fixed-variant": "#004e5c",
                    "on-background": "#e3e2e6",
                    "secondary": "#adc6ff",
                    "on-secondary": "#002e69",
                    "outline": "#84948e",
                    "inverse-primary": "#006b57",
                    "inverse-on-surface": "#2f3034",
                    "error": "#ffb4ab",
                    "primary-fixed": "#52fcd3",
                    "surface": "#121316",
                    "tertiary-fixed-dim": "#42d7f8",
                    "on-secondary-fixed-variant": "#004494",
                    "on-primary": "#00382c",
                    "surface-tint": "#21dfb8",
                    "on-tertiary-container": "#005564",
                    "surface-container-high": "#292a2d"
            },
            "borderRadius": {
                    "DEFAULT": "1rem",
                    "lg": "2rem",
                    "xl": "3rem",
                    "full": "9999px"
            },
            "fontFamily": {
                    "headline": ["Manrope"],
                    "body": ["Inter"],
                    "label": ["Space Grotesk"],
                    "mono": ["Space Mono"]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .grain-overlay {
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            opacity: 0.03;
            pointer-events: none;
        }
        .asymmetric-gradient {
            background: radial-gradient(circle at 80% 20%, rgba(74, 141, 255, 0.15) 0%, transparent 50%),
                        radial-gradient(circle at 20% 80%, rgba(0, 215, 176, 0.1) 0%, transparent 50%);
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background text-on-background font-body min-h-screen selection:bg-primary selection:text-on-primary overflow-x-hidden">
<div class="fixed inset-0 grain-overlay z-0"></div>
<div class="fixed inset-0 asymmetric-gradient z-0"></div>
<!-- TopAppBar Shell -->
<header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 h-16 bg-[#121316]/80 backdrop-blur-lg border-b border-white/10 shadow-[0_4px_30px_rgba(0,0,0,0.1)]">
<button class="text-[#00D7B0] hover:opacity-80 transition-opacity active:scale-95 transition-transform">
<span class="material-symbols-outlined" data-icon="arrow_back">arrow_back</span>
</button>
<span class="text-2xl font-[800] tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-[#4A8DFF] to-[#00D7B0]">ZVELT</span>
<button class="text-[#00D7B0] hover:opacity-80 transition-opacity active:scale-95 transition-transform">
<span class="material-symbols-outlined" data-icon="settings">settings</span>
</button>
</header>
<main class="relative z-10 pt-24 pb-32 px-6 flex flex-col min-h-screen">
<!-- Hero Section -->
<div class="mb-12">
<p class="font-mono text-primary text-[10px] tracking-[0.3em] uppercase mb-2">Performance Projection</p>
<h1 class="font-headline font-[800] text-4xl md:text-6xl leading-[1.1] tracking-tight max-w-sm">
                Build strength <br/>
<span class="text-transparent bg-clip-text bg-gradient-to-r from-[#4A8DFF] to-[#00D7B0]">that compounds</span>
</h1>
</div>
<!-- Chart Container -->
<div class="relative flex-1 min-h-[400px] flex items-center justify-center">
<!-- Glass Overlay Info -->
<div class="absolute top-0 right-0 z-20">
<div class="backdrop-blur-xl bg-white/5 border border-white/10 rounded-lg p-4 shadow-2xl">
<div class="flex items-center gap-3 mb-3">
<div class="w-3 h-3 rounded-full bg-gradient-to-r from-[#4A8DFF] to-[#00D7B0]"></div>
<span class="font-mono text-[10px] text-white">With ZVELT</span>
</div>
<div class="flex items-center gap-3">
<div class="w-3 h-1 border-t-2 border-dashed border-amber-500"></div>
<span class="font-mono text-[10px] text-slate-400">Without tracking</span>
</div>
</div>
</div>
<!-- SVG Compound Chart -->
<div class="w-full h-full relative">
<svg class="w-full h-full" preserveaspectratio="none" viewbox="0 0 400 300">
<defs>
<lineargradient id="chartGradient" x1="0%" x2="100%" y1="0%" y2="0%">
<stop offset="0%" stop-color="#4A8DFF"></stop>
<stop offset="100%" stop-color="#00D7B0"></stop>
</lineargradient>
<lineargradient id="fillGradient" x1="0%" x2="0%" y1="0%" y2="100%">
<stop offset="0%" stop-color="#00D7B0" stop-opacity="0.2"></stop>
<stop offset="100%" stop-color="#00D7B0" stop-opacity="0"></stop>
</lineargradient>
</defs>
<!-- Grid Lines -->
<g class="stroke-white/5 stroke-[0.5]">
<line x1="0" x2="400" y1="50" y2="50"></line>
<line x1="0" x2="400" y1="100" y2="100"></line>
<line x1="0" x2="400" y1="150" y2="150"></line>
<line x1="0" x2="400" y1="200" y2="200"></line>
<line x1="0" x2="400" y1="250" y2="250"></line>
<line x1="80" x2="80" y1="0" y2="300"></line>
<line x1="160" x2="160" y1="0" y2="300"></line>
<line x1="240" x2="240" y1="0" y2="300"></line>
<line x1="320" x2="320" y1="0" y2="300"></line>
</g>
<!-- Without Tracking (Linear/Stagnant Curve) -->
<path class="opacity-60" d="M0,250 C50,245 150,240 250,235 C320,232 400,230 400,230" fill="none" stroke="#F59E0B" stroke-dasharray="6,4" stroke-width="2"></path>
<!-- With ZVELT (Exponential Curve) -->
<path d="M0,250 C80,240 160,200 240,140 C320,80 380,40 400,20" fill="none" stroke="url(#chartGradient)" stroke-linecap="round" stroke-width="4"></path>
<path d="M0,250 C80,240 160,200 240,140 C320,80 380,40 400,20 L400,300 L0,300 Z" fill="url(#fillGradient)"></path>
<!-- Focal Point -->
<circle class="animate-pulse" cx="280" cy="110" fill="#00D7B0" r="6"></circle>
</svg>
<!-- Floating Label Tag -->
<div class="absolute top-[35%] left-[65%] -translate-x-1/2 -translate-y-1/2">
<div class="bg-primary/20 backdrop-blur-md border border-primary/30 px-3 py-1.5 rounded-full flex items-center gap-2">
<span class="material-symbols-outlined text-primary text-sm" data-icon="bolt" style="font-variation-settings: 'FILL' 1;">bolt</span>
<span class="font-mono text-[10px] font-bold text-primary tracking-tight">+142% EFFICIENCY</span>
</div>
</div>
</div>
</div>
<!-- HUD Data Strip -->
<div class="mt-8 mb-12 flex items-center justify-between border-y border-white/5 py-4">
<div class="flex flex-col">
<span class="font-mono text-[8px] text-slate-500 uppercase tracking-widest">Baseline</span>
<span class="font-mono text-lg text-on-surface">185.0</span>
</div>
<div class="h-8 w-px bg-tertiary/20"></div>
<div class="flex flex-col text-center">
<span class="font-mono text-[8px] text-slate-500 uppercase tracking-widest">Projection</span>
<span class="font-mono text-lg text-primary">447.2</span>
</div>
<div class="h-8 w-px bg-tertiary/20"></div>
<div class="flex flex-col text-right">
<span class="font-mono text-[8px] text-slate-500 uppercase tracking-widest">Delta</span>
<span class="font-mono text-lg text-secondary">+262.2</span>
</div>
</div>
<!-- CTA Action -->
<div class="mt-auto">
<button class="w-full bg-gradient-to-r from-[#4A8DFF] to-[#00D7B0] py-5 rounded-full font-headline font-bold text-on-primary flex items-center justify-center gap-3 group active:scale-95 transition-all duration-200 hover:shadow-[0_0_20px_rgba(0,215,176,0.3)]">
<span>Continue</span>
<span class="material-symbols-outlined group-hover:translate-x-1 transition-transform" data-icon="arrow_forward">arrow_forward</span>
</button>
<p class="text-center font-mono text-[10px] text-slate-500 mt-4 uppercase tracking-[0.2em]">Validated by ZVELT Kinetic Labs</p>
</div>
</main>
<!-- BottomNavBar Shell -->
<nav class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-center h-20 bg-[#121316]/90 backdrop-blur-xl border-t border-white/5 pb-safe shadow-[0_-10px_40px_rgba(0,0,0,0.5)]">
<button class="flex flex-col items-center justify-center text-[#00D7B0] bg-gradient-to-b from-[#00D7B0]/10 to-transparent p-3 relative after:content-[''] after:absolute after:top-0 after:w-1/2 after:h-[2px] after:bg-[#00D7B0] active:scale-90 transition-all duration-200">
<span class="material-symbols-outlined" data-icon="bolt" style="font-variation-settings: 'FILL' 1;">bolt</span>
</button>
<button class="flex flex-col items-center justify-center text-slate-600 p-3 hover:text-[#4A8DFF] transition-colors active:scale-90 transition-all duration-200">
<span class="material-symbols-outlined" data-icon="query_stats">query_stats</span>
</button>
<button class="flex flex-col items-center justify-center text-slate-600 p-3 hover:text-[#4A8DFF] transition-colors active:scale-90 transition-all duration-200">
<span class="material-symbols-outlined" data-icon="emoji_events">emoji_events</span>
</button>
<button class="flex flex-col items-center justify-center text-slate-600 p-3 hover:text-[#4A8DFF] transition-colors active:scale-90 transition-all duration-200">
<span class="material-symbols-outlined" data-icon="person">person</span>
</button>
</nav>
</body></html>