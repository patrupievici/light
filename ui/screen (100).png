<span class="text-xs font-semibold text-primary-fixed tracking-widest uppercase">Upgrade to View</span>
</div>
</div>
<!-- Metric 2 -->
<div class="bg-surface-container rounded-xl p-6 relative group overflow-hidden">
<div class="flex justify-between items-start mb-8">
<div>
<span class="text-on-surface-variant font-label text-[0.6875rem] uppercase tracking-widest block mb-1">Circadian Alignment</span>
<h4 class="font-headline text-xl font-bold">Sleep Architecture</h4>
</div>
<span class="material-symbols-outlined text-primary/40">lock</span>
</div>
<div class="flex items-center gap-4 opacity-20">
<div class="w-12 h-12 rounded-full border-4 border-tertiary border-t-transparent"></div>
<div class="flex flex-col gap-1">
<div class="h-2 w-24 bg-surface-container-highest rounded-full"></div>
<div class="h-2 w-16 bg-surface-container-highest rounded-full"></div>
</div>
</div>
<div class="absolute inset-0 bg-gradient-to-r from-transparent via-surface-container/80 to-transparent flex items-center justify-center translate-y-4 group-hover:translate-y-0 transition-all duration-300">
<span class="text-xs font-semibold text-primary-fixed tracking-widest uppercase">Upgrade to View</span>
</div>
</div>
</div>
</div>
<!-- Conversion Section -->
<div class="bg-surface-container-low rounded-xl p-8 md:p-12 border-l-4 border-primary/40">
<div class="grid md:grid-cols-2 gap-12 items-center">
<div>
<h3 class="text-3xl font-headline font-extrabold mb-4">Precision shouldn't be a luxury.</h3>
<p class="text-on-surface-variant mb-6 text-lg">
                        The premium tier offers more than just data—it offers clarity. Join 45,000+ athletes who use ZVELT to eliminate guesswork from their training cycles.
                    </p>
<ul class="space-y-4 mb-8">
<li class="flex items-start gap-3">
<span class="material-symbols-outlined text-primary text-sm mt-1">check_circle</span>
<span class="text-on-surface">Unlimited Historical Data Storage</span>
</li>
<li class="flex items-start gap-3">
<span class="material-symbols-outlined text-primary text-sm mt-1">check_circle</span>
<span class="text-on-surface">AI-Powered Training Readiness Forecasting</span>
</li>
<li class="flex items-start gap-3">
<span class="material-symbols-outlined text-primary text-sm mt-1">check_circle</span>
<span class="text-on-surface">Advanced Metabolic Signal Export (PDF/CSV)</span>
