<span class="material-symbols-outlined text-secondary text-sm">lock</span>
<span class="text-secondary font-semibold text-sm">Premium Locked</span>
</div>
</div>
</div>
</section>
<!-- Bento Grid Feature Display -->
<div class="grid grid-cols-1 md:grid-cols-12 gap-6 mb-12">
