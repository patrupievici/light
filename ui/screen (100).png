<div class="flex justify-between items-start mb-8">
<div>
<span class="text-on-surface-variant font-label text-[0.6875rem] uppercase tracking-widest block mb-1">Weekly Delta</span>
<h4 class="font-headline text-xl font-bold">Deep Recovery Score</h4>
</div>
<span class="material-symbols-outlined text-primary/40">lock</span>
</div>
<div class="h-16 w-full flex items-end gap-1 opacity-20">
<div class="flex-1 bg-primary h-[40%]"></div>
<div class="flex-1 bg-primary h-[60%]"></div>
<div class="flex-1 bg-primary h-[35%]"></div>
<div class="flex-1 bg-primary h-[80%]"></div>
<div class="flex-1 bg-primary h-[50%]"></div>
<div class="flex-1 bg-primary h-[90%]"></div>
</div>
