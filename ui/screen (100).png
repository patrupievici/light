<span class="material-symbols-outlined text-primary text-3xl">analytics</span>
</div>
<h3 class="font-headline text-2xl font-bold mb-2">Biometric Resonance Mapping</h3>
<p class="text-on-surface-variant max-w-md mb-8">
                        Visualizing the synchronization between your central nervous system and metabolic output. Requires ZVELT Premium.
                    </p>
<div class="flex flex-wrap justify-center gap-3">
<span class="bg-surface-container-high px-3 py-1 rounded-sm text-[0.6875rem] font-medium tracking-wider text-on-surface-variant border border-outline-variant/10">HRV TRENDS</span>
<span class="bg-surface-container-high px-3 py-1 rounded-sm text-[0.6875rem] font-medium tracking-wider text-on-surface-variant border border-outline-variant/10">METABOLIC EFFICIENCY</span>
<span class="bg-surface-container-high px-3 py-1 rounded-sm text-[0.6875rem] font-medium tracking-wider text-on-surface-variant border border-outline-variant/10">CNS READINESS</span>
</div>
</div>
<!-- Lock Overlay Gradient -->
<div class="absolute inset-0 bg-surface-dim/40 backdrop-blur-[2px] z-15"></div>
</div>
<!-- Side Metric Teasers -->
<div class="md:col-span-4 flex flex-col gap-6">
<!-- Metric 1 -->
