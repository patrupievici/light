{
  "name": "zvelt-backend",
  "version": "1.0.0",
  "description": "Zvelt fitness app backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "prisma migrate deploy && node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:purge-users": "tsx prisma/scripts/purge-all-users.ts",
    "db:check-gifs": "tsx prisma/scripts/check-exercise-gifs.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^4.27.0",
    "fastify-raw-body": "^4.3.0",
    "google-auth-library": "^9.14.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "prisma": "^5.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.7",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7"
  }
}
