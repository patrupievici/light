  /// JSON snapshot of mutable set fields after the edit.
  after     Json
  /// Optional user-supplied note (required when a weight jump is flagged).
  note      String?  @db.VarChar(500)
  /// True when this edit triggered the >2x personal-max anti-cheat path.
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  set WorkoutSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([setId])
  @@map("set_edit_audits")
}

model HealthConsent {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  /// e.g. heart_rate, sleep, weight, steps, hrv, blood_oxygen, ... or "all".
  consentType    String    @map("consent_type") @db.VarChar(64)
  granted        Boolean   @default(true)
  consentVersion String    @default("1") @map("consent_version") @db.VarChar(16)
  source         String?   @db.VarChar(32) // healthkit|health_connect|manual
  grantedAt      DateTime  @default(now()) @map("granted_at")
  revokedAt      DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, consentType])
  @@index([userId])
  @@map("health_consents")
}
