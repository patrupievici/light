// ─── GPS ACTIVITIES & SEGMENTS ───────────────────────────────────────────────

/// GPS outdoor session recorded by BackgroundTrackingService.
model GpsActivity {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  /// Explicit sport selected by the athlete. Null only for legacy/imported rows.
  activityType String?  @map("activity_type") @db.VarChar(16)
  routePoints Json      @default("[]") @map("route_points")
  distanceM   Float?    @map("distance_m")
  durationS   Int?      @map("duration_s")
  /// Server-computed metrics (recomputed from route_points, anti-cheat).
  elevGainM   Float?    @map("elev_gain_m")
  avgSpeedMs  Float?    @map("avg_speed_ms")
  /// Per-activity GPS privacy. private = only me; friends; public.
  visibility  String    @default("private")
  calories    Int?
  startedAt   DateTime  @map("started_at")
  endedAt     DateTime? @map("ended_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  segmentEfforts SegmentEffort[]

  @@index([userId, startedAt(sort: Desc)])
  @@map("activities")
}

/// Named stretch of road/trail that users can race against each other on.
model Segment {
  id          String   @id @default(uuid())
  name        String
  description String?
  routePoints Json     @default("[]") @map("route_points")
  startLat    Float?   @map("start_lat")
  startLng    Float?   @map("start_lng")
  endLat      Float?   @map("end_lat")
  endLng      Float?   @map("end_lng")
  distanceM   Float?   @map("distance_m")
  elevGainM   Float?   @map("elev_gain_m")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  creator User?           @relation("SegmentCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  efforts SegmentEffort[]

  @@index([startLat, startLng])
  @@index([createdBy])
  @@map("segments")
}

/// One attempt by a user on a segment.  Multiple per user are kept;
/// the leaderboard surfaces personal-best via DISTINCT ON.
model SegmentEffort {
  id           String   @id @default(uuid())
  segmentId    String   @map("segment_id")
  userId       String   @map("user_id")
  activityId   String?  @map("activity_id")
  elapsedTimeS Int      @map("elapsed_time_s")
  avgSpeedKmh  Float?   @map("avg_speed_kmh")
  createdAt    DateTime @default(now()) @map("created_at")

  segment  Segment      @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity GpsActivity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@index([segmentId, elapsedTimeS])
  @@index([userId, createdAt(sort: Desc)])
  @@map("segment_efforts")
}

