  consentVersion String   @default("1") @map("consent_version") @db.VarChar(16)
  source         String?  @db.VarChar(32)
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("health_consent_events")
}

/// Per-locale exercise name/description (translatable layer over the canonical
