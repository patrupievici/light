generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  createdAt            DateTime  @default(now()) @map("created_at")
  status               String    @default("active") // active|disabled|deleted
  /// Soft-delete grace window (opt-in via ZVELT_SOFT_DELETE). When set, the user
  /// is blocked from login and hard-erased by a cron after scheduledHardEraseAt.
  softDeletedAt        DateTime? @map("soft_deleted_at")
  scheduledHardEraseAt DateTime? @map("scheduled_hard_erase_at")

  profile                 UserProfile?
  authIdentities          AuthIdentity[]
  workouts                Workout[]
  posts                   Post[]
  postLikes               PostLike[]
  postComments            PostComment[]
  friendsFrom             Friendship[]            @relation("FriendshipUser")
  friendsTo               Friendship[]            @relation("FriendshipFriend")
  exerciseRanks           UserExerciseRank[]
  seasonStats             UserSeasonStat[]
  wallet                  Wallet?
  analyticsEvents         AnalyticsEvent[]
  userAchievements        UserAchievement[]
  trainingProfile         UserTrainingProfile?
  notifications           Notification[]
  dmConversationsLow      DirectConversation[]    @relation("DmUserLow")
  dmConversationsHigh     DirectConversation[]    @relation("DmUserHigh")
  directMessagesSent      DirectMessage[]
  pushTokens              UserPushToken[]
  nutritionLogDays        NutritionLogDay[]
  nutritionPlanDays       NutritionPlanDay[]
  plannedWorkouts         PlannedWorkout[]
  routines                Routine[]
  userPrograms            UserProgram[]
  customFoods             UserCustomFood[]
  favoriteFoods           UserFavoriteFood[]
  recipes                 UserRecipe[]
  challengesCreated       Challenge[]
  challengeParticipations ChallengeParticipant[]
  challengeProgressLogs   ChallengeProgressLog[]
  challengeMessages       ChallengeMessage[]
  stories                 Story[]
  storyLikes              StoryLike[]
  postBookmarks           PostBookmark[]
  postHides               PostHide[]
  postReports             PostReport[]
  gpsActivities           GpsActivity[]
  createdSegments         Segment[]               @relation("SegmentCreator")
  segmentEfforts          SegmentEffort[]
  wearableConnections     WearableConnection[]
  healthImports           UserHealthImport[]
  healthDailyMetrics      UserHealthDailyMetric[]
  healthConsents          HealthConsent[]
  storedMedia             StoredMedia[]

  @@map("users")
}

/// Durable user-uploaded image bytes. Relative /uploads URLs stay stable while
/// PostgreSQL provides persistence across stateless service deployments.
model StoredMedia {
  key         String   @id @db.VarChar(512)
  ownerUserId String   @map("owner_user_id")
  kind        String   @db.VarChar(16) // posts|avatars|stories
  contentType String   @map("content_type") @db.VarChar(32)
  data        Bytes
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, kind])
  @@map("stored_media")
}

/// Planned weekly workouts synced cross-device (pending/completed in calendar).
model PlannedWorkout {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  day           String   @map("day") @db.VarChar(10)
  weekStart     String   @map("week_start") @db.VarChar(10)
  title         String   @db.VarChar(140)
  kind          String   @db.VarChar(32) // gym|run|swim|cycle|walk|other
  status        String   @default("pending") @db.VarChar(16) // pending|completed
  /// AI-generated exercise list for the day: [{ name, sets, reps, restSeconds, notes?, whyThisExercise?, exerciseId? }]
  exercisesJson Json?    @map("exercises_json")
  /// Free-form AI commentary for the day (focus area, warmup hints, etc.).
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, day])
  @@index([userId, weekStart])
  @@map("planned_workouts")
}

/// Reusable workout templates the user saves and starts repeatedly (mockup 4
/// "Routines": Push Day, Pull Day, ...). `exercisesJson` mirrors
/// PlannedWorkout.exercisesJson so a routine can be built from an AI plan and
/// started via the same converter path.
model Routine {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  name          String   @db.VarChar(80)
  /// Optional muscle-group summary line, e.g. "Chest • Shoulders • Triceps".
  focus         String?  @db.VarChar(140)
  /// [{ name, sets, reps, restSeconds, notes?, exerciseId? }]
  exercisesJson Json     @map("exercises_json")
  position      Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("routines")
}

/// A multi-week periodized training program a user has STARTED (e.g. an instance
/// of the "5/3/1 BBB" or "PPL 6-day" code template). The template structure lives
/// in code (src/programming/program-templates.ts); this row holds the user's
/// instance + mutable progression state (training maxes / working weights) and is
/// materialized one DAY at a time into the existing PlannedWorkout → tracker flow.
model UserProgram {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  /// Code template id, e.g. 'stronglifts_5x5' | 'ppl_6day' | '531_bbb' | 'nsuns_4day'.
  templateId        String    @map("template_id") @db.VarChar(64)
  title             String    @db.VarChar(120)
  totalWeeks        Int       @map("total_weeks")
  daysPerWeek       Int       @map("days_per_week")
  /// Progression strategy: auto (RPE) | linear | double | reps_sum | percentage (% of training max).
  progressionScheme String    @default("auto") @map("progression_scheme") @db.VarChar(16)
  /// Planned deload cadence in weeks (0 = no scheduled deload).
  deloadCadence     Int       @default(4) @map("deload_cadence")
  status            String    @default("active") @db.VarChar(16) // active|completed|archived
  /// 1-based current training week within the program.
  currentWeek       Int       @default(1) @map("current_week")
  /// Per-slot mutable progression state, keyed by slotKey:
  /// { [slotKey]: { trainingMaxKg?, currentWeightKg?, currentReps?, failCount? } }
  stateJson         Json?     @map("state_json")
  /// User customizations layered over the code template (swaps, set/rep edits).
  /// null = use the code template verbatim.
  structureJson     Json?     @map("structure_json")
  /// Equipment the user selected at start (filters exercise resolution).
  equipmentTags     Json      @default("[]") @map("equipment_tags")
  startedAt         DateTime  @default(now()) @map("started_at")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("user_programs")
}

/// Log nutriție pe zi (calendar local client — YYYY-MM-DD), payload JSON: entries, waterMl, weightKg.
model NutritionLogDay {
  userId    String   @map("user_id")
  day       String   @db.VarChar(10)
  payload   Json     @default("{}")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, day])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("nutrition_log_days")
}

/// Generated daily nutrition targets for a week, synced cross-device.
model NutritionPlanDay {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  day       String   @db.VarChar(10)
  weekStart String   @map("week_start") @db.VarChar(10)
  goal      String   @db.VarChar(32)
  calories  Int
  proteinG  Int      @map("protein_g")
  carbsG    Int      @map("carbs_g")
  fatG      Int      @map("fat_g")
  waterMl   Int      @map("water_ml")
  mealPlan  Json?    @map("meal_plan")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@index([userId, weekStart])
  @@map("nutrition_plan_days")
}

/// Token FCM per dispozitiv — pentru push social (prieteni, like, DM).
model UserPushToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique @db.VarChar(512)
  platform  String   @db.VarChar(16) // android|ios|web
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_push_tokens")
}

model AuthIdentity {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  provider        String // email|apple|google
  providerSubject String   @map("provider_subject")
  email           String?
  passwordHash    String?  @map("password_hash")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerSubject])
  @@map("auth_identities")
}

model UserProfile {
  userId                 String   @id @map("user_id")
  username               String?  @unique
  displayName            String?  @map("display_name")
  bio                    String?
  unitSystem             String   @default("metric") @map("unit_system") // metric|imperial
  bodyweightKg           Decimal? @map("bodyweight_kg") @db.Decimal(6, 2)
  birthYear              Int?     @map("birth_year")
  sex                    String? // male|female|other|null
  privacyDefault         String   @default("friends") @map("privacy_default") // private|friends|public
  feedFriendsOnly        Boolean  @default(true) @map("feed_friends_only")
  discoveryOptIn         Boolean  @default(false) @map("discovery_opt_in")
  dmFriendsOnly          Boolean  @default(true) @map("dm_friends_only")
  showBodyStats          Boolean  @default(true) @map("show_body_stats")
  showActivityFeed       Boolean  @default(true) @map("show_activity_feed")
  heightCm               Decimal? @map("height_cm") @db.Decimal(6, 2)
  dailyCalories          Int?     @map("daily_calories")
  dailyProtein           Decimal? @map("daily_protein") @db.Decimal(8, 2)
  dailyCarbs             Decimal? @map("daily_carbs") @db.Decimal(8, 2)
  dailyFat               Decimal? @map("daily_fat") @db.Decimal(8, 2)
  dailyWaterMl           Int?     @map("daily_water_ml")
  /// Canonical nutrition-plan preferences. Daily macro targets above are the
  /// source of truth for both the diary and generated meal plans.
  nutritionGoal          String   @default("maintain") @map("nutrition_goal") @db.VarChar(16)
  nutritionActivityLevel String   @default("moderate") @map("nutrition_activity_level") @db.VarChar(16)
  nutritionDiet          String   @default("omnivore") @map("nutrition_diet") @db.VarChar(16)
  nutritionMealsPerDay   Int      @default(3) @map("nutrition_meals_per_day")
  /// Profile photo URL — Google OAuth `picture` at signup; users can upload
  /// via settings (saved to same field). Nullable → UI falls back to initials.
  photoUrl               String?  @map("photo_url")
  /// Gym-RPG style XP (gym_rpg_app.html); awarded on workout complete.
  gameXpTotal            Int      @default(0) @map("game_xp_total")
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

/// Input vector for program generation (goals, schedule, equipment, limits).
/// Demographics live on UserProfile; this extends training-specific prefs.
model UserTrainingProfile {
  userId                    String    @id @map("user_id")
  primaryGoal               String?   @map("primary_goal")
  secondaryGoals            Json      @default("[]") @map("secondary_goals")
  trainingLevel             String?   @map("training_level")
  gymExperience             String?   @map("gym_experience") @db.VarChar(500)
  daysPerWeek               Int?      @map("days_per_week")
  sessionMinutes            Int?      @map("session_minutes")
  equipment                 Json      @default("[]")
  injuriesLimitations       String?   @map("injuries_limitations") @db.Text
  splitPreference           String?   @map("split_preference")
  onboardingCompleted       Boolean   @default(false) @map("onboarding_completed")
  /// Textul liber din onboarding („Tell AI your goal”) — aceeași sursă ca la generarea planului.
  onboardingGoalText        String?   @map("onboarding_goal_text") @db.VarChar(2000)
  /// Sfaturi personalizate (al doilea apel AI pe același goal text).
  goalAdviceText            String?   @map("goal_advice_text") @db.Text
  /// Cached `GET /v1/me/workout-suggestion` for the UTC day (avoids duplicate DeepSeek calls).
  workoutSuggestionCache    Json?     @map("workout_suggestion_cache")
  workoutSuggestionCachedAt DateTime? @map("workout_suggestion_cached_at")
  /// Progressive-overload scheme: auto (RPE autoreg) | linear | double | reps_sum.
  progressionScheme         String    @default("auto") @map("progression_scheme")
  /// Per-user plate inventory (kg per side, JSON array) + bar weight for the plate calculator.
  plateInventoryKg          Json?     @map("plate_inventory_kg")
  barbellKg                 Float?    @map("barbell_kg")
  updatedAt                 DateTime  @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_training_profiles")
}

/// Cloud wearable / aggregator account connection. Tokens should stay with the
/// aggregator when possible; if provider tokens are ever stored here, encrypt
/// them before persistence.
model WearableConnection {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  provider       String    @db.VarChar(40) // terra|spike|rook|garmin|fitbit|huawei|...
  sourcePath     String    @map("source_path") @db.VarChar(40) // aggregator|huawei_health_kit|manual_bridge
  externalUserId String?   @map("external_user_id") @db.VarChar(160)
  status         String    @default("link_required") @db.VarChar(32)
  scopes         Json      @default("[]")
  metadata       Json      @default("{}")
  connectedAt    DateTime? @map("connected_at")
  lastSyncAt     DateTime? @map("last_sync_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, sourcePath])
  @@index([userId, provider])
  @@index([provider, status])
  @@map("wearable_connections")
}

/// Raw/semi-normalized health event imported from Health Connect or a cloud
/// wearable aggregator. Daily summaries should be derived from this table.
model UserHealthImport {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  metricType   String   @map("metric_type") @db.VarChar(48)
  sourcePath   String   @map("source_path") @db.VarChar(40)
  provider     String   @db.VarChar(64)
  sourceApp    String?  @map("source_app") @db.VarChar(120)
  sourceDevice String?  @map("source_device") @db.VarChar(120)
  externalId   String   @map("external_id") @db.VarChar(240)
  startAt      DateTime @map("start_at")
  endAt        DateTime @map("end_at")
  value        Decimal? @db.Decimal(14, 4)
  unit         String?  @db.VarChar(32)
  payload      Json     @default("{}")
  importedAt   DateTime @default(now()) @map("imported_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourcePath, provider, metricType, externalId])
  @@index([userId, metricType, startAt])
  @@index([userId, sourcePath, provider])
  @@map("user_health_imports")
}

/// Source-aware daily rollup. A later reconciliation job can derive a single
/// user-facing daily summary without double-counting overlapping providers.
model UserHealthDailyMetric {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  day        String   @db.VarChar(10)
  sourcePath String   @map("source_path") @db.VarChar(40)
  provider   String   @db.VarChar(64)
  steps      Int?
  distanceM  Decimal? @map("distance_m") @db.Decimal(14, 2)
  activeKcal Decimal? @map("active_kcal") @db.Decimal(14, 2)
  restingHr  Decimal? @map("resting_hr") @db.Decimal(6, 2)
  avgHr      Decimal? @map("avg_hr") @db.Decimal(6, 2)
  hrvMs      Decimal? @map("hrv_ms") @db.Decimal(8, 2)
  sleepMin   Int?     @map("sleep_min")
  spo2Pct    Decimal? @map("spo2_pct") @db.Decimal(6, 2)
  payload    Json     @default("{}")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day, sourcePath, provider])
  @@index([userId, day])
  @@map("user_health_daily_metrics")
}

// ─── EXERCISES ───────────────────────────────────────────────────────────────

model Exercise {
  id                 String   @id @default(uuid())
  name               String
  primaryMuscle      String?  @map("primary_muscle")
  equipment          String?
  rankModel          String   @default("WEIGHTED") @map("rank_model") // WEIGHTED|BW_REPS|TIME
  /// BW_REPS: fracțiune din greutatea corporală tratată ca „încărcare” (ex. push-up ~0.64, pull-up 1.0). Opțional; altfel se deduce din nume.
  bwStrengthFraction Decimal? @map("bw_strength_fraction") @db.Decimal(4, 3)
  category           String   @default("strength") // strength|explosive|bodyweight|cardio
  /// Primary pattern for exercise selection / program structure
  movementPattern    String   @default("skill_stability") @map("movement_pattern")
  secondaryPatterns  Json     @default("[]") @map("secondary_patterns")
  /// Structured secondary muscles (controlled vocabulary, see constants/muscles)
  /// — feeds the muscle map, recovery model, and substitution muscle-overlap.
  secondaryMuscles   Json     @default("[]") @map("secondary_muscles")
  /// Variation grouping: canonical parent exercise (a front-squat variation ->
  /// back squat). Null = top-level/canonical.
  parentExerciseId   String?  @map("parent_exercise_id")
  /// Catalogue curation metadata.
  provenance         String?  @db.VarChar(64)
  sourceLicense      String?  @map("source_license") @db.VarChar(64)
  reviewStatus       String?  @map("review_status") @db.VarChar(24)
  /// 1 = low local fatigue … 5 = very demanding
  fatigueScore       Int      @default(3) @map("fatigue_score")
  goalTags           Json     @default("[]") @map("goal_tags")
  contraindications  Json     @default("[]")
  beginnerSuitable   Boolean  @default(true) @map("beginner_suitable")

  isRanked        Boolean @default(true) @map("is_ranked")
  isCustom        Boolean @default(false) @map("is_custom")
  createdByUserId String? @map("created_by_user_id")

  workoutExercises WorkoutExercise[]
  exerciseRanks    UserExerciseRank[]

  @@map("exercises")
}

// ─── WORKOUTS ────────────────────────────────────────────────────────────────

model Workout {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  status    String    @default("draft") // draft|completed|posted
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  timezone  String?
  notes     String?

  user      User              @relation(fields: [userId], references: [id])
  exercises WorkoutExercise[]
  post      Post?

  @@map("workouts")
}

model WorkoutExercise {
  id                 String  @id @default(uuid())
  workoutId          String  @map("workout_id")
  exerciseId         String  @map("exercise_id")
  position           Int
  restSecondsDefault Int?    @map("rest_seconds_default")
  /// Prescription from generator, e.g. "8–12" — shown in app; optional.
  repRangeHint       String? @map("rep_range_hint") @db.VarChar(80)

  workout  Workout      @relation(fields: [workoutId], references: [id])
  exercise Exercise     @relation(fields: [exerciseId], references: [id])
  sets     WorkoutSet[]

  @@unique([workoutId, position])
  @@map("workout_exercises")
}

model WorkoutSet {
  id                String   @id @default(uuid())
  workoutExerciseId String   @map("workout_exercise_id")
  setIndex          Int      @map("set_index")
  weightKg          Decimal  @default(0) @map("weight_kg") @db.Decimal(7, 2)
  reps              Int
  rpe               Decimal? @db.Decimal(3, 1)
  tag               String   @default("WORK") // WORK|WARMUP|DROP
  isCompleted       Boolean  @default(false) @map("is_completed")
  /// Client-side idempotency token: retries from the offline queue reuse the
  /// same row instead of creating duplicates.
  clientSetId       String?  @unique @map("client_set_id")
  /// Optional justification note. Required (anti-cheat) when the weight is a >2x
  /// jump vs the user's recent personal max for this exercise.
  note              String?  @map("note")
  createdAt         DateTime @default(now()) @map("created_at")

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id])
  setEditAudits   SetEditAudit[]

  @@unique([workoutExerciseId, setIndex])
  @@map("workout_sets")
}

// ─── POSTS & SOCIAL ──────────────────────────────────────────────────────────

model Post {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  /// Null = postare doar social (fără antrenament atașat)
  workoutId  String?  @unique @map("workout_id")
  visibility String   @default("friends") // private|friends|public
  caption    String?
  /// Cale relativă servită de /uploads/... (ex. /uploads/posts/{id}.jpg)
  imageUrl   String?  @map("image_url") @db.VarChar(512)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  user            User                @relation(fields: [userId], references: [id])
  workout         Workout?            @relation(fields: [workoutId], references: [id])
  privacySettings PostPrivacySetting?
  likes           PostLike[]
  comments        PostComment[]
  bookmarks       PostBookmark[]
  hides           PostHide[]
  reports         PostReport[]
  editCount       Int                 @default(0) @map("edit_count")
  lastEditAt      DateTime?           @map("last_edit_at")
  /// True when the attached workout set a personal record (rank LP gained on
  /// post). Drives the Feed "PRs" filter (kind=pr). Set at post creation.
  isPr            Boolean             @default(false) @map("is_pr")

  @@map("posts")
}

/// Provocări sociale (vizibilitate friends | public).
model Challenge {
  id           String   @id @default(uuid())
  creatorId    String   @map("creator_id")
  kind         String // pullUps|deadlift|squat|benchPress|custom
  customTitle  String?  @map("custom_title") @db.VarChar(200)
  visibility   String // friends|public
  /// Seeded "official" public rooms (Camere publice) run by the Zvelt system
  /// account. Surfaced first in Discover; user-created challenges are false.
  isOfficial   Boolean  @default(false) @map("is_official")
  targetHint   String?  @map("target_hint") @db.VarChar(120)
  durationDays Int      @map("duration_days")
  endsAt       DateTime @map("ends_at")
  createdAt    DateTime @default(now()) @map("created_at")

  // ── Scoring engine (Feed & Challenges v1). NULL scoringType = legacy/manual
  //    challenge (scored from manual progress logs). Set = auto-scored from
  //    workouts via challenge-scoring.service + challenge-recalc.service.
  scoringType        String?   @map("scoring_type") // workout_streak|most_workouts|total_volume|pr_battle|consistency
  startsAt           DateTime? @map("starts_at")
  ruleMinDurationMin Int?      @map("rule_min_duration_min")
  ruleMinSets        Int?      @map("rule_min_sets")
  ruleMinExercises   Int?      @map("rule_min_exercises")
  ruleMaxPerDay      Int?      @map("rule_max_per_day")
  ruleExerciseId     String?   @map("rule_exercise_id") // pr_battle target exercise
  ruleTargetDays     Int?      @map("rule_target_days") // consistency target
  scoringVersion     Int       @default(1) @map("scoring_version")

  creator      User                   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  participants ChallengeParticipant[]
  progressLogs ChallengeProgressLog[]
  messages     ChallengeMessage[]

  @@index([creatorId, endsAt])
  @@index([visibility, endsAt])
  @@index([visibility, isOfficial, endsAt])
  @@map("challenges")
}

/// One "Log progress" entry in a race — totals/standings are SUM(amount)
/// per user. Append-only audit trail (anti-cheat principle: no silent edits).
model ChallengeProgressLog {
  id          String   @id @default(uuid())
  challengeId String   @map("challenge_id")
  userId      String   @map("user_id")
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([challengeId, userId])
  @@index([challengeId, createdAt])
  @@map("challenge_progress_logs")
}

/// Shared race chat — visible to everyone who can see the challenge.
model ChallengeMessage {
  id          String   @id @default(uuid())
  challengeId String   @map("challenge_id")
  userId      String   @map("user_id")
  body        String   @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([challengeId, createdAt])
  @@map("challenge_messages")
}

model PostPrivacySetting {
  postId         String  @id @map("post_id")
  hideWeights    Boolean @default(false) @map("hide_weights")
  hideReps       Boolean @default(false) @map("hide_reps")
  hideBodyweight Boolean @default(false) @map("hide_bodyweight")

  post Post @relation(fields: [postId], references: [id])

  @@map("post_privacy_settings")
}

model Friendship {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  friendUserId String   @map("friend_user_id")
  status       String // requested|accepted|blocked
  createdAt    DateTime @default(now()) @map("created_at")

  user   User @relation("FriendshipUser", fields: [userId], references: [id])
  friend User @relation("FriendshipFriend", fields: [friendUserId], references: [id])

  @@unique([userId, friendUserId])
  @@map("friendships")
}

/// In-app notifications (friend requests, likes, comments). Push tokens = viitor.
model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String // friend_request|friend_accepted|post_like|post_comment
  actorId   String?   @map("actor_id")
  payload   Json      @default("{}")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@map("notifications")
}

/// Idempotency ledger for SCHEDULED notifications (streak-risk, challenge
/// ending/ended). Each row claims "this notification was already sent" so a
/// cron re-run or a service restart mid-batch never double-notifies. dedupeKey
/// is per-type: a UTC date (YYYY-MM-DD) for streak-risk, the challengeId for
/// challenge ending/ended. FK-less; an eventual cleanup prunes old rows.
model NotificationSentLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   @db.VarChar(40)
  dedupeKey String   @map("dedupe_key") @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, type, dedupeKey])
  @@index([createdAt])
  @@map("notification_sent_logs")
}

model PostLike {
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@id([postId, userId])
  @@map("post_likes")
}

model PostComment {
