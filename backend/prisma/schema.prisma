  userLow  User            @relation("DmUserLow", fields: [userLowId], references: [id], onDelete: Cascade)
  userHigh User            @relation("DmUserHigh", fields: [userHighId], references: [id], onDelete: Cascade)
  messages DirectMessage[]

  @@unique([userLowId, userHighId])
  @@index([userLowId])
  @@index([userHighId])
  @@map("direct_conversations")
}

model DirectMessage {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  body           String   @db.VarChar(2000)
  createdAt      DateTime @default(now()) @map("created_at")

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User               @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("direct_messages")
}

// ─── RANKS ───────────────────────────────────────────────────────────────────

model UserExerciseRank {
  userId        String   @map("user_id")
  exerciseId    String   @map("exercise_id")
  bestE1rmKg    Decimal  @map("best_e1rm_kg") @db.Decimal(7, 2)
  strengthRatio Decimal  @map("strength_ratio") @db.Decimal(8, 4)
  lpTotal       Int      @map("lp_total")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id])
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@id([userId, exerciseId])
  @@map("user_exercise_ranks")
}

/// Durable per-lift autoregulation state, written on workout complete.
/// Records what was actually logged last (weight/reps/max RPE) and the engine's
/// decision for next time (source/weight/reason via autoregulateLoad). Read by
/// the next-session reconcile + the "next session" UI. No FK relations on
/// purpose — keep migration risk minimal; absent row = fall back to last-set query.
model UserExerciseProgress {
  userId        String   @map("user_id")
  exerciseId    String   @map("exercise_id")
  lastWeightKg  Decimal? @map("last_weight_kg") @db.Decimal(7, 2)
  lastReps      Int?     @map("last_reps")
  lastRpe       Decimal? @map("last_rpe") @db.Decimal(3, 1)
  lastWorkoutAt DateTime @map("last_workout_at")
  /// progression | hold | deload | no_history — the autoregulation decision.
  nextSource    String?  @map("next_source") @db.VarChar(16)
  nextWeightKg  Decimal? @map("next_weight_kg") @db.Decimal(7, 2)
  nextReason    String?  @map("next_reason")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([userId, exerciseId])
  @@index([userId])
  @@map("user_exercise_progress")
}

/// Backend-persisted body measurements (was device-only). Generic type+value so
/// weight / body-fat / circumferences share one table. FK-less like
/// UserExerciseProgress — erasure cleans it explicitly.
model UserBodyMeasurement {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  type       String   @db.VarChar(32) // weight|body_fat|chest|waist|hips|arm|thigh|...
  valueNum   Decimal  @map("value_num") @db.Decimal(10, 3)
  unit       String   @db.VarChar(12) // kg|lb|cm|in|pct
  measuredAt DateTime @map("measured_at")
  source     String?  @db.VarChar(24)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([userId, type, measuredAt(sort: Desc)])
  @@map("user_body_measurements")
}

/// Durable raw-envelope inbox for provider webhooks (Terra/wearables). Lets a
/// webhook be acked instantly and processed/retried by a worker instead of
/// best-effort in-handler. Not user-scoped (provider events).
model WebhookInbox {
  id          String    @id @default(uuid())
  provider    String    @db.VarChar(40)
  sourcePath  String?   @map("source_path") @db.VarChar(40)
  eventType   String?   @map("event_type") @db.VarChar(64)
  externalId  String?   @map("external_id") @db.VarChar(240)
  payload     Json
  status      String    @default("received") @db.VarChar(16) // received|processed|failed
  attempts    Int       @default(0)
  error       String?   @db.Text
  receivedAt  DateTime  @default(now()) @map("received_at")
  processedAt DateTime? @map("processed_at")

  @@index([status, receivedAt])
  @@map("webhook_inbox")
}

/// Reusable saved-meal templates for one-tap re-logging. FK-less; erasure cleans it.
model NutritionMealTemplate {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String   @db.VarChar(80)
  itemsJson Json     @map("items_json")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([userId])
  @@map("nutrition_meal_templates")
}

/// User-created custom foods (MyFitnessPal-style). Macros stored canonical per-100g
/// to match the diary FoodItem shape. Referenced from a diary entry via
/// foodId = `custom:<id>`.
model UserCustomFood {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String   @db.VarChar(120)
  brand           String?  @db.VarChar(120)
  caloriesPer100g Float    @map("calories_per_100g")
  proteinPer100g  Float    @map("protein_per_100g")
  carbsPer100g    Float    @map("carbs_per_100g")
  fatPer100g      Float    @map("fat_per_100g")
  servingGrams    Float?   @map("serving_grams")
  servingLabel    String?  @map("serving_label") @db.VarChar(60)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_custom_foods")
}

/// Starred foods for one-tap re-logging. foodId is the source key
/// (`off:<barcode>` | `usda_fdc_<id>` | `custom:<id>`); macros cached per-100g.
model UserFavoriteFood {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  foodId          String   @map("food_id") @db.VarChar(120)
  name            String   @db.VarChar(120)
  brand           String?  @db.VarChar(120)
  caloriesPer100g Float    @map("calories_per_100g")
  proteinPer100g  Float    @map("protein_per_100g")
  carbsPer100g    Float    @map("carbs_per_100g")
  fatPer100g      Float    @map("fat_per_100g")
  servingGrams    Float?   @map("serving_grams")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, foodId])
  @@index([userId])
  @@map("user_favorite_foods")
}

/// Multi-ingredient recipe; per-serving macros derived from the ingredient totals
/// on apply. ingredientsJson: [{ name, grams, caloriesPer100g, proteinPer100g,
/// carbsPer100g, fatPer100g, foodId? }].
model UserRecipe {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String   @db.VarChar(120)
  ingredientsJson Json     @map("ingredients_json")
  servings        Int      @default(1)
  totalCalories   Float    @map("total_calories")
  totalProtein    Float    @map("total_protein")
  totalCarbs      Float    @map("total_carbs")
  totalFat        Float    @map("total_fat")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_recipes")
}

/// Append-only consent ledger (GDPR Art. 7 verifiable history). Each grant/revoke
