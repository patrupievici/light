# Copy to .env and fill in values (never commit .env).

# PostgreSQL (Supabase: Settings → Database → Connection string URI)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# Auth — use a long random string in production
JWT_SECRET="change-me-in-production"
# Optional overrides:
# JWT_EXPIRES_IN=15m
# REFRESH_TOKEN_EXPIRES_DAYS=30

# Server
# NODE_ENV=development
# PORT=3000

# Google Sign-In (OAuth 2.0 Client ID from Google Cloud Console)
# GOOGLE_CLIENT_ID=

# FCM server-side (JSON minified service account key, or path if you add file-based loading)
# FIREBASE_PROJECT_ID=
# FIREBASE_SERVICE_ACCOUNT_JSON=

# OpenWeather
# OPENWEATHER_API_KEY=

# USDA FoodData Central — food search in app (server proxy; never ship key in mobile builds).
# https://fdc.nal.usda.gov/api-key-signup.html
# USDA_API_KEY=

# After pulling: `npm run db:migrate` (includes nutrition_log_days for meal sync).

# AI chat + daily quote cron @ 00:00 Europe/London (table global_daily_quotes)
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Optional second Postgres: exercise name → demo GIF URL (e.g. Supabase from zveltutzu export).
# Table defaults below; `exercise_name` must match seed names case-insensitively (trimmed).
# Example:
#   CREATE TABLE exercise_gifs (exercise_name text PRIMARY KEY, gif_url text NOT NULL);
#   INSERT INTO exercise_gifs VALUES ('Bench Press', 'https://....gif');
# EXERCISE_MEDIA_DATABASE_URL=
# EXERCISE_MEDIA_SCHEMA=
# EXERCISE_MEDIA_TABLE=exercise_gifs
# EXERCISE_MEDIA_NAME_COLUMN=exercise_name
# EXERCISE_MEDIA_URL_COLUMN=gif_url

# ExerciseDB via RapidAPI — powers /v1/exercises/db/* proxy + reference GIF dialog in app.
# https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
# EXERCISEDB_KEY=
