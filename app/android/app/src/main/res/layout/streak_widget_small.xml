<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/streak_small_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/today_widget_background"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/streak_small_brand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_brand"
        android:textColor="#2F6BFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.08" />

    <ImageView
        android:id="@+id/streak_small_flame"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginTop="4dp"
        android:src="@drawable/streak_widget_flame"
        android:contentDescription="@string/widget_streak_flame_desc" />

    <TextView
        android:id="@+id/streak_small_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#FFFFFF"
        android:textSize="40sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="0.9"
        android:text="0" />

    <TextView
        android:id="@+id/streak_small_days_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_streak_days"
        android:textColor="#A9B0C0"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/streak_small_at_risk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:text="@string/widget_at_risk"
        android:textColor="#FFB020"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />
</LinearLayout>
