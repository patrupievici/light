<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/challenge_small_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/today_widget_background"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/widget_pack_people"
        android:contentDescription="@string/widget_challenge_title" />

    <TextView
        android:id="@+id/challenge_small_rank"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="#–"
        android:textColor="#7B52FF"
        android:textSize="40sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="0.85"
        android:includeFontPadding="false" />

    <TextView
        android:id="@+id/challenge_small_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_challenge_title"
        android:textColor="#A9B0C0"
        android:textSize="10sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/challenge_small_gap"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="—"
        android:textColor="#7B52FF"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/challenge_small_gap_to"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#A9B0C0"
        android:textSize="10sp" />

</LinearLayout>
