<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/recovery_small_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/today_widget_background"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Ring + score overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/recovery_ring_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:contentDescription="@string/widget_recovery_ring_desc" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/recovery_score_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="0.9" />
        </LinearLayout>
    </FrameLayout>

    <!-- Status label -->
    <TextView
        android:id="@+id/recovery_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/widget_recovery_ready"
        android:textColor="#2EEA7A"
        android:textSize="11sp"
        android:textStyle="bold" />

    <!-- Checkmark circle -->
    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginTop="4dp"
        android:src="@drawable/widget_check_circle"
        android:contentDescription="@string/widget_recovery_ready" />

</LinearLayout>
