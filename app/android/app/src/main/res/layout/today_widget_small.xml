<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/today_small_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/today_widget_background"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/today_small_brand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_brand"
        android:textColor="#2F6BFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.06" />

    <TextView
        android:id="@+id/today_small_streak"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/today_small_workouts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#A9B0C0"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/today_small_at_risk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/widget_at_risk"
        android:textColor="#FFB020"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />
</LinearLayout>
