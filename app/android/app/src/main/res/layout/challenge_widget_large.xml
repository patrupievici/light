<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/challenge_large_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/today_widget_background"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Header: people icon · challenge name · days left -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/widget_pack_people"
            android:contentDescription="@string/widget_challenge_title" />

        <TextView
            android:id="@+id/challenge_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/widget_challenge_title"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/challenge_days_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#7B52FF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Leaderboard bitmap -->
    <ImageView
        android:id="@+id/challenge_leaderboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:scaleType="fitXY"
        android:contentDescription="@string/widget_challenge_leaderboard_desc" />

    <!-- CTA row -->
    <LinearLayout
        android:id="@+id/challenge_cta_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_card_dark"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/streak_widget_flame"
            android:contentDescription="@string/widget_streak_flame_desc" />

        <TextView
            android:id="@+id/challenge_cta_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/widget_challenge_cta_default"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="8dp"
            android:text="›"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:gravity="center"
            android:background="@drawable/widget_purple_btn" />
    </LinearLayout>

</LinearLayout>
