<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/day_streak_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/today_widget_background"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="8dp">

    <ImageView
        android:id="@+id/day_streak_flame"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:src="@drawable/streak_widget_flame"
        android:contentDescription="@string/widget_streak_flame_desc" />

    <TextView
        android:id="@+id/day_streak_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="0"
        android:textColor="#FF5A1F"
        android:textSize="44sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="0.9"
        android:includeFontPadding="false" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_day_streak_label"
        android:textColor="#A9B0C0"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.04" />

    <TextView
        android:id="@+id/day_streak_at_risk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:text="@string/widget_at_risk"
        android:textColor="#FFB020"
        android:textSize="9sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>
